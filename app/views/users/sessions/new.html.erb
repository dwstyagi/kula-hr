<div class="min-h-screen flex">

  <%# Left panel — branding %>
  <div class="hidden lg:flex lg:w-1/2 bg-linear-to-br from-blue-600 via-blue-700 to-indigo-800 flex-col justify-between p-12 relative overflow-hidden">

    <%# Background decoration %>
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-white/5"></div>
      <div class="absolute -bottom-32 -left-16 w-80 h-80 rounded-full bg-white/5"></div>
      <div class="absolute top-1/2 left-1/3 w-64 h-64 rounded-full bg-white/5"></div>
    </div>

    <div class="relative z-10">
      <%# Logo %>
      <div class="flex items-center gap-3">
        <div class="h-10 w-10 rounded-xl bg-white/20 backdrop-blur flex items-center justify-center text-white font-bold text-xl">K</div>
        <span class="text-white font-bold text-2xl tracking-tight">Kula HR</span>
      </div>
    </div>

    <div class="relative z-10 space-y-8">
      <div>
        <h2 class="text-4xl font-bold text-white leading-tight">
          Payroll & HR<br>made simple.
        </h2>
        <p class="text-blue-200 mt-4 text-lg leading-relaxed">
          Manage your team, leaves, and payroll — all in one place, built for Indian companies.
        </p>
      </div>

      <div class="space-y-4">
        <% [
          ["Automated Indian payroll with PF, ESI & PT", "M9 12.75l-3-3m0 0l-3 3m3-3v7.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z"],
          ["Leave management with real-time approval flow", "M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75"],
          ["Multi-company with tenant isolation", "M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z"]
        ].each do |text, path| %>
          <div class="flex items-start gap-3">
            <div class="mt-0.5 shrink-0 h-5 w-5 rounded-full bg-white/20 flex items-center justify-center">
              <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <span class="text-blue-100 text-sm leading-relaxed"><%= text %></span>
          </div>
        <% end %>
      </div>
    </div>

    <div class="relative z-10">
      <p class="text-blue-300 text-sm">© <%= Date.today.year %> Kula HR. Built for India.</p>
    </div>
  </div>

  <%# Right panel — form %>
  <div class="flex-1 flex flex-col justify-center px-8 sm:px-16 lg:px-20 py-12 bg-gray-50">
    <div class="w-full max-w-sm mx-auto">

      <%# Mobile logo (hidden on lg) %>
      <div class="flex items-center gap-2 mb-10 lg:hidden">
        <div class="h-8 w-8 rounded-lg bg-blue-600 flex items-center justify-center text-white font-bold text-lg">K</div>
        <span class="font-bold text-xl text-gray-900">Kula HR</span>
      </div>

      <div class="mb-8">
        <h1 class="text-2xl font-bold text-gray-900">Welcome back</h1>
        <p class="text-gray-500 text-sm mt-1">Sign in to your company account</p>
      </div>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name),
                   html: { class: "space-y-5" }) do |f| %>

        <%# Flash errors from Devise %>
        <% if flash[:alert].present? %>
          <div class="rounded-lg bg-red-50 border border-red-200 p-4">
            <div class="flex gap-3">
              <svg class="w-5 h-5 text-red-400 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd"/>
              </svg>
              <p class="text-sm text-red-700"><%= flash[:alert] %></p>
            </div>
          </div>
        <% end %>

        <div>
          <%= f.label :email, "Work email", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              placeholder: "you@company.com",
              class: "w-full rounded-lg border-gray-300 bg-white shadow-sm text-sm focus:border-blue-500 focus:ring-blue-500 placeholder-gray-400" %>
        </div>

        <div>
          <div class="flex items-center justify-between mb-1.5">
            <%= f.label :password, "Password", class: "block text-sm font-medium text-gray-700" %>
          </div>
          <%= f.password_field :password,
              autocomplete: "current-password",
              placeholder: "••••••••",
              class: "w-full rounded-lg border-gray-300 bg-white shadow-sm text-sm focus:border-blue-500 focus:ring-blue-500 placeholder-gray-400" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-2">
            <%= f.check_box :remember_me,
                class: "rounded border-gray-300 text-blue-600 shadow-sm focus:ring-blue-500" %>
            <%= f.label :remember_me, "Keep me signed in",
                class: "text-sm text-gray-600 cursor-pointer" %>
          </div>
        <% end %>

        <%= f.submit "Sign in",
            class: "w-full py-2.5 px-4 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded-lg shadow-sm transition-colors cursor-pointer" %>
      <% end %>

      <p class="mt-8 text-center text-xs text-gray-400">
        Having trouble signing in? Contact your HR administrator.
      </p>
    </div>
  </div>

</div>
