<div class="min-h-screen bg-stone-50 flex items-center justify-center px-4">
  <div class="w-full max-w-md text-center">
    <div class="inline-flex items-center justify-center w-16 h-16 bg-green-100 rounded-full mb-6">
      <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
    </div>

    <h1 class="page-title text-2xl">Check Your Inbox</h1>
    <p class="mt-3 text-sm text-stone-500 max-w-sm mx-auto">
      If your details match our records, you'll receive an activation email shortly.
      Click the link in the email to set your password and access your portal.
    </p>

    <div class="mt-6 bg-amber-50 border border-amber-100 rounded-lg px-5 py-4 text-sm text-amber-700 text-left">
      <strong>Didn't receive it?</strong>
      <ul class="mt-2 space-y-1 list-disc list-inside text-amber-600">
        <li>Check your spam or junk folder</li>
        <li>Make sure you used your work email</li>
        <li>Wait a few minutes — delivery can take up to 5 minutes</li>
        <li>Contact your HR admin if the issue persists</li>
      </ul>
    </div>

    <p class="mt-8 text-xs text-stone-400">
      <%= link_to "← Try again", employee_activation_path(params[:token]), class: "text-kula-600 hover:underline" %>
    </p>
  </div>
</div>
