<%# Banner %>
<div style="background:linear-gradient(135deg,#DC2626 0%,#EF4444 100%);padding:36px 40px 32px;">
  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td>
        <p style="margin:0 0 6px;font-size:12px;font-weight:600;color:#FECACA;letter-spacing:1px;text-transform:uppercase;">Leave Encashment</p>
        <h1 style="margin:0;font-size:26px;font-weight:700;color:#ffffff;line-height:1.2;">Encashment Not Approved</h1>
        <p style="margin:10px 0 0;font-size:15px;color:#FEE2E2;"><%= @leave_type.name %> &middot; <%= @request.number_of_days.to_i %> Day(s)</p>
      </td>
      <td align="right" valign="top">
        <div style="background:rgba(255,255,255,0.15);border-radius:50%;width:56px;height:56px;line-height:56px;text-align:center;font-size:28px;">❌</div>
      </td>
    </tr>
  </table>
</div>

<%# Body %>
<div style="padding:36px 40px;">
  <p style="margin:0 0 24px;font-size:15px;color:#374151;line-height:1.6;">
    Hi <%= @employee.first_name %>,<br><br>
    Your encashment request for <strong><%= @request.number_of_days.to_i %> <%= @leave_type.name %> day(s)</strong> was not approved.
  </p>

  <% if @request.rejection_reason.present? %>
    <div style="background:#FEF2F2;border:1px solid #FECACA;border-radius:10px;padding:16px 20px;margin-bottom:24px;">
      <p style="margin:0 0 6px;font-size:12px;font-weight:600;color:#DC2626;text-transform:uppercase;letter-spacing:0.5px;">Reason</p>
      <p style="margin:0;font-size:14px;color:#374151;"><%= @request.rejection_reason %></p>
    </div>
  <% end %>

  <p style="margin:0 0 24px;font-size:14px;color:#374151;line-height:1.6;">
    Your <strong><%= @request.number_of_days.to_i %> <%= @leave_type.name %> day(s)</strong> will
    <strong>carry forward automatically</strong> to the next financial year on April 1st.
    No action is needed from your side.
  </p>

  <p style="margin:0;font-size:14px;color:#9CA3AF;">
    — The Kula HR System
  </p>
</div>
