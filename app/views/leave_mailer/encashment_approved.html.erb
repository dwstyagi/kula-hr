<%# Banner %>
<div style="background:linear-gradient(135deg,#059669 0%,#10B981 100%);padding:36px 40px 32px;">
  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td>
        <p style="margin:0 0 6px;font-size:12px;font-weight:600;color:#A7F3D0;letter-spacing:1px;text-transform:uppercase;">Leave Encashment</p>
        <h1 style="margin:0;font-size:26px;font-weight:700;color:#ffffff;line-height:1.2;">Encashment Approved ✓</h1>
        <p style="margin:10px 0 0;font-size:15px;color:#D1FAE5;"><%= @leave_type.name %> &middot; <%= @request.number_of_days.to_i %> Day(s)</p>
      </td>
      <td align="right" valign="top">
        <div style="background:rgba(255,255,255,0.15);border-radius:50%;width:56px;height:56px;line-height:56px;text-align:center;font-size:28px;">✅</div>
      </td>
    </tr>
  </table>
</div>

<%# Body %>
<div style="padding:36px 40px;">
  <p style="margin:0 0 24px;font-size:15px;color:#374151;line-height:1.6;">
    Hi <%= @employee.first_name %>,<br><br>
    Your encashment request for <strong><%= @request.number_of_days.to_i %> <%= @leave_type.name %> day(s)</strong> has been approved.
  </p>

  <div style="background:#F0FDF4;border:1px solid #BBF7D0;border-radius:10px;padding:20px 24px;margin-bottom:28px;text-align:center;">
    <p style="margin:0 0 4px;font-size:13px;color:#16A34A;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Encashment Amount</p>
    <p style="margin:0;font-size:36px;font-weight:700;color:#14532D;">₹<%= number_with_delimiter(@request.encashment_amount.to_i) %></p>
    <p style="margin:8px 0 0;font-size:13px;color:#16A34A;">Will be added to your next payroll</p>
  </div>

  <p style="margin:0 0 24px;font-size:14px;color:#6B7280;line-height:1.6;">
    These days will <strong>not</strong> carry forward to the next financial year.
    The payout will appear as a separate line item on your payslip.
  </p>

  <p style="margin:0;font-size:14px;color:#9CA3AF;">
    — The Kula HR System
  </p>
</div>
