<% content_for(:page_title, "New Tenant") %>

<div class="max-w-2xl">
  <div class="mb-6 flex items-center gap-3">
    <%= link_to platform_admin_tenants_path, class: "inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-700" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      Back to Tenants
    <% end %>
  </div>

  <div class="bg-white rounded-lg border border-gray-200 p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-6">Create New Tenant</h2>

    <% if flash[:alert] %>
      <div class="mb-4 bg-red-50 border border-red-200 rounded-lg p-4 text-sm text-red-700">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <%= form_with model: @signup_form, url: platform_admin_tenants_path, method: :post, class: "space-y-6" do |f| %>
      <% if @signup_form.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded-lg p-4">
          <ul class="list-disc list-inside text-sm text-red-700 space-y-1">
            <% @signup_form.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# Company Info %>
      <div>
        <h3 class="text-sm font-medium text-gray-700 mb-3 pb-2 border-b border-gray-100">Company Details</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700">Company Name <span class="text-red-500">*</span></label>
            <%= f.text_field :company_name, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none sm:text-sm", placeholder: "Acme Corp" %>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700">Subdomain <span class="text-red-500">*</span></label>
            <% app_domain = ENV.fetch("APP_DOMAIN", "lvh.me") %>
            <div class="mt-1 flex rounded-lg border border-gray-300 shadow-sm focus-within:border-indigo-500 focus-within:ring-1 focus-within:ring-indigo-500 overflow-hidden">
              <%= f.text_field :subdomain, class: "block w-full px-3 py-2 focus:outline-none sm:text-sm", placeholder: "acme" %>
              <span class="inline-flex items-center px-3 bg-gray-50 text-gray-500 text-sm border-l border-gray-300">.<%= app_domain %></span>
            </div>
          </div>

          <div class="sm:col-span-2">
            <label class="block text-sm font-medium text-gray-700">State <span class="text-red-500">*</span></label>
            <%= f.select :state,
                [["-- Select State --", ""]] +
                [["Andhra Pradesh", "andhra_pradesh"], ["Gujarat", "gujarat"],
                 ["Karnataka", "karnataka"], ["Maharashtra", "maharashtra"],
                 ["Tamil Nadu", "tamil_nadu"], ["Telangana", "telangana"],
                 ["West Bengal", "west_bengal"],
                 ["Other", "other"]],
                {},
                class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none sm:text-sm" %>
            <p class="mt-1 text-xs text-gray-500">PT slabs are auto-seeded for supported states.</p>
          </div>
        </div>
      </div>

      <%# Admin User %>
      <div>
        <h3 class="text-sm font-medium text-gray-700 mb-3 pb-2 border-b border-gray-100">Admin User</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700">First Name <span class="text-red-500">*</span></label>
            <%= f.text_field :first_name, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none sm:text-sm" %>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700">Last Name <span class="text-red-500">*</span></label>
            <%= f.text_field :last_name, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none sm:text-sm" %>
          </div>

          <div class="sm:col-span-2">
            <label class="block text-sm font-medium text-gray-700">Email <span class="text-red-500">*</span></label>
            <%= f.email_field :email, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none sm:text-sm", placeholder: "admin@company.com" %>
          </div>

          <div data-controller="password" class="sm:col-span-2 grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700">Password <span class="text-red-500">*</span></label>
              <div class="mt-1 relative">
                <%= f.password_field :password,
                    data: { password_target: "password", action: "input->password#checkMatch" },
                    class: "block w-full rounded-lg border border-gray-300 px-3 py-2 pr-10 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none sm:text-sm",
                    placeholder: "Min. 6 characters" %>
                <button type="button" data-action="click->password#toggle"
                        class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-600">
                  <svg class="icon-show w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                  </svg>
                  <svg class="icon-hide w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 4.411m0 0L21 21"/>
                  </svg>
                </button>
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">Confirm Password <span class="text-red-500">*</span></label>
              <div class="mt-1 relative">
                <%= f.password_field :password_confirmation,
                    data: { password_target: "confirmation", action: "input->password#checkMatch" },
                    class: "block w-full rounded-lg border border-gray-300 px-3 py-2 pr-10 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 focus:outline-none sm:text-sm" %>
                <button type="button" data-action="click->password#toggle"
                        class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-600">
                  <svg class="icon-show w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                  </svg>
                  <svg class="icon-hide w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 4.411m0 0L21 21"/>
                  </svg>
                </button>
              </div>
              <p data-password-target="matchMessage" class="mt-1 text-xs"></p>
            </div>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-4 pt-2">
        <%= f.submit "Create Tenant", class: "rounded-lg bg-indigo-600 px-5 py-2 text-sm font-medium text-white hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 cursor-pointer" %>
        <%= link_to platform_admin_tenants_path, class: "inline-flex items-center gap-1.5 text-sm text-gray-600 hover:text-gray-900" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          Cancel
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="mt-4 bg-blue-50 border border-blue-100 rounded-lg p-4 text-sm text-blue-700">
    <strong>What gets created:</strong> Tenant record, admin user account (super_admin role), payroll settings, salary components, leave types, and PT slabs for the selected state.
  </div>
</div>
