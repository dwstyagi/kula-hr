<% content_for(:page_title, "Edit #{@tenant.name}") %>

<div class="max-w-2xl">
  <div class="bg-white rounded-lg border border-gray-200 p-6">
    <%= form_with model: @tenant, url: platform_admin_tenant_path(@tenant), method: :patch, class: "space-y-6" do |f| %>
      <% if @tenant.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded-lg p-4">
          <ul class="list-disc list-inside text-sm text-red-700">
            <% @tenant.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700">Company Name</label>
          <%= f.text_field :name, class: "mt-1 block w-full rounded-lg border border-gray-300 px-4 py-3 shadow-sm focus:border-blue-500 focus:ring-blue-500 focus:outline-none sm:text-sm" %>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">Status</label>
          <%= f.select :status, %w[trial active suspended cancelled],
              {}, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:ring-blue-500 focus:outline-none sm:text-sm" %>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">GSTIN</label>
          <%= f.text_field :gstin, class: "mt-1 block w-full rounded-lg border border-gray-300 px-4 py-3 shadow-sm focus:border-blue-500 focus:ring-blue-500 focus:outline-none sm:text-sm" %>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">PAN</label>
          <%= f.text_field :pan, class: "mt-1 block w-full rounded-lg border border-gray-300 px-4 py-3 shadow-sm focus:border-blue-500 focus:ring-blue-500 focus:outline-none sm:text-sm" %>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">State</label>
          <%= f.text_field :state, class: "mt-1 block w-full rounded-lg border border-gray-300 px-4 py-3 shadow-sm focus:border-blue-500 focus:ring-blue-500 focus:outline-none sm:text-sm" %>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">City</label>
          <%= f.text_field :city, class: "mt-1 block w-full rounded-lg border border-gray-300 px-4 py-3 shadow-sm focus:border-blue-500 focus:ring-blue-500 focus:outline-none sm:text-sm" %>
        </div>

        <div class="sm:col-span-2">
          <label class="block text-sm font-medium text-gray-700">Address</label>
          <%= f.text_area :address, rows: 2, class: "mt-1 block w-full rounded-lg border border-gray-300 px-4 py-3 shadow-sm focus:border-blue-500 focus:ring-blue-500 focus:outline-none sm:text-sm" %>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">Pincode</label>
          <%= f.text_field :pincode, class: "mt-1 block w-full rounded-lg border border-gray-300 px-4 py-3 shadow-sm focus:border-blue-500 focus:ring-blue-500 focus:outline-none sm:text-sm" %>
        </div>
      </div>

      <div class="flex items-center gap-4 pt-4">
        <%= f.submit "Update Tenant", class: "rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 cursor-pointer" %>
        <%= link_to platform_admin_tenant_path(@tenant), class: "inline-flex items-center gap-1.5 text-sm text-gray-600 hover:text-gray-900" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          Cancel
        <% end %>
      </div>
    <% end %>
  </div>
</div>
