<%= form_with model: work_location, url: url, method: local_assigns.fetch(:method, :post), class: "space-y-4" do |f| %>
  <% if work_location.errors.any? %>
    <div class="rounded-lg bg-red-50 p-4">
      <ul class="text-sm text-red-700 list-disc list-inside space-y-1">
        <% work_location.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name,
          class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm",
          autofocus: true,
          placeholder: "e.g. Mumbai Office" %>
    </div>

    <div>
      <%= f.label :state, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :state,
          class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm",
          placeholder: "e.g. Maharashtra" %>
    </div>
  </div>

  <div>
    <label class="flex items-center gap-2 cursor-pointer">
      <%= f.check_box :is_active, class: "rounded border-gray-300 text-blue-600 shadow-sm focus:ring-blue-500" %>
      <span class="text-sm text-gray-700">Active</span>
    </label>
  </div>

  <div class="flex items-center gap-3 pt-1">
    <%= f.submit work_location.persisted? ? "Update Location" : "Create Location",
        class: "px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 cursor-pointer" %>
    <%= link_to "Cancel", admin_work_locations_path,
        class: "px-4 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-200" %>
  </div>
<% end %>
