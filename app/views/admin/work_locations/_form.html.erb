<%= form_with model: work_location, url: url, method: local_assigns.fetch(:method, :post), class: "space-y-4" do |f| %>
  <% if work_location.errors.any? %>
    <div class="rounded-lg bg-red-50 p-4">
      <ul class="text-sm text-red-700 list-disc list-inside space-y-1">
        <% work_location.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= f.label :name, class: "label" %>
      <%= f.text_field :name,
          class: "input",
          autofocus: true,
          placeholder: "e.g. Mumbai Office" %>
    </div>

    <div>
      <%= f.label :state, class: "label" %>
      <%= f.text_field :state,
          class: "input",
          placeholder: "e.g. Maharashtra" %>
    </div>
  </div>

  <div>
    <label class="flex items-center gap-2 cursor-pointer">
      <%= f.check_box :is_active, class: "rounded border-stone-300 text-kula-700 shadow-sm focus:ring-kula-600" %>
      <span class="text-sm text-stone-700">Active</span>
    </label>
  </div>

  <div class="flex items-center gap-3 pt-1">
    <%= f.submit work_location.persisted? ? "Update Location" : "Create Location",
        class: "btn btn-primary cursor-pointer" %>
    <%= link_to "Cancel", admin_work_locations_path,
        class: "btn btn-ghost" %>
  </div>
<% end %>
