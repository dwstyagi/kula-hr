<div class="max-w-5xl mx-auto">

  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Import Preview</h1>
    <p class="text-sm text-gray-500 mt-1">Review validation results before importing.</p>
  </div>

  <%# Summary bar %>
  <div class="grid grid-cols-3 gap-4 mb-6">
    <div class="bg-white rounded-lg border border-gray-200 p-4 text-center">
      <p class="text-2xl font-bold text-gray-900"><%= @total_count %></p>
      <p class="text-xs text-gray-500 mt-1">Total Rows</p>
    </div>
    <div class="bg-green-50 rounded-lg border border-green-200 p-4 text-center">
      <p class="text-2xl font-bold text-green-700"><%= @valid_rows.size %></p>
      <p class="text-xs text-green-600 mt-1">Ready to Import</p>
    </div>
    <div class="bg-red-50 rounded-lg border border-red-200 p-4 text-center">
      <p class="text-2xl font-bold text-red-700"><%= @invalid_rows.size %></p>
      <p class="text-xs text-red-600 mt-1">Have Errors</p>
    </div>
  </div>

  <%# Error rows warning %>
  <% if @invalid_rows.any? %>
    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-6">
      <p class="text-sm text-yellow-800">
        <strong><%= @invalid_rows.size %> rows have errors</strong> and will be skipped during import.
        After importing, an Excel file with the skipped rows and error details will download automatically.
      </p>
    </div>
  <% end %>

  <%# Results table %>
  <div class="bg-white rounded-lg border border-gray-200 overflow-x-auto mb-4">
    <table class="min-w-full divide-y divide-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Row</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Joining Date</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Errors</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @displayed_rows.each do |row| %>
          <tr class="<%= row['_valid'] ? 'hover:bg-gray-50' : 'bg-red-50 hover:bg-red-100' %>">
            <td class="px-4 py-3 text-gray-400 font-mono text-xs"><%= row["_row"] %></td>
            <td class="px-4 py-3">
              <% if row["_valid"] %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  Valid
                </span>
              <% else %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                  Error
                </span>
              <% end %>
            </td>
            <td class="px-4 py-3 font-medium text-gray-900">
              <%= [row["first_name"], row["last_name"]].compact_blank.join(" ").presence || "—" %>
            </td>
            <td class="px-4 py-3 text-gray-600"><%= row["email"].presence || "—" %></td>
            <td class="px-4 py-3 text-gray-600"><%= row["joining_date"].presence || "—" %></td>
            <td class="px-4 py-3">
              <% if row["_errors"].any? %>
                <ul class="text-xs text-red-600 space-y-0.5 list-disc list-inside">
                  <% row["_errors"].each do |err| %>
                    <li><%= err %></li>
                  <% end %>
                </ul>
              <% else %>
                <span class="text-gray-400 text-xs">—</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# Pagination %>
  <% if @total_pages > 1 %>
    <div class="flex items-center justify-between mb-6">
      <p class="text-sm text-gray-500">
        Showing rows <%= (@current_page - 1) * 10 + 1 %>–<%= [ @current_page * 10, @total_count ].min %> of <%= @total_count %>
      </p>
      <div class="flex items-center gap-1">
        <%# Previous %>
        <% if @current_page > 1 %>
          <%= link_to preview_admin_imports_path(page: @current_page - 1),
              class: "px-3 py-1.5 text-sm rounded-lg border border-gray-200 text-gray-600 hover:bg-gray-50" do %>
            &larr; Prev
          <% end %>
        <% else %>
          <span class="px-3 py-1.5 text-sm rounded-lg border border-gray-100 text-gray-300 cursor-not-allowed">&larr; Prev</span>
        <% end %>

        <%# Page numbers — show up to 7 around current %>
        <% page_range = [ [@current_page - 2, 1].max, @total_pages ].then { |s, e| (s..[ [s + 4, e].min, @total_pages ].min) } %>
        <% if page_range.first > 1 %>
          <%= link_to "1", preview_admin_imports_path(page: 1), class: "px-3 py-1.5 text-sm rounded-lg border border-gray-200 text-gray-600 hover:bg-gray-50" %>
          <span class="px-1 text-gray-400 text-sm">…</span>
        <% end %>
        <% page_range.each do |p| %>
          <% if p == @current_page %>
            <span class="px-3 py-1.5 text-sm rounded-lg bg-blue-600 text-white font-medium"><%= p %></span>
          <% else %>
            <%= link_to p.to_s, preview_admin_imports_path(page: p), class: "px-3 py-1.5 text-sm rounded-lg border border-gray-200 text-gray-600 hover:bg-gray-50" %>
          <% end %>
        <% end %>
        <% if page_range.last < @total_pages %>
          <span class="px-1 text-gray-400 text-sm">…</span>
          <%= link_to @total_pages.to_s, preview_admin_imports_path(page: @total_pages), class: "px-3 py-1.5 text-sm rounded-lg border border-gray-200 text-gray-600 hover:bg-gray-50" %>
        <% end %>

        <%# Next %>
        <% if @current_page < @total_pages %>
          <%= link_to preview_admin_imports_path(page: @current_page + 1),
              class: "px-3 py-1.5 text-sm rounded-lg border border-gray-200 text-gray-600 hover:bg-gray-50" do %>
            Next &rarr;
          <% end %>
        <% else %>
          <span class="px-3 py-1.5 text-sm rounded-lg border border-gray-100 text-gray-300 cursor-not-allowed">Next &rarr;</span>
        <% end %>
      </div>
    </div>
  <% else %>
    <p class="text-sm text-gray-500 mb-6">Showing all <%= @total_count %> rows.</p>
  <% end %>

  <%# Actions %>
  <div class="flex items-center gap-3">
    <% if @valid_rows.size.positive? %>
      <%= form_with url: confirm_admin_imports_path, method: :post, data: { turbo: false } do |f| %>
        <%= f.submit "Import #{@valid_rows.size} #{'Employee'.pluralize(@valid_rows.size)}#{@invalid_rows.any? ? ' & Download Error Report' : ''}",
              class: "px-6 py-2.5 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 cursor-pointer" %>
      <% end %>
    <% end %>
    <%= link_to "Upload Different File", new_admin_import_path,
        class: "px-6 py-2.5 bg-gray-100 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-200" %>
  </div>

</div>
