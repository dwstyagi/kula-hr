<div class="max-w-5xl mx-auto">

  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Import Preview</h1>
    <p class="text-sm text-gray-500 mt-1">File parsed successfully. Review the data below before importing.</p>
  </div>

  <%# Summary bar %>
  <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-6 flex items-center gap-3">
    <svg class="w-5 h-5 text-green-600 shrink-0" fill="currentColor" viewBox="0 0 20 20">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
    </svg>
    <p class="text-sm text-green-800">
      <strong><%= @valid_count %> rows</strong> found in the file.
      Showing first <%= @preview_rows.size %> below.
      Validation and import happen in the next step.
    </p>
  </div>

  <%# Preview table %>
  <div class="bg-white rounded-lg border border-gray-200 overflow-x-auto mb-6">
    <table class="min-w-full divide-y divide-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Row</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Joining Date</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Department</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @preview_rows.each do |row| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 text-gray-400 font-mono text-xs"><%= row["_row"] %></td>
            <td class="px-4 py-3 font-medium text-gray-900">
              <%= [row["first_name"], row["last_name"]].compact_blank.join(" ").presence || "—" %>
            </td>
            <td class="px-4 py-3 text-gray-600"><%= row["email"].presence || "—" %></td>
            <td class="px-4 py-3 text-gray-600"><%= row["joining_date"].presence || "—" %></td>
            <td class="px-4 py-3">
              <% if row["employment_status"].present? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                  <%= row["employment_status"].titleize %>
                </span>
              <% else %>
                <span class="text-gray-400">—</span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-gray-600"><%= row["department"].presence || "—" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @valid_count > 5 %>
      <div class="px-4 py-3 border-t border-gray-100 text-xs text-gray-400 text-center">
        + <%= @valid_count - 5 %> more rows not shown
      </div>
    <% end %>
  </div>

  <%# Actions %>
  <div class="flex items-center gap-3">
    <%= link_to "Upload Different File", new_admin_import_path,
        class: "px-6 py-2.5 bg-gray-100 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-200" %>
  </div>

</div>
