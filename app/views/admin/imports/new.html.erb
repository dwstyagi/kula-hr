<div class="max-w-2xl mx-auto">

  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Import Employees</h1>
    <p class="text-sm text-gray-500 mt-1">Upload an Excel file to bulk import employees into your organisation.</p>
  </div>

  <%# Flash alert %>
  <% if flash[:alert] %>
    <div class="mb-6 rounded-lg bg-red-50 border border-red-200 p-4 text-sm text-red-700">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%# Instructions %>
  <div class="bg-blue-50 border border-blue-200 rounded-lg p-5 mb-6">
    <h3 class="text-sm font-semibold text-blue-900 mb-3">Before you upload</h3>
    <ol class="space-y-2 text-sm text-blue-800 list-decimal list-inside">
      <li>Download the official template using the link below</li>
      <li>Fill in employee details — required fields: First name, Last name, Email, Joining date, Status</li>
      <li>Delete the sample and notes rows, keep only the header row and your data</li>
      <li>Save as <strong>.xlsx</strong> and upload below</li>
    </ol>
    <%= link_to template_admin_employees_path, format: :xlsx,
        class: "inline-flex items-center gap-2 mt-4 px-4 py-2 bg-white border border-blue-300 text-blue-700 text-sm font-medium rounded-lg hover:bg-blue-50",
        data: { turbo: "false" } do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
      </svg>
      Download Template
    <% end %>
  </div>

  <%# Upload form %>
  <%= form_with url: admin_imports_path, method: :post, multipart: true, data: { turbo: false }, class: "bg-white rounded-lg border border-gray-200 p-6" do |f| %>
    <div class="mb-6" data-controller="file-upload">
      <label class="block text-sm font-medium text-gray-700 mb-2">Select Excel file (.xlsx)</label>

      <div data-file-upload-target="dropzone"
           class="border-2 border-dashed border-gray-300 rounded-lg p-8 text-center transition-colors cursor-pointer"
           onclick="this.querySelector('input[type=file]').click()">

        <svg class="mx-auto h-10 w-10 text-gray-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>

        <div data-file-upload-target="label">
          <p class="text-sm font-medium text-gray-700 mb-1">Drag and drop your file here</p>
          <p class="text-xs text-gray-400">or click to browse — .xlsx files only</p>
        </div>

        <p data-file-upload-target="filename"
           class="hidden text-sm font-semibold text-blue-700 mt-1"></p>

        <%= f.file_field :file, accept: ".xlsx",
            class: "hidden",
            data: {
              file_upload_target: "input",
              action: "change->file-upload#onFileSelected"
            } %>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <%= f.submit "Parse & Preview",
          class: "px-6 py-2.5 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 cursor-pointer" %>
      <%= link_to "Cancel", admin_employees_path,
          class: "px-6 py-2.5 bg-gray-100 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-200" %>
    </div>
  <% end %>

</div>
