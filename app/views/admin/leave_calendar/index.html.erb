<div class="max-w-7xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Leave Calendar</h1>
      <p class="text-sm text-gray-500 mt-1">Company-wide view of who is on leave each day.</p>
    </div>
  </div>

  <div class="flex flex-wrap items-center justify-between gap-4 mb-4">
    <% prev_month = @date.prev_month %>
    <% next_month = @date.next_month %>
    <div class="flex items-center gap-4">
      <%= link_to admin_leave_calendar_path(month: prev_month.month, year: prev_month.year, department_id: @selected_department_id),
          class: "p-1.5 rounded-md text-gray-600 hover:bg-gray-100" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      <% end %>
      <span class="text-sm font-semibold text-gray-900 w-40 text-center"><%= @date.strftime("%B %Y") %></span>
      <%= link_to admin_leave_calendar_path(month: next_month.month, year: next_month.year, department_id: @selected_department_id),
          class: "p-1.5 rounded-md text-gray-600 hover:bg-gray-100" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <% end %>
    </div>

    <%= form_with url: admin_leave_calendar_path, method: :get, data: { turbo_frame: "_top" }, class: "flex items-center gap-2" do |f| %>
      <%= f.hidden_field :month, value: @month %>
      <%= f.hidden_field :year, value: @year %>
      <%= f.collection_select :department_id, @departments, :id, :name,
          { selected: @selected_department_id, include_blank: "All departments" },
          class: "rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm",
          onchange: "this.form.requestSubmit()" %>
    <% end %>
  </div>

  <%= render "shared/leave_calendar_grid", calendar: @calendar %>
</div>
