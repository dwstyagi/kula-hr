<% content_for(:page_title, "ESI Monthly Report") %>
<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">ESI Monthly Report</h1>
      <p class="text-sm text-gray-500 mt-0.5">Employee and employer ESI contributions</p>
    </div>
    <%= link_to "← Back to Reports", admin_reports_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
  </div>

  <%= render "month_selector", url: esi_report_admin_reports_path, selected_month: @month, selected_year: @year %>

  <% if @report.rows.any? %>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="bg-white rounded-xl border border-gray-200 p-5">
        <p class="text-xs text-gray-400 uppercase tracking-wide">Employees</p>
        <p class="text-xl font-bold text-gray-900 mt-0.5"><%= @report.summary[:employee_count] %></p>
      </div>
      <div class="bg-white rounded-xl border border-gray-200 p-5">
        <p class="text-xs text-gray-400 uppercase tracking-wide">Employee ESI</p>
        <p class="text-xl font-bold text-gray-900 mt-0.5">₹<%= number_with_delimiter(@report.summary[:total_ee].round(0)) %></p>
      </div>
      <div class="bg-white rounded-xl border border-gray-200 p-5">
        <p class="text-xs text-gray-400 uppercase tracking-wide">Employer ESI</p>
        <p class="text-xl font-bold text-gray-900 mt-0.5">₹<%= number_with_delimiter(@report.summary[:total_er].round(0)) %></p>
      </div>
      <div class="bg-white rounded-xl border border-gray-200 p-5">
        <p class="text-xs text-gray-400 uppercase tracking-wide">Total Contribution</p>
        <p class="text-xl font-bold text-gray-900 mt-0.5">₹<%= number_with_delimiter((@report.summary[:total_ee] + @report.summary[:total_er]).round(0)) %></p>
      </div>
    </div>

    <div class="flex justify-end">
      <%= link_to download_esi_csv_admin_reports_path(month: @month, year: @year),
          class: "inline-flex items-center gap-2 px-4 py-2 bg-green-600 text-white text-sm font-medium rounded-lg hover:bg-green-700" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
        </svg>
        Download CSV
      <% end %>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Employee Code</th>
            <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
            <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Gross Wages</th>
            <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Employee ESI</th>
            <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Employer ESI</th>
            <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Total</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @report.rows.each do |row| %>
            <tr class="hover:bg-gray-50">
              <td class="px-5 py-3 font-mono text-xs text-gray-600"><%= row.employee_code %></td>
              <td class="px-5 py-3 font-medium text-gray-900"><%= row.name %></td>
              <td class="px-5 py-3 text-right text-gray-600">₹<%= number_with_delimiter(row.gross_wages.to_i) %></td>
              <td class="px-5 py-3 text-right text-gray-600">₹<%= number_with_delimiter(row.employee_contribution.to_i) %></td>
              <td class="px-5 py-3 text-right text-gray-600">₹<%= number_with_delimiter(row.employer_contribution.to_i) %></td>
              <td class="px-5 py-3 text-right font-semibold text-gray-900">₹<%= number_with_delimiter(row.total_contribution.to_i) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white rounded-xl border border-gray-200 text-center py-16 text-gray-400">
      <svg class="mx-auto w-10 h-10 mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
      </svg>
      <p class="font-medium">No ESI data for <%= Date::MONTHNAMES[@month] %> <%= @year %></p>
      <p class="text-sm mt-1">Run and approve payroll with ESI-applicable employees to generate this report.</p>
    </div>
  <% end %>
</div>
