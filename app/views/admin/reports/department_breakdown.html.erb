<% content_for(:page_title, "Department Breakdown") %>
<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="page-title text-2xl">Department Breakdown</h1>
      <p class="text-sm text-stone-500 mt-0.5">Payroll costs by department</p>
    </div>
    <%= link_to "← Back to Reports", admin_reports_path, class: "text-sm text-kula-700 hover:text-kula-900" %>
  </div>

  <%= render "month_selector", url: department_breakdown_admin_reports_path, selected_month: @month, selected_year: @year %>

  <% if @report.rows.any? %>
    <div class="flex justify-end">
      <%= link_to download_department_csv_admin_reports_path(month: @month, year: @year),
          class: "inline-flex items-center gap-2 btn btn-primary" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
        </svg>
        Download CSV
      <% end %>
    </div>

    <div class="card overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-stone-50 border-b border-stone-200">
          <tr>
            <th class="px-5 py-3 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Department</th>
            <th class="px-5 py-3 text-right text-xs font-medium text-stone-500 uppercase tracking-wider">Employees</th>
            <th class="px-5 py-3 text-right text-xs font-medium text-stone-500 uppercase tracking-wider">Gross Pay</th>
            <th class="px-5 py-3 text-right text-xs font-medium text-stone-500 uppercase tracking-wider">Deductions</th>
            <th class="px-5 py-3 text-right text-xs font-medium text-stone-500 uppercase tracking-wider">Net Pay</th>
            <th class="px-5 py-3 text-right text-xs font-medium text-stone-500 uppercase tracking-wider">Employer PF</th>
            <th class="px-5 py-3 text-right text-xs font-medium text-stone-500 uppercase tracking-wider">Employer ESI</th>
            <th class="px-5 py-3 text-right text-xs font-medium text-stone-500 uppercase tracking-wider">CTC</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-stone-100">
          <% @report.rows.each do |row| %>
            <tr class="hover:bg-stone-50">
              <td class="px-5 py-3.5 font-medium text-stone-900"><%= row.department_name %></td>
              <td class="px-5 py-3.5 text-right text-stone-600"><%= row.employee_count %></td>
              <td class="px-5 py-3.5 text-right text-stone-600">₹<%= number_with_delimiter(row.total_gross.round(0)) %></td>
              <td class="px-5 py-3.5 text-right text-stone-600">₹<%= number_with_delimiter(row.total_deductions.round(0)) %></td>
              <td class="px-5 py-3.5 text-right font-semibold text-stone-900">₹<%= number_with_delimiter(row.total_net.round(0)) %></td>
              <td class="px-5 py-3.5 text-right text-stone-600">₹<%= number_with_delimiter(row.total_employer_pf.round(0)) %></td>
              <td class="px-5 py-3.5 text-right text-stone-600">₹<%= number_with_delimiter(row.total_employer_esi.round(0)) %></td>
              <td class="px-5 py-3.5 text-right font-semibold text-stone-900">₹<%= number_with_delimiter(row.total_ctc.round(0)) %></td>
            </tr>
          <% end %>
        </tbody>
        <tfoot class="bg-stone-50 border-t border-stone-200">
          <tr class="font-semibold">
            <td class="px-5 py-3 text-stone-900">Total</td>
            <td class="px-5 py-3 text-right text-stone-900"><%= @report.summary[:employee_count] %></td>
            <td class="px-5 py-3 text-right text-stone-900">₹<%= number_with_delimiter(@report.summary[:total_gross].round(0)) %></td>
            <td class="px-5 py-3 text-right text-stone-900">₹<%= number_with_delimiter(@report.summary[:total_deductions].round(0)) %></td>
            <td class="px-5 py-3 text-right text-stone-900">₹<%= number_with_delimiter(@report.summary[:total_net].round(0)) %></td>
            <td class="px-5 py-3 text-right text-stone-900">₹<%= number_with_delimiter(@report.summary[:total_employer_pf].round(0)) %></td>
            <td class="px-5 py-3 text-right text-stone-900">₹<%= number_with_delimiter(@report.summary[:total_employer_esi].round(0)) %></td>
            <td class="px-5 py-3 text-right text-stone-900">₹<%= number_with_delimiter(@report.summary[:total_ctc].round(0)) %></td>
          </tr>
        </tfoot>
      </table>
    </div>
  <% else %>
    <div class="card text-center py-16 text-stone-400">
      <svg class="mx-auto w-10 h-10 mb-3 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      <p class="font-medium">No payroll data for <%= Date::MONTHNAMES[@month] %> <%= @year %></p>
      <p class="text-sm mt-1">Run and approve payroll for this month to generate the report.</p>
    </div>
  <% end %>
</div>
