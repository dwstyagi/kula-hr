<% content_for(:page_title, "PT Challan") %>
<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="page-title text-2xl">Professional Tax Challan</h1>
      <p class="text-sm text-stone-500 mt-0.5">Slab-wise PT breakdown for state filing</p>
    </div>
    <%= link_to "← Back to Reports", admin_reports_path, class: "text-sm text-kula-700 hover:text-kula-900" %>
  </div>

  <%= render "month_selector", url: pt_challan_admin_reports_path, selected_month: @month, selected_year: @year %>

  <% if @report.rows.any? %>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      <div class="card p-5">
        <p class="text-xs text-stone-400 uppercase tracking-wide">Employees</p>
        <p class="text-xl font-bold text-stone-900 mt-0.5"><%= @report.summary[:employee_count] %></p>
      </div>
      <div class="card p-5">
        <p class="text-xs text-stone-400 uppercase tracking-wide">Total PT</p>
        <p class="text-xl font-bold text-stone-900 mt-0.5">₹<%= number_with_delimiter(@report.summary[:total_pt].round(0)) %></p>
      </div>
    </div>

    <%# Slab Summary %>
    <% if @report.slab_summaries.any? %>
      <div class="card overflow-hidden">
        <div class="px-5 py-3 border-b border-stone-100 bg-stone-50">
          <h3 class="text-sm font-semibold text-stone-700">Slab-wise Summary</h3>
        </div>
        <table class="w-full text-sm">
          <thead class="bg-stone-50 border-b border-stone-200">
            <tr>
              <th class="px-5 py-3 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Slab Range (₹)</th>
              <th class="px-5 py-3 text-right text-xs font-medium text-stone-500 uppercase tracking-wider">Employees</th>
              <th class="px-5 py-3 text-right text-xs font-medium text-stone-500 uppercase tracking-wider">Total PT</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-stone-100">
            <% @report.slab_summaries.each do |slab| %>
              <tr class="hover:bg-stone-50">
                <td class="px-5 py-3 text-stone-900"><%= slab.slab_range %></td>
                <td class="px-5 py-3 text-right text-stone-600"><%= slab.employee_count %></td>
                <td class="px-5 py-3 text-right font-semibold text-stone-900">₹<%= number_with_delimiter(slab.total_pt.to_i) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <div class="flex justify-end">
      <%= link_to download_pt_csv_admin_reports_path(month: @month, year: @year),
          class: "inline-flex items-center gap-2 btn btn-primary" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
        </svg>
        Download CSV
      <% end %>
    </div>

    <%# Employee detail %>
    <div class="card overflow-hidden">
      <div class="px-5 py-3 border-b border-stone-100 bg-stone-50">
        <h3 class="text-sm font-semibold text-stone-700">Employee Detail</h3>
      </div>
      <table class="w-full text-sm">
        <thead class="bg-stone-50 border-b border-stone-200">
          <tr>
            <th class="px-5 py-3 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Employee Code</th>
            <th class="px-5 py-3 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Name</th>
            <th class="px-5 py-3 text-right text-xs font-medium text-stone-500 uppercase tracking-wider">Gross Pay</th>
            <th class="px-5 py-3 text-right text-xs font-medium text-stone-500 uppercase tracking-wider">PT Amount</th>
            <th class="px-5 py-3 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Slab</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-stone-100">
          <% @report.rows.each do |row| %>
            <tr class="hover:bg-stone-50">
              <td class="px-5 py-3 font-mono text-xs text-stone-600"><%= row.employee_code %></td>
              <td class="px-5 py-3 font-medium text-stone-900"><%= row.name %></td>
              <td class="px-5 py-3 text-right text-stone-600">₹<%= number_with_delimiter(row.gross_pay.to_i) %></td>
              <td class="px-5 py-3 text-right font-semibold text-stone-900">₹<%= number_with_delimiter(row.pt_amount.to_i) %></td>
              <td class="px-5 py-3 text-stone-600"><%= row.slab_range %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="card text-center py-16 text-stone-400">
      <svg class="mx-auto w-10 h-10 mb-3 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z"/>
      </svg>
      <p class="font-medium">No PT data for <%= Date::MONTHNAMES[@month] %> <%= @year %></p>
      <p class="text-sm mt-1">Run and approve payroll with PT-applicable employees to generate this report.</p>
    </div>
  <% end %>
</div>
