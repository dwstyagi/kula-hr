<%= form_tag url, method: :get, class: "flex items-center gap-3" do %>
  <div>
    <select name="month" class="rounded-lg border-gray-300 text-sm focus:ring-blue-500 focus:border-blue-500">
      <% (1..12).each do |m| %>
        <option value="<%= m %>" <%= m == selected_month ? "selected" : "" %>><%= Date::MONTHNAMES[m] %></option>
      <% end %>
    </select>
  </div>
  <div>
    <select name="year" class="rounded-lg border-gray-300 text-sm focus:ring-blue-500 focus:border-blue-500">
      <% ((Date.current.year - 2)..Date.current.year).each do |y| %>
        <option value="<%= y %>" <%= y == selected_year ? "selected" : "" %>><%= y %></option>
      <% end %>
    </select>
  </div>
  <button type="submit" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700">
    Generate
  </button>
<% end %>
