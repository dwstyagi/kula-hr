<% content_for(:page_title, "YTD Earnings") %>
<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">YTD Earnings Report</h1>
      <p class="text-sm text-gray-500 mt-0.5">Year-to-date earnings and deductions per employee</p>
    </div>
    <%= link_to "← Back to Reports", admin_reports_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
  </div>

  <%# FY Selector %>
  <% current_year = Date.current.year %>
  <%= form_tag ytd_earnings_admin_reports_path, method: :get, class: "flex items-center gap-3" do %>
    <select name="financial_year" class="rounded-lg border-gray-300 text-sm focus:ring-blue-500 focus:border-blue-500">
      <% (-2..0).each do |offset| %>
        <% y = current_year + offset %>
        <% fy = "#{y}-#{(y + 1).to_s.last(2)}" %>
        <option value="<%= fy %>" <%= fy == @financial_year ? "selected" : "" %>>FY <%= fy %></option>
      <% end %>
    </select>
    <button type="submit" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700">
      Generate
    </button>
  <% end %>

  <% if @report.rows.any? %>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="bg-white rounded-xl border border-gray-200 p-5">
        <p class="text-xs text-gray-400 uppercase tracking-wide">Employees</p>
        <p class="text-xl font-bold text-gray-900 mt-0.5"><%= @report.summary[:employee_count] %></p>
      </div>
      <div class="bg-white rounded-xl border border-gray-200 p-5">
        <p class="text-xs text-gray-400 uppercase tracking-wide">Total Gross</p>
        <p class="text-xl font-bold text-gray-900 mt-0.5">₹<%= number_with_delimiter(@report.summary[:total_gross].round(0)) %></p>
      </div>
      <div class="bg-white rounded-xl border border-gray-200 p-5">
        <p class="text-xs text-gray-400 uppercase tracking-wide">Total Deductions</p>
        <p class="text-xl font-bold text-gray-900 mt-0.5">₹<%= number_with_delimiter(@report.summary[:total_deductions].round(0)) %></p>
      </div>
      <div class="bg-white rounded-xl border border-gray-200 p-5">
        <p class="text-xs text-gray-400 uppercase tracking-wide">Total Net</p>
        <p class="text-xl font-bold text-green-700 mt-0.5">₹<%= number_with_delimiter(@report.summary[:total_net].round(0)) %></p>
      </div>
    </div>

    <div class="flex justify-end">
      <%= link_to download_ytd_csv_admin_reports_path(financial_year: @financial_year),
          class: "inline-flex items-center gap-2 px-4 py-2 bg-green-600 text-white text-sm font-medium rounded-lg hover:bg-green-700" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
        </svg>
        Download CSV
      <% end %>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap">Employee</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap">Department</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap">Months</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap">Total Gross</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap">Total Deductions</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap">Net Pay</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @report.rows.each do |row| %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3">
                <p class="font-medium text-gray-900"><%= row.name %></p>
                <p class="text-xs text-gray-400 font-mono"><%= row.employee_code %></p>
              </td>
              <td class="px-4 py-3 text-gray-600"><%= row.department %></td>
              <td class="px-4 py-3 text-right text-gray-600"><%= row.months_count %></td>
              <td class="px-4 py-3 text-right text-gray-600">₹<%= number_with_delimiter(row.total_gross.to_i) %></td>
              <td class="px-4 py-3 text-right text-gray-600">₹<%= number_with_delimiter(row.total_deductions.to_i) %></td>
              <td class="px-4 py-3 text-right font-semibold text-gray-900">₹<%= number_with_delimiter(row.total_net.to_i) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white rounded-xl border border-gray-200 text-center py-16 text-gray-400">
      <svg class="mx-auto w-10 h-10 mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      <p class="font-medium">No data for FY <%= @financial_year %></p>
      <p class="text-sm mt-1">Run and approve payroll for this financial year to generate the report.</p>
    </div>
  <% end %>
</div>
