<div class="max-w-4xl mx-auto">
  <div class="mb-6">
    <h1 class="page-title text-2xl">Revise Salary</h1>
    <p class="mt-1 text-sm text-stone-500">
      Revise salary for
      <span class="font-medium text-stone-700"><%= @employee.full_name %></span>
      (<%= @employee.employee_code %>)
    </p>
    <% if @current_salary %>
      <p class="mt-1 text-sm text-stone-500">
        Current CTC: <span class="font-medium text-stone-700 font-mono">₹<%= number_with_delimiter(@current_salary.annual_ctc) %></span>/year
        &middot; Structure: <span class="font-medium text-stone-700"><%= @current_salary.salary_structure.name %></span>
      </p>
    <% end %>
  </div>

  <%= render "salary_form",
       employee: @employee,
       employee_salary: @employee_salary,
       salary_structures: @salary_structures,
       url: revise_salary_admin_employee_path(@employee),
       submit_label: "Revise Salary" %>
</div>
