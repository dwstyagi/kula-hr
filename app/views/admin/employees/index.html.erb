<% content_for(:page_title, "Employees") %>
<div class="max-w-7xl mx-auto">
  <%# Import error report download banner %>
  <% if session[:import_error_key].present? %>
    <div class="alert alert-warning justify-between mb-5">
      <p class="flex-1"><strong><%= session[:import_error_count] %> rows</strong> could not be imported. Download the error report to fix and re-upload.</p>
      <%= link_to "Download error report", download_errors_admin_imports_path,
          class: "btn btn-secondary btn-sm shrink-0", data: { turbo: false } %>
    </div>
  <% end %>

  <%# Invite people link banner %>
  <% tenant = ActsAsTenant.current_tenant %>
  <% if tenant.invite_token_valid? %>
    <% invite_url = employee_registration_url(token: tenant.invite_token, subdomain: tenant.subdomain) %>
    <div id="invite-banner" class="alert alert-success justify-between mb-5">
      <div class="flex items-center gap-2 min-w-0 flex-1">
        <span class="eyebrow shrink-0 text-emerald-700">Invite link</span>
        <span class="truncate code"><%= invite_url %></span>
        <span class="shrink-0 text-xs opacity-70">· expires <%= time_ago_in_words(tenant.invite_token_expires_at) %> from now</span>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <button type="button"
                data-invite-url="<%= invite_url %>"
                onclick="
                  const url = this.dataset.inviteUrl;
                  const btn = this;
                  const original = btn.innerHTML;
                  if (navigator.clipboard && window.isSecureContext) {
                    navigator.clipboard.writeText(url);
                  } else {
                    const ta = document.createElement('textarea');
                    ta.value = url; ta.style.position = 'fixed'; ta.style.opacity = '0';
                    document.body.appendChild(ta); ta.select(); document.execCommand('copy');
                    document.body.removeChild(ta);
                  }
                  btn.textContent = 'Copied!';
                  setTimeout(() => btn.innerHTML = original, 2000);
                "
                class="btn btn-primary btn-sm cursor-pointer">
          Copy
        </button>
        <%= button_to "Regenerate", generate_admin_invite_link_path, method: :post,
            class: "btn btn-secondary btn-sm cursor-pointer",
            form: { data: { turbo_confirm: "This will invalidate the current invite link. Continue?" } } %>
        <%= button_to "Revoke", revoke_admin_invite_link_path, method: :delete,
            class: "btn btn-secondary btn-sm text-red-600 cursor-pointer",
            form: { data: { turbo_confirm: "This will disable self-registration. Continue?" } } %>
        <button type="button"
                onclick="document.getElementById('invite-banner').remove()"
                class="p-1.5 opacity-60 hover:opacity-100 rounded-lg cursor-pointer"
                title="Dismiss" aria-label="Dismiss">
          <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  <% end %>

  <%# Activation link banner %>
  <% if tenant.activation_token_valid? %>
    <% activation_url = employee_activation_url(token: tenant.activation_token, subdomain: tenant.subdomain) %>
    <div id="activation-banner" class="alert alert-info justify-between mb-5">
      <div class="flex items-center gap-2 min-w-0 flex-1">
        <span class="eyebrow shrink-0 text-sky-700">Activation link</span>
        <span class="truncate code"><%= activation_url %></span>
        <span class="shrink-0 text-xs opacity-70">· expires <%= time_ago_in_words(tenant.activation_token_expires_at) %> from now</span>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <button type="button"
                data-activation-url="<%= activation_url %>"
                onclick="
                  const url = this.dataset.activationUrl;
                  const btn = this;
                  const original = btn.innerHTML;
                  if (navigator.clipboard && window.isSecureContext) {
                    navigator.clipboard.writeText(url);
                  } else {
                    const ta = document.createElement('textarea');
                    ta.value = url; ta.style.position = 'fixed'; ta.style.opacity = '0';
                    document.body.appendChild(ta); ta.select(); document.execCommand('copy');
                    document.body.removeChild(ta);
                  }
                  btn.textContent = 'Copied!';
                  setTimeout(() => btn.innerHTML = original, 2000);
                "
                class="btn btn-primary btn-sm cursor-pointer">
          Copy
        </button>
        <%= button_to "Regenerate", generate_admin_activation_link_path, method: :post,
            class: "btn btn-secondary btn-sm cursor-pointer",
            form: { data: { turbo_confirm: "This will invalidate the current link. Continue?" } } %>
        <%= button_to "Revoke", revoke_admin_activation_link_path, method: :delete,
            class: "btn btn-secondary btn-sm text-red-600 cursor-pointer",
            form: { data: { turbo_confirm: "This will disable self-service activation. Continue?" } } %>
        <button type="button"
                onclick="document.getElementById('activation-banner').remove()"
                class="p-1.5 opacity-60 hover:opacity-100 rounded-lg cursor-pointer"
                title="Dismiss" aria-label="Dismiss">
          <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  <% end %>

  <div class="flex flex-wrap items-center justify-between gap-3 mb-6">
    <h1 class="page-title">Employees</h1>
    <div class="flex flex-wrap items-center gap-2">
      <% unless tenant.invite_token_valid? %>
        <%= button_to "Generate invite link", generate_admin_invite_link_path, method: :post,
            class: "btn btn-secondary cursor-pointer" %>
      <% end %>
      <% unless tenant.activation_token_valid? %>
        <%= button_to "Generate activation link", generate_admin_activation_link_path, method: :post,
            class: "btn btn-secondary cursor-pointer" %>
      <% end %>
      <%= link_to "Export", export_admin_employees_path(q: params[:q], department_id: params[:department_id], status: params[:status]),
          class: "btn btn-secondary", data: { turbo: false } %>
      <%= link_to "Import", new_admin_import_path, class: "btn btn-secondary", data: { turbo_frame: "_top" } %>
      <%= link_to new_admin_employee_path, class: "btn btn-primary", data: { turbo_frame: "_top" } do %>
        <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
        </svg>
        Add employee
      <% end %>
    </div>
  </div>

  <%# Search & Filters %>
  <%= form_with url: admin_employees_path, method: :get,
      data: { turbo_frame: "employees_list" },
      class: "flex flex-wrap items-end gap-3 mb-4" do |f| %>
    <div class="flex-1 min-w-48">
      <%= f.label :q, "Search", class: "label" %>
      <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 size-4 text-stone-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/>
        </svg>
        <%= f.search_field :q, value: params[:q], placeholder: "Name or employee code…",
            class: "input pl-9" %>
      </div>
    </div>
    <div class="min-w-40">
      <%= f.label :department_id, "Department", class: "label" %>
      <%= f.collection_select :department_id, @departments, :id, :name,
          { selected: params[:department_id], include_blank: "All departments" },
          class: "select" %>
    </div>
    <div class="min-w-36">
      <%= f.label :status, "Status", class: "label" %>
      <%= f.select :status,
          Employee::EMPLOYMENT_STATUSES.map { |s| [s.titleize, s] },
          { selected: params[:status], include_blank: "All statuses" },
          class: "select" %>
    </div>
    <div class="flex gap-2">
      <%= f.submit "Search", class: "btn btn-primary cursor-pointer" %>
      <% if params[:q].present? || params[:department_id].present? || params[:status].present? %>
        <%= link_to "Clear", admin_employees_path, class: "btn btn-ghost",
            data: { turbo_frame: "employees_list" } %>
      <% end %>
    </div>
  <% end %>

  <%# Results (Turbo Frame) %>
  <%= turbo_frame_tag "employees_list" do %>
    <div class="card overflow-hidden">
      <% if @employees.any? %>
        <div class="px-5 sm:px-6 py-3 border-b border-stone-100 text-xs text-stone-500">
          <span class="amount"><%= @pagy.count %></span> employee<%= @pagy.count == 1 ? "" : "s" %> found
        </div>
        <div class="overflow-x-auto">
        <table class="tbl">
          <thead>
            <tr>
              <th>Employee</th>
              <th>Code</th>
              <th>Department</th>
              <th>Designation</th>
              <th>Status</th>
              <th>Account</th>
              <th class="text-right">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @employees.each do |employee| %>
              <tr>
                <td>
                  <div class="flex items-center gap-3">
                    <%= avatar_chip employee.full_name %>
                    <div>
                      <%= link_to employee.full_name, admin_employee_path(employee),
                          class: "text-sm font-medium text-stone-900 hover:text-kula-700 hover:underline underline-offset-2",
                          data: { turbo_frame: "_top" } %>
                      <p class="text-xs text-stone-500"><%= employee.email %></p>
                    </div>
                  </div>
                </td>
                <td><span class="code"><%= employee.employee_code %></span></td>
                <td class="text-stone-600"><%= employee.department&.name || "—" %></td>
                <td class="text-stone-600"><%= employee.designation&.name || "—" %></td>
                <td><%= status_badge employee.employment_status %></td>
                <td>
                  <% if employee.user&.invitation_accepted_at.present? %>
                    <span class="badge badge-success">Accepted</span>
                  <% elsif employee.user&.invitation_sent_at.present? %>
                    <span class="badge badge-warning">Invite pending</span>
                  <% elsif employee.user.nil? %>
                    <span class="badge badge-neutral">Not invited</span>
                  <% else %>
                    <span class="badge badge-info">Active</span>
                  <% end %>
                </td>
                <td class="text-right">
                  <div class="flex items-center justify-end gap-1">
                    <%= link_to admin_employee_path(employee),
                        title: "View profile",
                        class: "p-1.5 rounded-md text-stone-500 hover:bg-stone-100 hover:text-kula-700 transition-colors",
                        data: { turbo_frame: "_top" } do %>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.644C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                      </svg>
                    <% end %>
                    <%= link_to edit_admin_employee_path(employee),
                        title: "Edit profile",
                        class: "p-1.5 rounded-md text-stone-500 hover:bg-stone-100 hover:text-kula-700 transition-colors",
                        data: { turbo_frame: "_top" } do %>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                      </svg>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
        </div>
        <% if @pagy.pages > 1 %>
          <div class="px-6 py-3 border-t border-stone-200 flex justify-center">
            <%= render "shared/pagy_nav", pagy: @pagy %>
          </div>
        <% end %>
      <% else %>
        <div class="empty-state">
          <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
          </svg>
          <% if params[:q].present? || params[:department_id].present? || params[:status].present? %>
            <h3 class="text-sm font-semibold text-stone-900">No employees match your search</h3>
            <p class="mt-1 text-sm text-stone-500">Try adjusting your filters.</p>
          <% else %>
            <h3 class="text-sm font-semibold text-stone-900">No employees yet</h3>
            <p class="mt-1 text-sm text-stone-500">Add your first employee to get started.</p>
            <%= link_to "Add employee", new_admin_employee_path, class: "btn btn-primary mt-4", data: { turbo_frame: "_top" } %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
