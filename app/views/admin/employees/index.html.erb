<div class="max-w-7xl mx-auto">

  <%# Import error report download banner %>
  <% if session[:import_error_key].present? %>
    <div class="flex items-center justify-between bg-amber-50 border border-amber-200 rounded-lg px-4 py-3 mb-5">
      <div class="flex items-center gap-2 text-sm text-amber-800">
        <svg class="w-4 h-4 shrink-0 text-amber-500" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
        </svg>
        <span><strong><%= session[:import_error_count] %> rows</strong> could not be imported. Download the error report to fix and re-upload.</span>
      </div>
      <%= link_to download_errors_admin_imports_path,
          class: "shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 bg-amber-600 text-white text-xs font-medium rounded-lg hover:bg-amber-700",
          data: { turbo: false } do %>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        Download Error Report
      <% end %>
    </div>
  <% end %>

  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Employees</h1>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to template_admin_employees_path, format: :xlsx,
          class: "inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50",
          data: { turbo: "false" } do %>
        <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        Download Template
      <% end %>
      <%= link_to new_admin_import_path,
          class: "inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50",
          data: { turbo_frame: "_top" } do %>
        <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
        </svg>
        Import Employees
      <% end %>
      <%= link_to new_admin_employee_path,
          class: "inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700",
          data: { turbo_frame: "_top" } do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Add Employee
      <% end %>
    </div>
  </div>

  <%# Search & Filters %>
  <%= form_with url: admin_employees_path, method: :get,
      data: { turbo_frame: "employees_list" },
      class: "flex flex-wrap items-end gap-3 mb-4" do |f| %>

    <div class="flex-1 min-w-48">
      <%= f.label :q, "Search", class: "block text-xs font-medium text-gray-600 mb-1" %>
      <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/>
        </svg>
        <%= f.search_field :q, value: params[:q], placeholder: "Name or employee code...",
            class: "w-full pl-9 pr-3 py-2 rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm" %>
      </div>
    </div>

    <div class="min-w-40">
      <%= f.label :department_id, "Department", class: "block text-xs font-medium text-gray-600 mb-1" %>
      <%= f.collection_select :department_id, @departments, :id, :name,
          { selected: params[:department_id], include_blank: "All Departments" },
          class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2" %>
    </div>

    <div class="min-w-36">
      <%= f.label :status, "Status", class: "block text-xs font-medium text-gray-600 mb-1" %>
      <%= f.select :status,
          Employee::EMPLOYMENT_STATUSES.map { |s| [s.titleize, s] },
          { selected: params[:status], include_blank: "All Statuses" },
          class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2" %>
    </div>

    <div class="flex gap-2">
      <%= f.submit "Search", class: "px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 cursor-pointer" %>
      <% if params[:q].present? || params[:department_id].present? || params[:status].present? %>
        <%= link_to "Clear", admin_employees_path,
            class: "px-4 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-200",
            data: { turbo_frame: "employees_list" } %>
      <% end %>
    </div>
  <% end %>

  <%# Results (Turbo Frame) %>
  <%= turbo_frame_tag "employees_list" do %>
    <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
      <% if @employees.any? %>
        <div class="px-6 py-3 border-b border-gray-100 text-xs text-gray-500">
          <%= @pagy.count %> employee<%= @pagy.count == 1 ? "" : "s" %> found
        </div>
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Employee</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Code</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Department</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Designation</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @employees.each do |employee| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4">
                  <div class="flex items-center gap-3">
                    <div class="h-9 w-9 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 font-semibold text-sm shrink-0">
                      <%= employee.first_name.first %><%= employee.last_name.first %>
                    </div>
                    <div>
                      <p class="text-sm font-medium text-gray-900"><%= employee.full_name %></p>
                      <p class="text-xs text-gray-500"><%= employee.email %></p>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4 text-sm font-mono text-gray-500"><%= employee.employee_code %></td>
                <td class="px-6 py-4 text-sm text-gray-500"><%= employee.department&.name || "—" %></td>
                <td class="px-6 py-4 text-sm text-gray-500"><%= employee.designation&.name || "—" %></td>
                <td class="px-6 py-4">
                  <% status_colors = { "active" => "bg-green-100 text-green-800", "probation" => "bg-yellow-100 text-yellow-800", "notice_period" => "bg-orange-100 text-orange-800", "resigned" => "bg-red-100 text-red-800", "terminated" => "bg-gray-100 text-gray-800" } %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= status_colors[employee.employment_status] %>">
                    <%= employee.employment_status.titleize %>
                  </span>
                </td>
                <td class="px-6 py-4 text-right space-x-2">
                  <%= link_to "View", admin_employee_path(employee), class: "text-sm text-blue-600 hover:text-blue-800", data: { turbo_frame: "_top" } %>
                  <%= link_to "Edit", edit_admin_employee_path(employee), class: "text-sm text-gray-600 hover:text-gray-800", data: { turbo_frame: "_top" } %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>

        <% if @pagy.pages > 1 %>
          <div class="px-6 py-3 border-t border-gray-200 flex justify-center">
            <%== pagy_nav(@pagy) %>
          </div>
        <% end %>
      <% else %>
        <div class="p-12 text-center">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <% if params[:q].present? || params[:department_id].present? || params[:status].present? %>
            <h3 class="mt-2 text-sm font-medium text-gray-900">No employees match your search</h3>
            <p class="mt-1 text-sm text-gray-500">Try adjusting your filters.</p>
          <% else %>
            <h3 class="mt-2 text-sm font-medium text-gray-900">No employees yet</h3>
            <p class="mt-1 text-sm text-gray-500">Get started by adding your first employee.</p>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
