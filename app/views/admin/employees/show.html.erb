<% content_for(:page_title, @employee.full_name) %>

<div class="max-w-6xl mx-auto" data-controller="scrollspy"
     data-scrollspy-active-class="bg-kula-50 text-kula-800 font-semibold">
  <div class="grid grid-cols-1 lg:grid-cols-[300px_1fr] gap-6 items-start">

    <%# ── Identity rail — always in view ─────────────────────────────────── %>
    <aside class="lg:sticky lg:top-8 space-y-4 animate-fade-up">
      <div class="card card-pad text-center">
        <div class="mx-auto size-20 rounded-full bg-kula-100 flex items-center justify-center text-kula-800 font-bold text-3xl">
          <%= @employee.first_name.first %><%= @employee.last_name.first %>
        </div>
        <h1 class="page-title mt-3"><%= @employee.full_name %></h1>
        <p class="code mt-1"><%= @employee.employee_code %></p>
        <p class="text-sm text-stone-500 mt-1">
          <%= [@employee.designation&.name, @employee.department&.name].compact_blank.join(" · ").presence || "—" %>
        </p>
        <div class="mt-3 flex items-center justify-center gap-2 flex-wrap">
          <%= status_badge @employee.employment_status %>
          <% if @employee.user&.invitation_accepted_at.present? %>
            <span class="badge badge-success">Invite accepted</span>
          <% elsif @employee.user&.invitation_sent_at.present? %>
            <span class="badge badge-warning">Invite pending</span>
          <% elsif @employee.user.nil? %>
            <span class="badge badge-neutral">Not invited</span>
          <% elsif @employee.user.account_active? %>
            <span class="badge badge-info">Account active</span>
          <% else %>
            <span class="badge badge-danger">Account deactivated</span>
          <% end %>
        </div>

        <dl class="mt-5 pt-5 border-t border-stone-100 space-y-3 text-left">
          <div class="flex items-center justify-between gap-3">
            <dt class="text-xs text-stone-400 shrink-0">Email</dt>
            <dd class="text-xs text-stone-700 truncate"><%= @employee.email %></dd>
          </div>
          <div class="flex items-center justify-between gap-3">
            <dt class="text-xs text-stone-400 shrink-0">Phone</dt>
            <dd class="text-xs text-stone-700 amount"><%= @employee.phone.presence || "—" %></dd>
          </div>
          <div class="flex items-center justify-between gap-3">
            <dt class="text-xs text-stone-400 shrink-0">Joined</dt>
            <dd class="text-xs text-stone-700"><%= @employee.joining_date.strftime("%d %b %Y") %></dd>
          </div>
          <div class="flex items-center justify-between gap-3">
            <dt class="text-xs text-stone-400 shrink-0">Manager</dt>
            <dd class="text-xs truncate">
              <% if @employee.reporting_manager %>
                <%= link_to @employee.reporting_manager.full_name, admin_employee_path(@employee.reporting_manager), class: "link" %>
              <% else %>
                <span class="text-stone-700">—</span>
              <% end %>
            </dd>
          </div>
        </dl>

        <div class="mt-5 pt-5 border-t border-stone-100 space-y-2">
          <%= link_to "Edit profile", edit_admin_employee_path(@employee), class: "btn btn-primary w-full" %>
          <% if @current_salary %>
            <%= link_to "Revise salary", revise_salary_admin_employee_path(@employee), class: "btn btn-secondary w-full" %>
          <% else %>
            <%= link_to "Assign salary", assign_salary_admin_employee_path(@employee), class: "btn btn-secondary w-full" %>
          <% end %>
          <% unless @employee.user&.invitation_accepted_at.present? %>
            <%= button_to @employee.user ? "Resend invite" : "Send invite", resend_invite_admin_employee_path(@employee),
                method: :post, class: "btn btn-secondary w-full cursor-pointer" %>
          <% end %>
          <% if @employee.user %>
            <% if @employee.user.account_active? %>
              <%= button_to "Deactivate account", toggle_account_status_admin_employee_path(@employee),
                  method: :patch,
                  data: { turbo_confirm: "Deactivate portal access for #{@employee.full_name}? They will no longer be able to log in." },
                  class: "btn btn-ghost w-full text-red-600 cursor-pointer" %>
            <% else %>
              <%= button_to "Reactivate account", toggle_account_status_admin_employee_path(@employee),
                  method: :patch, class: "btn btn-ghost w-full text-kula-700 cursor-pointer" %>
            <% end %>
          <% end %>
        </div>
      </div>

      <%# Section nav — sticks with the rail, highlights on scroll %>
      <nav class="card p-2 hidden lg:block" aria-label="Profile sections">
        <% { personal: "Personal", employment: "Employment", bank: "Bank & statutory", salary: "Salary", leave: "Leave" }.each do |key, label| %>
          <a href="#<%= key %>" data-scrollspy-target="link" data-action="scrollspy#jump"
             class="block rounded-lg px-3 py-2 text-sm text-stone-600 hover:bg-stone-50 hover:text-stone-900 transition-colors">
            <%= label %>
          </a>
        <% end %>
      </nav>

      <%= link_to "← All employees", admin_employees_path, class: "block text-center text-sm text-stone-500 hover:text-stone-700" %>
    </aside>

    <%# ── Record sections — everything visible, nothing hidden in tabs ────── %>
    <div class="space-y-6 min-w-0" data-controller="reveal" data-reveal-delay-value="70">

      <section id="personal" data-scrollspy-target="section" class="card card-pad scroll-mt-24">
        <h3 class="card-title mb-4">Personal</h3>
        <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-5">
          <div>
            <dt class="eyebrow">Email</dt>
            <dd class="mt-1 text-sm text-stone-900"><%= @employee.email %></dd>
          </div>
          <div>
            <dt class="eyebrow">Phone</dt>
            <dd class="mt-1 text-sm text-stone-900 amount"><%= @employee.phone.presence || "—" %></dd>
          </div>
          <div>
            <dt class="eyebrow">Date of birth</dt>
            <dd class="mt-1 text-sm text-stone-900"><%= @employee.date_of_birth&.strftime("%d %b %Y") || "—" %></dd>
          </div>
          <div>
            <dt class="eyebrow">Gender</dt>
            <dd class="mt-1 text-sm text-stone-900"><%= @employee.gender&.titleize || "—" %></dd>
          </div>
          <div>
            <dt class="eyebrow">Address</dt>
            <dd class="mt-1 text-sm text-stone-900">
              <% if @employee.current_address.present? %>
                <%= @employee.current_address %><br>
                <span class="text-stone-600"><%= [@employee.city, @employee.state, @employee.pincode].compact_blank.join(", ") %></span>
              <% else %>
                —
              <% end %>
            </dd>
          </div>
          <div>
            <dt class="eyebrow">Emergency contact</dt>
            <dd class="mt-1 text-sm text-stone-900">
              <% if @employee.emergency_contact_name.present? %>
                <%= @employee.emergency_contact_name %>
                <span class="text-stone-500">(<%= @employee.emergency_contact_relation %>)</span><br>
                <span class="amount"><%= @employee.emergency_contact_phone %></span>
              <% else %>
                —
              <% end %>
            </dd>
          </div>
        </dl>
      </section>

      <section id="employment" data-scrollspy-target="section" class="card card-pad scroll-mt-24">
        <h3 class="card-title mb-4">Employment</h3>
        <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-5">
          <div>
            <dt class="eyebrow">Employee code</dt>
            <dd class="mt-1"><span class="code text-stone-900"><%= @employee.employee_code %></span></dd>
          </div>
          <div>
            <dt class="eyebrow">Status</dt>
            <dd class="mt-1"><%= status_badge @employee.employment_status %></dd>
          </div>
          <div>
            <dt class="eyebrow">Joining date</dt>
            <dd class="mt-1 text-sm text-stone-900"><%= @employee.joining_date.strftime("%d %b %Y") %></dd>
          </div>
          <div>
            <dt class="eyebrow">Confirmation date</dt>
            <dd class="mt-1 text-sm text-stone-900"><%= @employee.confirmation_date&.strftime("%d %b %Y") || "—" %></dd>
          </div>
          <div>
            <dt class="eyebrow">Department</dt>
            <dd class="mt-1 text-sm text-stone-900"><%= @employee.department&.name || "—" %></dd>
          </div>
          <div>
            <dt class="eyebrow">Designation</dt>
            <dd class="mt-1 text-sm text-stone-900"><%= @employee.designation&.name || "—" %></dd>
          </div>
          <div>
            <dt class="eyebrow">Reporting manager</dt>
            <dd class="mt-1 text-sm text-stone-900">
              <% if @employee.reporting_manager %>
                <%= link_to @employee.reporting_manager.full_name,
                    admin_employee_path(@employee.reporting_manager), class: "link" %>
              <% else %>
                —
              <% end %>
            </dd>
          </div>
          <% if @employee.direct_reports.any? %>
            <div>
              <dt class="eyebrow">Direct reports</dt>
              <dd class="mt-1 text-sm text-stone-900 amount"><%= @employee.direct_reports.count %></dd>
            </div>
          <% end %>
        </dl>
      </section>

      <section id="bank" data-scrollspy-target="section" class="card card-pad scroll-mt-24">
        <h3 class="card-title mb-4">Bank &amp; statutory</h3>
        <dl class="grid grid-cols-1 md:grid-cols-3 gap-x-8 gap-y-5">
          <div>
            <dt class="eyebrow">Bank name</dt>
            <dd class="mt-1 text-sm text-stone-900"><%= @employee.bank_name.presence || "—" %></dd>
          </div>
          <div>
            <dt class="eyebrow">Account number</dt>
            <dd class="mt-1"><span class="code text-stone-900"><%= @employee.bank_account_number.presence || "—" %></span></dd>
          </div>
          <div>
            <dt class="eyebrow">IFSC code</dt>
            <dd class="mt-1"><span class="code text-stone-900"><%= @employee.ifsc_code.presence || "—" %></span></dd>
          </div>
          <div>
            <dt class="eyebrow">PAN number</dt>
            <dd class="mt-1"><span class="code text-stone-900"><%= @employee.pan_number.presence || "—" %></span></dd>
          </div>
          <div>
            <dt class="eyebrow">Aadhaar number</dt>
            <dd class="mt-1"><span class="code text-stone-900"><%= @employee.aadhaar_number.presence || "—" %></span></dd>
          </div>
          <div>
            <dt class="eyebrow">UAN (PF)</dt>
            <dd class="mt-1"><span class="code text-stone-900"><%= @employee.uan_number.presence || "—" %></span></dd>
          </div>
          <div>
            <dt class="eyebrow">ESI number</dt>
            <dd class="mt-1"><span class="code text-stone-900"><%= @employee.esi_number.presence || "—" %></span></dd>
          </div>
        </dl>
        <% if @employee.bank_account_number.blank? || @employee.ifsc_code.blank? %>
          <div class="alert alert-warning mt-5 text-xs">
            Bank details are incomplete — this employee will be missing from bank transfer files.
          </div>
        <% end %>
      </section>

      <section id="salary" data-scrollspy-target="section" class="scroll-mt-24 space-y-6">
        <% if @current_salary %>
          <div class="card card-pad">
            <div class="flex items-center justify-between mb-4">
              <h3 class="card-title">Salary</h3>
              <%= link_to "Revise salary", revise_salary_admin_employee_path(@employee), class: "btn btn-secondary btn-sm" %>
            </div>
            <dl class="grid grid-cols-1 md:grid-cols-3 gap-x-8 gap-y-5">
              <div>
                <dt class="eyebrow">Annual CTC</dt>
                <dd class="mt-1 text-lg font-bold text-stone-900 amount"><%= inr(@current_salary.annual_ctc) %></dd>
              </div>
              <div>
                <dt class="eyebrow">Monthly CTC</dt>
                <dd class="mt-1 text-lg font-bold text-stone-900 amount"><%= inr(@current_salary.monthly_ctc) %></dd>
              </div>
              <div>
                <dt class="eyebrow">Structure</dt>
                <dd class="mt-1 text-sm">
                  <%= link_to @current_salary.salary_structure.name, admin_salary_structure_path(@current_salary.salary_structure), class: "link" %>
                </dd>
              </div>
              <div>
                <dt class="eyebrow">Effective from</dt>
                <dd class="mt-1 text-sm text-stone-900"><%= @current_salary.effective_from.strftime("%d %b %Y") %></dd>
              </div>
            </dl>
          </div>
          <% if @salary_history.any? %>
            <div class="card overflow-hidden">
              <div class="card-header">
                <h3 class="card-title">Salary history</h3>
              </div>
              <table class="tbl">
                <thead>
                  <tr>
                    <th class="text-right">Annual CTC</th>
                    <th>Structure</th>
                    <th>From</th>
                    <th>To</th>
                  </tr>
                </thead>
                <tbody>
                  <% @salary_history.each do |salary| %>
                    <tr>
                      <td class="num font-medium text-stone-900"><%= inr(salary.annual_ctc) %></td>
                      <td class="text-stone-700"><%= salary.salary_structure.name %></td>
                      <td class="text-stone-500"><%= salary.effective_from.strftime("%d %b %Y") %></td>
                      <td class="text-stone-500"><%= salary.effective_to&.strftime("%d %b %Y") || "—" %></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% end %>
        <% else %>
          <div class="card">
            <div class="empty-state">
              <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <h3 class="text-sm font-semibold text-stone-900">No salary assigned</h3>
              <p class="mt-1 text-sm text-stone-500">Assign a salary structure and CTC to this employee.</p>
              <%= link_to "Assign salary", assign_salary_admin_employee_path(@employee), class: "btn btn-primary mt-4" %>
            </div>
          </div>
        <% end %>
      </section>

      <section id="leave" data-scrollspy-target="section" class="card card-pad scroll-mt-24">
        <div class="flex items-center justify-between mb-4">
          <h3 class="card-title">
            Leave balances
            <span class="code ml-1"><%= LeaveBalance.current_financial_year %></span>
          </h3>
        </div>
        <% if @leave_balances.any? %>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <% @leave_balances.each do |balance| %>
              <div class="rounded-lg border border-stone-200 p-4">
                <div class="flex items-center justify-between mb-2">
                  <span class="text-sm font-medium text-stone-900"><%= balance.leave_type.name %></span>
                  <span class="code"><%= balance.leave_type.code %></span>
                </div>
                <% used_pct = balance.total_days > 0 ? (balance.used_days / balance.total_days * 100).round : 0 %>
                <div class="w-full bg-stone-100 rounded-full h-1.5 mb-2 overflow-hidden">
                  <div class="h-1.5 rounded-full animate-grow-x <%= used_pct > 80 ? 'bg-red-500' : 'bg-kula-600' %>"
                       style="width: <%= used_pct %>%"></div>
                </div>
                <div class="flex items-end justify-between">
                  <div>
                    <p class="amount text-2xl font-bold text-stone-900"><%= balance.remaining_days.to_i %></p>
                    <p class="text-xs text-stone-400">remaining of <%= balance.total_days.to_i %></p>
                  </div>
                  <div class="text-right text-xs text-stone-400">
                    <p><%= balance.used_days.to_i %> used</p>
                    <% if balance.carried_forward_days > 0 %>
                      <p class="text-kula-600"><%= balance.carried_forward_days.to_i %> carried</p>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="empty-state">
            <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5"/>
            </svg>
            <p class="text-sm text-stone-500">No leave balances for the current financial year.</p>
          </div>
        <% end %>
      </section>
    </div>
  </div>
</div>
