<div class="max-w-4xl mx-auto">
  <div class="mb-6">
    <h1 class="page-title text-2xl">Assign Salary</h1>
    <p class="mt-1 text-sm text-stone-500">
      Assign a salary structure and CTC to
      <span class="font-medium text-stone-700"><%= @employee.full_name %></span>
      (<%= @employee.employee_code %>)
    </p>
  </div>

  <%= render "salary_form",
       employee: @employee,
       employee_salary: @employee_salary,
       salary_structures: @salary_structures,
       url: assign_salary_admin_employee_path(@employee),
       submit_label: "Assign Salary" %>
</div>
