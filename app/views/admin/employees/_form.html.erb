<%= form_with model: [:admin, employee], url: url, method: local_assigns[:method] || :post, class: "space-y-8" do |f| %>
  <% if employee.errors.any? %>
    <div class="rounded-lg bg-red-50 p-4">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
        </svg>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">Please fix the following errors:</h3>
          <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
            <% employee.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <%# Main Grid for 6 cards %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <%# Personal Information %>
    <div class="card card-pad">
      <h3 class="card-title mb-4">Personal Information</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <%= f.label :first_name, class: "label" %>
          <%= f.text_field :first_name, class: "input", required: true %>
        </div>
        <div>
          <%= f.label :last_name, class: "label" %>
          <%= f.text_field :last_name, class: "input", required: true %>
        </div>
        <div>
          <%= f.label :email, class: "label" %>
          <%= f.email_field :email, class: "input", required: true, disabled: employee.persisted? %>
          <% if employee.persisted? %>
            <p class="mt-1 text-xs text-stone-500">Email cannot be changed after creation.</p>
          <% end %>
        </div>
        <div>
          <%= f.label :phone, class: "label" %>
          <%= f.telephone_field :phone, class: "input" %>
        </div>
        <div>
          <%= f.label :date_of_birth, class: "label" %>
          <%= f.date_field :date_of_birth, class: "input" %>
        </div>
        <div>
          <%= f.label :gender, class: "label" %>
          <%= f.select :gender, Employee::GENDERS.map { |g| [g.titleize, g] }, { include_blank: "Select gender" }, class: "select" %>
        </div>
      </div>
    </div>

    <%# Employment Details %>
    <div class="card card-pad">
      <h3 class="card-title mb-4">Employment Details</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <%= f.label :joining_date, class: "label" %>
          <%= f.date_field :joining_date, class: "input", required: true %>
        </div>
        <div>
          <%= f.label :confirmation_date, class: "label" %>
          <%= f.date_field :confirmation_date, class: "input" %>
        </div>
        <div>
          <%= f.label :employment_status, class: "label" %>
          <%= f.select :employment_status, Employee::EMPLOYMENT_STATUSES.map { |s| [s.titleize, s] }, {}, class: "select" %>
        </div>
        <div>
          <%= f.label :department_id, "Department", class: "label" %>
          <%= f.collection_select :department_id, @departments, :id, :name, { include_blank: "Select department" }, class: "select" %>
        </div>
        <div>
          <%= f.label :designation_id, "Designation", class: "label" %>
          <%= f.collection_select :designation_id, @designations, :id, :name, { include_blank: "Select designation" }, class: "select" %>
        </div>
        <div>
          <%= f.label :reporting_manager_id, "Reporting Manager", class: "label" %>
          <%= f.collection_select :reporting_manager_id, @managers, :id, :full_name, { include_blank: "Select manager" }, class: "select" %>
        </div>
        <% if @work_locations&.any? %>
          <div>
            <%= f.label :work_location_id, "Work Location", class: "label" %>
            <%= f.collection_select :work_location_id, @work_locations, :id, :name, { include_blank: "Company-wide (no specific location)" }, class: "select" %>
            <p class="mt-1 text-xs text-stone-500">Determines which location's holidays apply to this employee.</p>
          </div>
        <% end %>
        <div>
          <%= f.label :leave_approver, "Leave Approver", class: "label" %>
          <%= f.select :leave_approver,
              [["HR / Admin", "hr"], ["Reporting Manager", "reporting_manager"]],
              {},
              class: "select" %>
          <p class="mt-1 text-xs text-stone-500">Who approves this employee's leave requests.</p>
        </div>
      </div>
    </div>

    <%# Bank Details %>
    <div class="card card-pad">
      <h3 class="card-title mb-4">Bank Details</h3>
      <div class="space-y-6">
        <div>
          <%= f.label :bank_name, class: "label" %>
          <%= f.text_field :bank_name, class: "input" %>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <%= f.label :bank_account_number, class: "label" %>
            <%= f.text_field :bank_account_number, class: "input" %>
          </div>
          <div>
            <%= f.label :ifsc_code, "IFSC Code", class: "label" %>
            <%= f.text_field :ifsc_code, class: "input" %>
          </div>
        </div>
      </div>
    </div>

    <%# Statutory Details %>
    <div class="card card-pad">
      <h3 class="card-title mb-4">Statutory Details</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <%= f.label :pan_number, "PAN Number", class: "label" %>
          <%= f.text_field :pan_number, class: "input uppercase", placeholder: "ABCDE1234F" %>
        </div>
        <div>
          <%= f.label :aadhaar_number, "Aadhaar Number", class: "label" %>
          <%= f.text_field :aadhaar_number, class: "input", placeholder: "123456789012" %>
        </div>
        <div>
          <%= f.label :uan_number, "UAN (PF)", class: "label" %>
          <%= f.text_field :uan_number, class: "input" %>
        </div>
        <div>
          <%= f.label :esi_number, "ESI Number", class: "label" %>
          <%= f.text_field :esi_number, class: "input" %>
        </div>
      </div>
    </div>

    <%# Address %>
    <div class="card card-pad">
      <h3 class="card-title mb-4">Address</h3>
      <div class="grid grid-cols-1 gap-6">
        <div>
          <%= f.label :current_address, class: "label" %>
          <%= f.text_area :current_address, rows: 2, class: "input" %>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-6">
        <div>
          <%= f.label :city, class: "label" %>
          <%= f.text_field :city, class: "input" %>
        </div>
        <div>
          <%= f.label :state, class: "label" %>
          <%= f.text_field :state, class: "input" %>
        </div>
        <div>
          <%= f.label :pincode, class: "label" %>
          <%= f.text_field :pincode, class: "input", placeholder: "400001" %>
        </div>
      </div>
    </div>

    <%# Emergency Contact %>
    <div class="card card-pad">
      <h3 class="card-title mb-4">Emergency Contact</h3>
      <div class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <%= f.label :emergency_contact_first_name, "First Name", class: "label" %>
            <%= f.text_field :emergency_contact_first_name, class: "input" %>
          </div>
          <div>
            <%= f.label :emergency_contact_last_name, "Last Name", class: "label" %>
            <%= f.text_field :emergency_contact_last_name, class: "input" %>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <%= f.label :emergency_contact_phone, "Phone", class: "label" %>
            <%= f.telephone_field :emergency_contact_phone, class: "input" %>
          </div>
          <div>
            <%= f.label :emergency_contact_relation, "Relation", class: "label" %>
            <%= f.text_field :emergency_contact_relation, class: "input", placeholder: "e.g. Spouse, Parent" %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Submit %>
  <div class="flex items-center gap-3">
    <%= f.submit employee.persisted? ? "Update Employee" : "Create Employee",
        class: "btn btn-primary cursor-pointer" %>
    <%= link_to "Cancel", employee.persisted? ? admin_employee_path(employee) : admin_employees_path,
        class: "btn btn-ghost" %>
  </div>
<% end %>
