<div class="max-w-4xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="page-title text-2xl">Announcements</h1>
      <p class="text-sm text-stone-500 mt-1">Share news, events and updates with all employees.</p>
    </div>
    <%= link_to new_admin_announcement_path,
        class: "btn btn-primary" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      New Announcement
    <% end %>
  </div>

  <div class="card overflow-hidden">
    <% if @announcements.any? %>
      <div class="overflow-x-auto">
        <table class="tbl">
          <thead>
            <tr>
              <th>Title</th>
              <th>Status</th>
              <th>Date</th>
              <th>Read</th>
              <th class="text-right">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @announcements.each do |announcement| %>
              <tr class="hover:bg-stone-50">
                <td class="text-sm font-medium text-stone-900">
                  <%= link_to announcement.title, admin_announcement_path(announcement), class: "hover:text-kula-700" %>
                </td>
                <td>
                  <% if announcement.published? %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-700">Published</span>
                  <% else %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-stone-100 text-stone-500">Draft</span>
                  <% end %>
                </td>
                <td class="text-sm text-stone-500">
                  <%= (announcement.published_at || announcement.created_at).strftime("%d %b %Y") %>
                </td>
                <td class="text-sm text-stone-500">
                  <% if announcement.published? %>
                    <span class="font-medium text-stone-900"><%= @read_counts[announcement.id] || 0 %></span>
                    <span class="text-stone-400">/ <%= @active_count %></span>
                  <% else %>
                    <span class="text-stone-300">&mdash;</span>
                  <% end %>
                </td>
                <td class="text-right">
                  <div class="flex items-center justify-end gap-2">
                    <% unless announcement.published? %>
                      <%= button_to publish_admin_announcement_path(announcement), method: :patch,
                          title: "Publish",
                          class: "p-1.5 rounded-md text-emerald-600 hover:bg-emerald-100 transition-colors cursor-pointer" do %>
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                      <% end %>
                    <% end %>

                    <%= link_to edit_admin_announcement_path(announcement),
                        title: "Edit",
                        class: "p-1.5 rounded-md text-kula-700 hover:bg-kula-100 transition-colors cursor-pointer" do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                      </svg>
                    <% end %>

                    <%= button_to admin_announcement_path(announcement), method: :delete,
                        title: "Delete",
                        class: "p-1.5 rounded-md text-red-600 hover:bg-red-100 transition-colors cursor-pointer",
                        form: { data: { turbo_confirm: "Delete '#{announcement.title}'? This cannot be undone." } } do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                      </svg>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="p-12 text-center">
        <svg class="mx-auto h-10 w-10 text-stone-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
        </svg>
        <p class="text-sm text-stone-500">No announcements yet. Create one to share news with your team.</p>
      </div>
    <% end %>
  </div>
</div>
