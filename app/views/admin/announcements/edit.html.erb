<div class="max-w-2xl mx-auto">
  <div class="mb-6">
    <%= link_to admin_announcements_path, class: "text-sm text-gray-500 hover:text-gray-700 inline-flex items-center gap-1 mb-2" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to announcements
    <% end %>
    <h1 class="text-2xl font-bold text-gray-900">Edit Announcement</h1>
  </div>

  <div class="bg-white rounded-lg border border-gray-200 p-6">
    <%= render "form", announcement: @announcement %>
  </div>
</div>
