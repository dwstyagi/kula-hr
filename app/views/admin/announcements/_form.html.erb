<%= form_with model: [ :admin, announcement ], class: "space-y-4" do |f| %>
  <% if announcement.errors.any? %>
    <div class="rounded-lg bg-red-50 p-4">
      <ul class="text-sm text-red-700 list-disc list-inside space-y-1">
        <% announcement.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, class: "label" %>
    <%= f.text_field :title,
        class: "input",
        autofocus: true,
        placeholder: "e.g. Office closed on Friday for Diwali" %>
  </div>

  <div>
    <%= f.label :body, "Message", class: "label" %>
    <%= f.text_area :body, rows: 8,
        class: "input",
        placeholder: "Write the announcement details here…" %>
  </div>

  <% if announcement.persisted? && announcement.published? %>
    <div class="rounded-lg bg-amber-50 border border-amber-200 p-3">
      <label class="flex items-start gap-2 cursor-pointer">
        <%= check_box_tag :notify_readers, "1", false, class: "mt-0.5 rounded border-stone-300 text-kula-700 shadow-sm focus:ring-kula-600" %>
        <span class="text-sm text-amber-800">
          <span class="font-medium">Notify employees who already read this.</span>
          Marks the announcement as unread again for everyone, so they re-read the update. Leave unchecked for minor fixes like typos.
        </span>
      </label>
    </div>
  <% end %>

  <div class="flex items-center gap-3 pt-1">
    <%= f.submit announcement.persisted? ? "Save Changes" : "Create Announcement",
        class: "btn btn-primary cursor-pointer" %>
    <%= link_to "Cancel", admin_announcements_path,
        class: "btn btn-ghost" %>
  </div>
<% end %>
