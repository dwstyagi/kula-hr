<div class="space-y-6" data-controller="readiness">
  <div>
    <h1 class="page-title text-2xl">Run Payroll</h1>
    <p class="text-sm text-stone-500 mt-0.5">Select the month and year to process payroll for</p>
  </div>
  <%= form_with model: [:admin, @payroll_run], class: "space-y-6" do |f| %>
    <% if @payroll_run.errors.any? %>
      <div class="rounded-lg bg-red-50 border border-red-200 p-4 text-sm text-red-700">
        <p class="font-semibold mb-1">Could not create payroll run:</p>
        <ul class="list-disc list-inside space-y-1">
          <% @payroll_run.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    <%# Row 1: Period + Notes %>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div class="card card-pad space-y-4">
        <h2 class="text-base font-semibold text-stone-900 border-b border-stone-100 pb-3">Payroll Period</h2>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="label">Month</label>
            <%= f.select :month,
                  (1..12).map { |m| [Date::MONTHNAMES[m], m] },
                  { selected: @payroll_run.month || Date.today.month },
                  class: "select",
                  data: { action: "change->readiness#refresh" } %>
          </div>
          <div>
            <label class="label">Year</label>
            <%= f.number_field :year,
                  value: @payroll_run.year || Date.today.year,
                  min: 2020, max: 2099,
                  class: "input",
                  data: { action: "change->readiness#refresh" } %>
          </div>
        </div>
      </div>
      <div class="card card-pad space-y-4">
        <h2 class="text-base font-semibold text-stone-900 border-b border-stone-100 pb-3">Notes</h2>
        <%= f.text_area :notes, rows: 3,
              placeholder: "Any notes for this payroll run…",
              class: "textarea" %>
      </div>
    </div>
    <%# Row 2: Prerequisites + Actions %>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div class="card card-pad">
        <%= render "readiness", readiness: @readiness, payroll_run: @payroll_run %>
      </div>
      <div class="card card-pad space-y-4">
        <h2 class="text-base font-semibold text-stone-900 border-b border-stone-100 pb-3">Actions</h2>
        <p class="text-sm text-stone-500">Review the details and click below to create the payroll run.</p>
        <div class="flex items-center gap-3 pt-2">
          <%= f.submit "Create Payroll Run",
                class: "px-5 py-2 bg-kula-700 text-white text-sm font-medium rounded-lg hover:bg-kula-800 cursor-pointer" %>
          <%= link_to "Cancel", admin_payroll_runs_path,
                class: "px-4 py-2 text-sm font-medium text-stone-700 hover:text-stone-900" %>
        </div>
      </div>
    </div>
  <% end %>
</div>
