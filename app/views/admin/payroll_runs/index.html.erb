<div class="space-y-6">
  <%# Header %>
  <div class="flex items-center justify-between">
    <div>
      <h1 class="page-title text-2xl">Payroll Runs</h1>
      <p class="text-sm text-stone-500 mt-0.5">Manage monthly payroll processing</p>
    </div>
    <div class="flex items-center gap-3">
      <% if @years.any? %>
        <%= form_with url: admin_payroll_runs_path, method: :get do |f| %>
          <%= f.select :year,
                options_for_select([ [ "All years", "" ] ] + @years.map { |y| [ y, y ] }, @year),
                {},
                class: "select w-36",
                aria: { label: "Filter by year" },
                onchange: "this.form.requestSubmit()" %>
        <% end %>
      <% end %>
      <%= link_to new_admin_payroll_run_path,
            class: "btn btn-primary" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Run Payroll
      <% end %>
    </div>
  </div>

  <%# Anchor card — current period at a glance, with one CTA to resume or start %>
  <div class="card card-pad flex flex-wrap items-center justify-between gap-4 border-kula-200 bg-kula-50/40 animate-fade-up">
    <% if @current_run %>
      <div class="flex flex-wrap items-center gap-4">
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-widest text-kula-700">Current period</p>
          <p class="text-lg font-bold text-stone-900 mt-0.5"><%= @current_run.period_label %></p>
        </div>
        <span class="badge <%= @current_run.status_badge_classes %>"><%= @current_run.status_badge_label %></span>
        <% unless @current_run.draft? %>
          <div class="hidden sm:flex items-center gap-6 pl-4 border-l border-kula-200">
            <div>
              <p class="text-[11px] text-stone-500 uppercase tracking-wide">Employees</p>
              <p class="text-sm font-semibold text-stone-900 amount"><%= @current_run.processed_employees %></p>
            </div>
            <div>
              <p class="text-[11px] text-stone-500 uppercase tracking-wide">Net pay</p>
              <p class="text-sm font-semibold text-stone-900 amount"><%= @current_run.formatted_total_net_pay %></p>
            </div>
          </div>
        <% end %>
      </div>
      <% if @current_run.paid? %>
        <%= link_to new_admin_payroll_run_path(month: @next_period_month, year: @next_period_year), class: "btn btn-primary" do %>
          Start <%= Date::MONTHNAMES[@next_period_month] %> <%= @next_period_year %> run →
        <% end %>
      <% else %>
        <%= link_to "Continue run →", admin_payroll_run_path(@current_run), class: "btn btn-primary" %>
      <% end %>
    <% else %>
      <div>
        <p class="text-[11px] font-semibold uppercase tracking-widest text-kula-700">Get started</p>
        <p class="text-lg font-bold text-stone-900 mt-0.5">No payroll runs yet</p>
      </div>
      <%= link_to new_admin_payroll_run_path(month: @next_period_month, year: @next_period_year), class: "btn btn-primary" do %>
        Start <%= Date::MONTHNAMES[@next_period_month] %> <%= @next_period_year %> run →
      <% end %>
    <% end %>
  </div>

  <%# Table %>
  <div class="card overflow-hidden">
    <% if @payroll_runs.any? %>
      <div class="overflow-x-auto">
      <table class="tbl">
        <thead>
          <tr>
            <th>Period</th>
            <th>Status</th>
            <th class="text-right">Employees</th>
            <th class="text-right">Net Pay</th>
            <th>Initiated By</th>
            <th>Date</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @payroll_runs.each do |run| %>
            <tr>
              <td>
                <%= link_to run.period_label, admin_payroll_run_path(run),
                      class: "font-medium text-stone-900 hover:text-kula-700 hover:underline underline-offset-2" %>
              </td>
              <td><%= render "status_badge", payroll_run: run %></td>
              <td class="num text-stone-600">
                <% if run.processing? %>
                  <%= run.processed_employees %> / <%= run.total_employees %>
                <% else %>
                  <%= run.processed_employees %>
                <% end %>
              </td>
              <td class="num text-stone-900 font-semibold">
                <% if run.total_net_pay > 0 %>
                  <%= run.formatted_total_net_pay %>
                <% else %>
                  <span class="text-stone-400 font-normal">—</span>
                <% end %>
              </td>
              <td class="text-stone-600"><%= run.initiated_by.full_name %></td>
              <td class="text-stone-500"><%= run.created_at.strftime("%d %b %Y") %></td>
              <td class="text-right">
                <%= link_to admin_payroll_run_path(run),
                      title: "View",
                      class: "inline-flex items-center justify-center size-8 rounded-lg text-stone-400 hover:text-kula-700 hover:bg-kula-50 transition-colors" do %>
                  <svg class="size-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                  </svg>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      </div>
    <% else %>
      <div class="text-center py-16 text-stone-400">
        <svg class="w-12 h-12 mx-auto mb-3 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        <% if @year %>
          <p class="font-medium">No payroll runs in <%= @year %></p>
          <p class="text-sm mt-1"><%= link_to "Show all years", admin_payroll_runs_path, class: "text-kula-700 hover:underline" %></p>
        <% else %>
          <p class="font-medium">No payroll runs yet</p>
          <p class="text-sm mt-1">Click "Run Payroll" to start your first payroll run.</p>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
