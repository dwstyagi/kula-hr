<div class="space-y-6">
  <%# Header %>
  <div class="flex items-center justify-between">
    <div>
      <h1 class="page-title text-2xl">Payroll Runs</h1>
      <p class="text-sm text-stone-500 mt-0.5">Manage monthly payroll processing</p>
    </div>
    <%= link_to new_admin_payroll_run_path,
          class: "btn btn-primary" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Run Payroll
    <% end %>
  </div>

  <%# Table %>
  <div class="card overflow-hidden">
    <% if @payroll_runs.any? %>
      <div class="overflow-x-auto">
      <table class="tbl">
        <thead>
          <tr>
            <th>Period</th>
            <th>Status</th>
            <th class="text-right">Employees</th>
            <th class="text-right">Net Pay</th>
            <th>Initiated By</th>
            <th>Date</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @payroll_runs.each do |run| %>
            <tr>
              <td class="font-medium text-stone-900"><%= run.period_label %></td>
              <td><%= render "status_badge", payroll_run: run %></td>
              <td class="num text-stone-600">
                <% if run.processing? %>
                  <%= run.processed_employees %> / <%= run.total_employees %>
                <% else %>
                  <%= run.processed_employees %>
                <% end %>
              </td>
              <td class="num text-stone-900 font-semibold">
                <% if run.total_net_pay > 0 %>
                  <%= run.formatted_total_net_pay %>
                <% else %>
                  <span class="text-stone-400 font-normal">—</span>
                <% end %>
              </td>
              <td class="text-stone-600"><%= run.initiated_by.full_name %></td>
              <td class="text-stone-500"><%= run.created_at.strftime("%d %b %Y") %></td>
              <td class="text-right">
                <%= link_to admin_payroll_run_path(run),
                      title: "View",
                      class: "inline-flex items-center justify-center size-8 rounded-lg text-stone-400 hover:text-kula-700 hover:bg-kula-50 transition-colors" do %>
                  <svg class="size-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                  </svg>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      </div>
    <% else %>
      <div class="text-center py-16 text-stone-400">
        <svg class="w-12 h-12 mx-auto mb-3 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        <p class="font-medium">No payroll runs yet</p>
        <p class="text-sm mt-1">Click "Run Payroll" to start your first payroll run.</p>
      </div>
    <% end %>
  </div>
</div>
