<%# locals: readiness (Payroll::ReadinessCheck::Result), payroll_run %>
<%= turbo_frame_tag "readiness", data: { readiness_target: "frame" } do %>
  <div class="space-y-3">
    <div class="flex items-center justify-between border-b border-stone-100 pb-3">
      <h2 class="text-base font-semibold text-stone-900">Readiness</h2>
      <span class="text-xs text-stone-400"><%= payroll_run.month_name %> <%= payroll_run.year %></span>
    </div>

    <% if readiness.eligible_count.zero? %>
      <p class="text-sm text-stone-500">No eligible employees for this period.</p>
    <% else %>
      <%# Headline counts %>
      <div class="flex items-center gap-4 text-sm">
        <span class="inline-flex items-center gap-1.5 text-emerald-700">
          <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
          <strong><%= readiness.ready_count %></strong>&nbsp;ready
        </span>
        <% if readiness.blocking.any? %>
          <span class="inline-flex items-center gap-1.5 text-red-700">
            <span class="w-2 h-2 rounded-full bg-red-500"></span>
            <strong><%= readiness.blocking.size %></strong>&nbsp;blocking
          </span>
        <% end %>
        <% if readiness.will_skip.any? %>
          <span class="inline-flex items-center gap-1.5 text-amber-700">
            <span class="w-2 h-2 rounded-full bg-amber-500"></span>
            <strong><%= readiness.will_skip.size %></strong>&nbsp;will be skipped
          </span>
        <% end %>
      </div>

      <%# Hard blockers — prevent creation %>
      <% if readiness.blocking.any? %>
        <div class="rounded-lg bg-red-50 border border-red-200 p-3 text-sm">
          <p class="font-medium text-red-800 mb-1">⛔ Cannot create until attendance is locked:</p>
          <ul class="list-disc list-inside text-red-700 space-y-0.5">
            <% readiness.blocking.each do |s| %>
              <li><%= s.employee.full_name %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# Soft — will be silently skipped at processing unless fixed %>
      <% if readiness.will_skip.any? %>
        <div class="rounded-lg bg-amber-50 border border-amber-200 p-3 text-sm">
          <p class="font-medium text-amber-800 mb-1">⚠️ These employees will be excluded (not paid):</p>
          <ul class="list-disc list-inside text-amber-700 space-y-0.5">
            <% readiness.will_skip.each do |s| %>
              <li><%= s.employee.full_name %> — <%= s.reasons.join(", ") %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <% if readiness.blocking.empty? && readiness.will_skip.empty? %>
        <p class="text-sm text-emerald-700">All eligible employees are ready to be paid. ✓</p>
      <% end %>
    <% end %>
  </div>
<% end %>
