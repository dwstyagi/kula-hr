<div class="space-y-6">
  <%# Header %>
  <div class="flex items-start justify-between">
    <div>
      <div class="flex items-center gap-3">
        <h1 class="text-2xl font-bold text-gray-900">Payroll — <%= @payroll_run.period_label %></h1>
        <%= render "status_badge", payroll_run: @payroll_run %>
      </div>
      <p class="text-sm text-gray-500 mt-1">
        Initiated by <%= @payroll_run.initiated_by.full_name %> on <%= @payroll_run.created_at.strftime("%d %b %Y") %>
      </p>
    </div>
    <%= link_to "← All Runs", admin_payroll_runs_path,
          class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>

  <%# Rejection reason banner %>
  <% if @payroll_run.rejected? && @payroll_run.rejection_reason.present? %>
    <div class="rounded-lg bg-red-50 border border-red-200 p-4 text-sm text-red-700">
      <p class="font-medium">Rejection Reason:</p>
      <p class="mt-1"><%= @payroll_run.rejection_reason %></p>
    </div>
  <% end %>

  <%# Progress bar (shown while processing or in draft) %>
  <% if @payroll_run.draft? || @payroll_run.processing? %>
    <%= render "progress", payroll_run: @payroll_run %>
  <% end %>

  <%# Summary cards (shown once processing is done) %>
  <% if @payroll_run.processed? || @payroll_run.under_review? || @payroll_run.approved? || @payroll_run.rejected? || @payroll_run.paid? %>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      <%= render "summary_card", label: "Total Gross",      value: @payroll_run.total_gross,         color: "blue" %>
      <%= render "summary_card", label: "Total Deductions", value: @payroll_run.total_deductions,    color: "orange" %>
      <%= render "summary_card", label: "Total Net Pay",    value: @payroll_run.total_net_pay,        color: "green" %>
      <%= render "summary_card", label: "Employer PF",      value: @payroll_run.payslips.sum(:employer_pf),  color: "gray" %>
      <%= render "summary_card", label: "Employer ESI",     value: @payroll_run.payslips.sum(:employer_esi), color: "gray" %>
      <%= render "summary_card", label: "Total CTC Cost",   value: @payroll_run.total_gross + @payroll_run.total_employer_cost, color: "purple" %>
    </div>

    <%# Processed / skipped counts %>
    <div class="bg-white rounded-xl border border-gray-200 p-4 flex items-center gap-6 text-sm">
      <span class="text-gray-600">
        <strong class="text-gray-900"><%= @payroll_run.processed_employees %></strong> processed
      </span>
      <% skipped = @payroll_run.total_employees - @payroll_run.processed_employees %>
      <% if skipped > 0 %>
        <span class="text-amber-600">
          <strong><%= skipped %></strong> skipped
        </span>
      <% end %>
    </div>

    <%# Action buttons based on current state %>
    <div class="flex flex-wrap items-center gap-3">
      <% if @payroll_run.processed? && policy(@payroll_run).submit_for_review? %>
        <%= button_to "Submit for Review",
              submit_for_review_admin_payroll_run_path(@payroll_run),
              method: :patch,
              class: "px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 cursor-pointer" %>
      <% end %>

      <% if @payroll_run.processed? && policy(@payroll_run).reprocess? %>
        <%= button_to "Reprocess",
              reprocess_admin_payroll_run_path(@payroll_run),
              method: :patch,
              class: "px-4 py-2 bg-white border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 cursor-pointer",
              form: { data: { turbo_confirm: "This will delete all payslips and re-run payroll. Are you sure?" } } %>
      <% end %>

      <% if @payroll_run.under_review? && policy(@payroll_run).approve? %>
        <%= button_to "Approve",
              approve_admin_payroll_run_path(@payroll_run),
              method: :patch,
              class: "px-4 py-2 bg-green-600 text-white text-sm font-medium rounded-lg hover:bg-green-700 cursor-pointer",
              form: { data: { turbo_confirm: "Approve payroll for #{@payroll_run.period_label}? This will lock all payslips." } } %>

        <%# Reject form with reason %>
        <%= form_with url: reject_admin_payroll_run_path(@payroll_run), method: :patch, class: "flex items-center gap-2" do |f| %>
          <%= f.text_field :rejection_reason, placeholder: "Rejection reason…",
                class: "border border-gray-300 rounded-lg px-3 py-2 text-sm w-64 focus:ring-2 focus:ring-red-500 focus:border-red-500" %>
          <%= f.submit "Reject",
                class: "px-4 py-2 bg-red-600 text-white text-sm font-medium rounded-lg hover:bg-red-700 cursor-pointer" %>
        <% end %>
      <% end %>

      <% if @payroll_run.rejected? && policy(@payroll_run).reprocess? %>
        <%= button_to "Reprocess",
              reprocess_admin_payroll_run_path(@payroll_run),
              method: :patch,
              class: "px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 cursor-pointer",
              form: { data: { turbo_confirm: "This will delete all payslips and re-run payroll. Are you sure?" } } %>
      <% end %>

      <% if @payroll_run.approved? && policy(@payroll_run).mark_paid? %>
        <%= button_to "Mark as Paid",
              mark_paid_admin_payroll_run_path(@payroll_run),
              method: :patch,
              class: "px-4 py-2 bg-emerald-600 text-white text-sm font-medium rounded-lg hover:bg-emerald-700 cursor-pointer",
              form: { data: { turbo_confirm: "Confirm bank transfer is complete and mark payroll as Paid?" } } %>
      <% end %>
    </div>

    <%# Link to payslips %>
    <%= link_to admin_payroll_run_payslips_path(@payroll_run),
          class: "bg-white rounded-xl border border-gray-200 p-4 flex items-center justify-between hover:bg-gray-50 transition-colors" do %>
      <p class="text-sm font-medium text-gray-700">
        Payslips
        <span class="ml-2 text-xs font-normal text-gray-400"><%= @payroll_run.processed_employees %> generated</span>
      </p>
      <span class="text-xs text-blue-600 font-medium">Review individual payslips →</span>
    <% end %>
  <% end %>
</div>
