<% content_for :page_title, "Payroll · #{@payroll_run.period_label}" %>

<div class="space-y-6 pb-2">
  <%# Header %>
  <div class="flex items-start justify-between gap-4">
    <div>
      <div class="flex items-center gap-3">
        <h1 class="page-title text-2xl">Payroll — <%= @payroll_run.period_label %></h1>
        <span class="badge <%= @payroll_run.status_badge_classes %>"><%= @payroll_run.status_badge_label %></span>
      </div>
      <p class="page-sub">
        Initiated by <%= @payroll_run.initiated_by.full_name %> on <%= @payroll_run.created_at.strftime("%d %b %Y") %>
        <% if @payroll_run.approved_by.present? %>
          · approved by <%= @payroll_run.approved_by.full_name %>
        <% end %>
      </p>
    </div>
    <%= link_to "← All runs", admin_payroll_runs_path, class: "text-sm text-stone-500 hover:text-stone-700 whitespace-nowrap mt-1" %>
  </div>

  <%# The guided flow %>
  <%= render "stepper", payroll_run: @payroll_run %>

  <%# Step content %>
  <% if @payroll_run.draft? %>
    <%= render "step_review", payroll_run: @payroll_run, readiness: @readiness %>

  <% elsif @payroll_run.processing? %>
    <%# Subscribe OUTSIDE #payroll_progress: broadcasts replace that div, and a
        stream source inside it would be torn down (dropping messages) on every
        update. %>
    <%= turbo_stream_from "payroll_run_#{@payroll_run.id}" %>
    <%= render "progress", payroll_run: @payroll_run %>

  <% else %>
    <%# Rejection reason — pinned above everything while it needs attention %>
    <% if @payroll_run.rejected? && @payroll_run.rejection_reason.present? %>
      <div class="alert alert-error animate-fade-up">
        <svg class="size-5 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/>
        </svg>
        <div>
          <p class="font-semibold">Rejected by reviewer</p>
          <p class="mt-0.5"><%= @payroll_run.rejection_reason %></p>
          <p class="mt-1 text-xs opacity-80">Correct the payslips (or reprocess from scratch), then resubmit for review.</p>
        </div>
      </div>
    <% end %>

    <%# Totals %>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4" data-controller="reveal" data-reveal-delay-value="50">
      <div class="stat-card">
        <p class="stat-label">Gross pay</p>
        <p class="stat-value"><%= @payroll_run.formatted_total_gross %></p>
      </div>
      <div class="stat-card">
        <p class="stat-label">Deductions</p>
        <p class="stat-value">− <%= @payroll_run.formatted_total_deductions %></p>
        <p class="stat-sub">PF, ESI, PT &amp; TDS withheld</p>
      </div>
      <div class="stat-card">
        <p class="stat-label">Net pay</p>
        <p class="stat-value text-kula-700"
           data-controller="countup"
           data-countup-value-value="<%= @payroll_run.total_net_pay.to_f.round %>"
           data-countup-prefix-value="₹"><%= @payroll_run.formatted_total_net_pay %></p>
        <p class="stat-sub">To be transferred to employees</p>
      </div>
      <div class="stat-card">
        <p class="stat-label">Total cost to company</p>
        <p class="stat-value"><%= @payroll_run.money(@payroll_run.total_gross + @payroll_run.total_employer_cost) %></p>
        <p class="stat-sub">Incl. employer PF <%= @payroll_run.money(@payroll_run.payslips.sum(:employer_pf)) %> · ESI <%= @payroll_run.money(@payroll_run.payslips.sum(:employer_esi)) %></p>
      </div>
    </div>

    <%# Skipped employees — the exception that still matters after processing %>
    <% skipped = @payroll_run.total_employees - @payroll_run.processed_employees %>
    <% if skipped.positive? %>
      <div class="alert alert-warning animate-fade-up">
        <svg class="size-5 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
        </svg>
        <p><strong><%= skipped %> employee<%= "s" unless skipped == 1 %></strong> <%= skipped == 1 ? "was" : "were" %> skipped in this run (missing locked attendance or salary). They will not be paid unless you fix and reprocess.</p>
      </div>
    <% end %>

    <%# Payslips + documents %>
    <div class="grid gap-4 <%= (@payroll_run.approved? || @payroll_run.paid?) ? "md:grid-cols-2" : "" %>">
      <%= link_to admin_payroll_run_payslips_path(@payroll_run), class: "card card-pad flex items-center justify-between gap-4 group hover:border-kula-300 transition-colors" do %>
        <div>
          <p class="text-sm font-semibold text-stone-900">Payslips
            <span class="ml-2 text-xs font-normal text-stone-400 amount"><%= @payroll_run.processed_employees %> generated</span>
          </p>
          <p class="text-xs text-stone-500 mt-0.5">Review individual payslips before <%= @payroll_run.processed? ? "submitting" : "paying" %></p>
        </div>
        <span class="text-kula-700 text-sm font-medium group-hover:translate-x-0.5 transition-transform">Open →</span>
      <% end %>

      <% if @payroll_run.approved? || @payroll_run.paid? %>
        <%= link_to bank_file_admin_payroll_run_path(@payroll_run), class: "card card-pad flex items-center justify-between gap-4 group hover:border-kula-300 transition-colors" do %>
          <div>
            <p class="text-sm font-semibold text-stone-900">Bank transfer file</p>
            <p class="text-xs text-stone-500 mt-0.5">HDFC · ICICI · SBI · generic CSV for salary disbursement</p>
          </div>
          <span class="text-kula-700 text-sm font-medium group-hover:translate-x-0.5 transition-transform">Generate →</span>
        <% end %>
      <% end %>
    </div>

    <%# Secondary / destructive actions live here, not in the sticky bar %>
    <div class="flex flex-wrap items-center gap-3">
      <%= link_to download_payslips_admin_payroll_run_path(@payroll_run), class: "btn btn-secondary btn-sm" do %>
        <svg class="size-4" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
        Download all payslips (ZIP)
      <% end %>

      <% if (@payroll_run.processed? || @payroll_run.rejected?) && policy(@payroll_run).reprocess? %>
        <%= button_to "Reprocess from scratch", reprocess_admin_payroll_run_path(@payroll_run),
              method: :patch, class: "btn btn-ghost btn-sm cursor-pointer",
              form: { data: { turbo_confirm: "This will delete all payslips and re-run payroll. Are you sure?" } } %>
      <% end %>
    </div>

    <%# Reviewer's reject form %>
    <% if @payroll_run.under_review? && policy(@payroll_run).approve? %>
      <div class="card card-pad">
        <p class="text-sm font-semibold text-stone-900">Something wrong?</p>
        <p class="text-xs text-stone-500 mt-0.5 mb-3">Send it back to HR with a reason — they can correct payslips and resubmit.</p>
        <%= form_with url: reject_admin_payroll_run_path(@payroll_run), method: :patch, class: "flex flex-wrap items-center gap-2" do |f| %>
          <%= f.text_field :rejection_reason, placeholder: "Reason for rejection…", required: true, class: "input max-w-md flex-1" %>
          <%= f.submit "Reject payroll", class: "btn btn-danger cursor-pointer" %>
        <% end %>
      </div>
    <% end %>

    <%# Paid — the finish line %>
    <% if @payroll_run.paid? %>
      <div class="card card-pad text-center space-y-2 animate-scale-in">
        <span class="mx-auto flex size-12 items-center justify-center rounded-full bg-emerald-50">
          <svg class="size-6 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" class="draw-stroke"/>
          </svg>
        </span>
        <p class="text-base font-semibold text-stone-900">Payroll complete for <%= @payroll_run.period_label %></p>
        <p class="text-sm text-stone-500"><%= @payroll_run.processed_employees %> employees paid <%= @payroll_run.formatted_total_net_pay %> — payslips are locked and visible in the employee portal.</p>
      </div>
    <% end %>
  <% end %>

  <%# Sticky totals + primary action %>
  <%= render "totals_bar", payroll_run: @payroll_run, readiness: @readiness %>
</div>
