<div class="space-y-6">
  <%# Breadcrumb %>
  <div>
    <div class="flex items-center gap-2 text-sm text-gray-500 mb-1">
      <%= link_to "Payroll Runs", admin_payroll_runs_path, class: "hover:text-gray-700" %>
      <span>/</span>
      <%= link_to @payroll_run.period_label, admin_payroll_run_path(@payroll_run), class: "hover:text-gray-700" %>
      <span>/</span>
      <span class="text-gray-900">Bank File</span>
    </div>
    <h1 class="text-2xl font-bold text-gray-900">Generate Bank File</h1>
    <p class="text-sm text-gray-500 mt-0.5"><%= @payroll_run.period_label %></p>
  </div>

  <%# Summary card %>
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <div class="grid grid-cols-3 gap-6 text-sm">
      <div>
        <p class="text-xs text-gray-400 uppercase tracking-wide">Status</p>
        <p class="font-semibold text-gray-900 mt-1 capitalize"><%= @payroll_run.status.humanize %></p>
      </div>
      <div>
        <p class="text-xs text-gray-400 uppercase tracking-wide">Employees</p>
        <p class="font-semibold text-gray-900 mt-1"><%= @payroll_run.processed_employees %></p>
      </div>
      <div>
        <p class="text-xs text-gray-400 uppercase tracking-wide">Total Net Pay</p>
        <p class="font-semibold text-gray-900 mt-1"><%= @payroll_run.formatted_total_net_pay %></p>
      </div>
    </div>
  </div>

  <%# Missing bank details warning %>
  <% if @missing.any? %>
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-4">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-amber-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
        </svg>
        <div>
          <p class="text-sm font-semibold text-amber-800">
            <%= @missing.count %> employee<%= @missing.count == 1 ? '' : 's' %> missing bank details — will be excluded
          </p>
          <ul class="mt-1.5 space-y-0.5">
            <% @missing.each do |emp| %>
              <li class="text-xs text-amber-700"><%= emp.full_name %> (<%= emp.employee_code %>)</li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <%# Format selector %>
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100">
      <h2 class="text-sm font-semibold text-gray-900">Select Bank Format</h2>
      <p class="text-xs text-gray-500 mt-0.5">Choose the format required by your company's bank</p>
    </div>

    <div class="divide-y divide-gray-100" id="bank-options">
      <% [
        { key: "hdfc",        label: "HDFC Bank",   desc: "NEFT/RTGS tilde-delimited text file for HDFC Corporate Internet Banking", ext: ".txt" },
        { key: "icici",       label: "ICICI Bank",  desc: "Pipe-delimited format for ICICI Corporate Internet Banking", ext: ".txt" },
        { key: "sbi",         label: "SBI",         desc: "CMP (Corporate Multi-Payment) format for State Bank of India", ext: ".txt" },
        { key: "generic_csv", label: "Generic CSV", desc: "Universal CSV format — works with any bank or payment processor", ext: ".csv" }
      ].each_with_index do |bank, i| %>
        <label class="flex items-center gap-4 px-5 py-4 cursor-pointer hover:bg-gray-50 transition-colors">
          <input type="radio" name="bank_format" value="<%= bank[:key] %>"
                 <%= i == 3 ? 'checked' : '' %>
                 class="w-4 h-4 text-blue-600 border-gray-300 focus:ring-blue-500"
                 onchange="updateDownloadLink(this.value)">
          <div class="flex-1">
            <div class="flex items-center gap-2">
              <span class="text-sm font-medium text-gray-900"><%= bank[:label] %></span>
              <span class="text-xs font-mono bg-gray-100 text-gray-500 px-1.5 py-0.5 rounded"><%= bank[:ext] %></span>
            </div>
            <p class="text-xs text-gray-500 mt-0.5"><%= bank[:desc] %></p>
          </div>
        </label>
      <% end %>
    </div>

    <div class="px-5 py-4 bg-gray-50 border-t border-gray-100">
      <%= link_to download_bank_file_admin_payroll_run_path(@payroll_run, bank: "generic_csv"),
            id: "download-link",
            class: "inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
        </svg>
        Generate & Download
      <% end %>
    </div>
  </div>

  <%= link_to "← Back to Payroll Run", admin_payroll_run_path(@payroll_run),
        class: "text-sm text-gray-500 hover:text-gray-700" %>
</div>

<script>
  function updateDownloadLink(bank) {
    const link = document.getElementById('download-link');
    const base = "<%= download_bank_file_admin_payroll_run_path(@payroll_run) %>";
    link.href = base + "?bank=" + bank;
  }
</script>
