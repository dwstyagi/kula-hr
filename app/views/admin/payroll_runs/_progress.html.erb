<div id="payroll_progress" class="space-y-4">
  <% if payroll_run.processing? %>
    <%# Live progress — Turbo Stream replaces this div each employee %>
    <%= turbo_stream_from "payroll_run_#{payroll_run.id}" %>

    <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-4">
      <div class="flex items-center justify-between text-sm">
        <span class="font-medium text-gray-700">Processing employees…</span>
        <span class="text-gray-500">
          <%= payroll_run.processed_employees %> / <%= payroll_run.total_employees %>
        </span>
      </div>

      <%# Progress bar %>
      <div class="w-full bg-gray-100 rounded-full h-3">
        <div class="bg-blue-600 h-3 rounded-full transition-all duration-300"
             style="width: <%= payroll_run.progress_percentage %>%"></div>
      </div>

      <p class="text-xs text-gray-400 text-center">
        This page updates automatically. You can leave and come back.
      </p>
    </div>

  <% elsif payroll_run.draft? %>
    <div class="bg-white rounded-xl border border-gray-200 p-6 text-center space-y-4">
      <p class="text-gray-600 text-sm">Ready to process payroll for <strong><%= payroll_run.period_label %></strong>.</p>
      <%= button_to process_payroll_admin_payroll_run_path(payroll_run),
            method: :post,
            class: "inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 cursor-pointer",
            form: { data: { turbo_confirm: "Start processing payroll for #{payroll_run.period_label}? This will run in the background." } } do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        Start Processing
      <% end %>
    </div>
  <% end %>
</div>
