<%# Step 2 — live processing region. PayrollProcessor broadcasts replacements
    of #payroll_progress over "payroll_run_<id>"; keep the id and stream name. %>
<div id="payroll_progress">
  <%= turbo_stream_from "payroll_run_#{payroll_run.id}" if payroll_run.processing? %>

  <% if payroll_run.processing? %>
    <div class="card card-pad space-y-5 animate-fade-up">
      <div class="flex items-center gap-3">
        <span class="relative flex size-9 items-center justify-center rounded-full bg-kula-50">
          <span class="absolute inline-flex size-5 rounded-full bg-kula-400 opacity-40 animate-ping" aria-hidden="true"></span>
          <svg class="relative size-5 text-kula-700 animate-spin" style="animation-duration: 1.6s" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/>
          </svg>
        </span>
        <div class="flex-1">
          <p class="text-sm font-semibold text-stone-900">Calculating salaries…</p>
          <p class="text-xs text-stone-500">PF, ESI, PT and TDS are computed per employee.</p>
        </div>
        <p class="text-sm font-semibold text-stone-700 amount">
          <%= payroll_run.processed_employees %><span class="text-stone-400 font-normal"> / <%= payroll_run.total_employees %></span>
        </p>
      </div>

      <div class="w-full bg-stone-100 rounded-full h-2.5 overflow-hidden">
        <div class="bg-kula-600 h-2.5 rounded-full transition-all duration-500 ease-out"
             style="width: <%= payroll_run.progress_percentage %>%"></div>
      </div>

      <p class="text-xs text-stone-400 text-center">This page updates live — you can leave and come back.</p>
    </div>

  <% elsif payroll_run.status.in?(%w[processed under_review approved rejected paid]) %>
    <%# Processing just finished while the user watched — advance the wizard. %>
    <div class="card card-pad text-center space-y-3 animate-scale-in">
      <span class="mx-auto flex size-12 items-center justify-center rounded-full bg-emerald-50">
        <svg class="size-6 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" class="draw-stroke"/>
        </svg>
      </span>
      <p class="text-sm font-semibold text-stone-900">Processing complete</p>
      <a href="<%= admin_payroll_run_path(payroll_run) %>" class="link text-sm">Review the results →</a>
    </div>
    <script>setTimeout(function () { window.Turbo && Turbo.visit(window.location.href, { action: "replace" }) }, 900)</script>
  <% end %>
</div>
