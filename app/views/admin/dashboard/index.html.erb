<% content_for(:page_title, "Admin Dashboard") %>
<div class="space-y-6">
  <!-- Stats Overview -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
    <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100 transition hover:shadow-md duration-300">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-500">Total Employees</p>
          <p class="mt-1 text-2xl font-bold text-gray-900"><%= @total_employees %></p>
        </div>
        <div class="p-3 bg-blue-50 rounded-full">
          <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
          </svg>
        </div>
      </div>
    </div>
    <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100 transition hover:shadow-md duration-300">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-500">Active Employees</p>
          <p class="mt-1 text-2xl font-bold text-green-600"><%= @active_employees %></p>
        </div>
        <div class="p-3 bg-green-50 rounded-full">
          <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
      </div>
    </div>
    <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100 transition hover:shadow-md duration-300">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-500">On Probation</p>
          <p class="mt-1 text-2xl font-bold text-yellow-600"><%= @probation_employees %></p>
        </div>
        <div class="p-3 bg-yellow-50 rounded-full">
          <svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
      </div>
    </div>
    <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100 transition hover:shadow-md duration-300">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-500">Resigned</p>
          <p class="mt-1 text-2xl font-bold text-red-600"><%= @resigned_employees %></p>
        </div>
        <div class="p-3 bg-red-50 rounded-full">
          <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7a4 4 0 11-8 0 4 4 0 018 0zM9 14a6 6 0 00-6 6v1h12v-1a6 6 0 00-6-6zM21 12h-6"></path>
          </svg>
        </div>
      </div>
    </div>
  </div>
  <!-- Payroll Summary -->
  <% if @payroll_data.current_run %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100 transition hover:shadow-md duration-300">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-500">Payroll Status</p>
            <p class="mt-1 text-2xl font-bold text-gray-900"><%= @payroll_data.current_run_status %></p>
            <p class="text-xs text-gray-400"><%= @payroll_data.current_run.period_label %></p>
          </div>
          <div class="p-3 bg-indigo-50 rounded-full">
            <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
          </div>
        </div>
      </div>
      <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100 transition hover:shadow-md duration-300">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-500">Net Pay</p>
            <p class="mt-1 text-2xl font-bold text-green-600">₹<%= number_with_delimiter(@payroll_data.current_run_net.round(0)) %></p>
          </div>
          <div class="p-3 bg-green-50 rounded-full">
            <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
        </div>
      </div>
      <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100 transition hover:shadow-md duration-300">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-500">CTC Cost</p>
            <p class="mt-1 text-2xl font-bold text-gray-900">₹<%= number_with_delimiter(@payroll_data.current_run_ctc.round(0)) %></p>
          </div>
          <div class="p-3 bg-purple-50 rounded-full">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
          </div>
        </div>
      </div>
      <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100 transition hover:shadow-md duration-300">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-500">Employees Processed</p>
            <p class="mt-1 text-2xl font-bold text-gray-900"><%= @payroll_data.current_run_employees %></p>
          </div>
          <div class="p-3 bg-amber-50 rounded-full">
            <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Payroll Trend & Recent Activity (side by side) -->
  <% if @payroll_data.payroll_trend.any? || @payroll_data.recent_activity.any? %>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <% if @payroll_data.payroll_trend.any? %>
        <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100">
          <h3 class="text-lg font-medium text-gray-900 mb-4">Payroll Trend (Last 6 Months)</h3>
          <%= line_chart [
                { name: "Gross", data: @payroll_data.payroll_trend.map { |t| [t[:label], t[:gross]] } },
                { name: "Net", data: @payroll_data.payroll_trend.map { |t| [t[:label], t[:net]] } },
                { name: "CTC", data: @payroll_data.payroll_trend.map { |t| [t[:label], t[:ctc]] } }
              ], height: "300px", prefix: "₹", thousands: ",", library: { tension: 0.4 } %>
        </div>
      <% end %>

      <% if @payroll_data.recent_activity.any? %>
        <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center">
            <h3 class="text-lg font-medium text-gray-900">Recent Payroll Activity</h3>
            <%= link_to "View All", admin_payroll_runs_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
          </div>
          <div class="divide-y divide-gray-100">
            <% status_colors = { "draft" => "bg-gray-100 text-gray-700", "processing" => "bg-blue-100 text-blue-700", "processed" => "bg-yellow-100 text-yellow-700", "under_review" => "bg-purple-100 text-purple-700", "approved" => "bg-green-100 text-green-700", "rejected" => "bg-red-100 text-red-700", "paid" => "bg-emerald-100 text-emerald-700" } %>
            <% @payroll_data.recent_activity.each do |activity| %>
              <div class="px-6 py-3 flex items-center justify-between">
                <div>
                  <p class="text-sm font-medium text-gray-900"><%= activity[:period] %></p>
                  <p class="text-xs text-gray-500">by <%= activity[:initiator] || "System" %> &middot; <%= time_ago_in_words(activity[:updated_at]) %> ago</p>
                </div>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= status_colors[activity[:status]] || 'bg-gray-100 text-gray-700' %>">
                  <%= activity[:status].titleize %>
                </span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Deduction Breakdown -->
  <% if @payroll_data.deduction_breakdown.any? %>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Deduction Breakdown (Current Month)</h3>
        <%= pie_chart @payroll_data.deduction_breakdown, height: "300px", prefix: "₹", thousands: ",", donut: true %>
      </div>
    </div>
  <% end %>

  <!-- Charts Section 1 -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Hiring Trend -->
    <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100">
      <h3 class="text-lg font-medium text-gray-900 mb-4">Hiring Trend (Last 6 Months)</h3>
      <%= line_chart @hiring_trend, height: "300px", colors: ["#3B82F6"], library: { tension: 0.4 } %>
    </div>
    <!-- Department Distribution -->
    <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100">
      <h3 class="text-lg font-medium text-gray-900 mb-4">Employees by Department</h3>
      <%= pie_chart @department_data, height: "300px", donut: true %>
    </div>
  </div>
  <!-- Charts Section 2 -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <!-- Employment Status -->
    <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100">
      <h3 class="text-lg font-medium text-gray-900 mb-4">Employment Status</h3>
      <%= pie_chart @status_data, height: "250px", legend: "bottom" %>
    </div>
    <!-- Gender Distribution -->
    <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100">
      <h3 class="text-lg font-medium text-gray-900 mb-4">Gender Distribution</h3>
      <%= pie_chart @gender_data, height: "250px", donut: true, legend: "bottom" %>
    </div>
    <!-- Average Tenure & Salary Range -->
    <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100 flex flex-col justify-between">
      <div>
        <h3 class="text-lg font-medium text-gray-900 mb-2">Average Tenure</h3>
        <p class="text-3xl font-bold text-gray-900"><%= number_with_precision(@avg_tenure, precision: 1) %> <span class="text-lg font-normal text-gray-500">Years</span></p>
      </div>
      <div class="mt-6">
        <h3 class="text-lg font-medium text-gray-900 mb-2">Salary Distribution</h3>
        <% if @salary_ranges.present? %>
          <%= bar_chart @salary_ranges, height: "150px", colors: ["#10B981"] %>
        <% else %>
          <p class="text-gray-500 text-sm">No salary data available</p>
        <% end %>
      </div>
    </div>
  </div>
  <!-- Detailed Lists -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Recent Hires -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center">
        <h3 class="text-lg font-medium text-gray-900">Recent Hires</h3>
        <%= link_to "View All", admin_employees_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
      </div>
      <div class="divide-y divide-gray-100">
        <% @recent_hires.each do |employee| %>
          <div class="px-6 py-4 flex items-center">
            <div class="shrink-0 h-10 w-10 rounded-full bg-gray-200 flex items-center justify-center text-gray-500 font-bold">
              <%= employee.first_name[0] %><%= employee.last_name[0] %>
            </div>
            <div class="ml-4">
              <div class="text-sm font-medium text-gray-900"><%= employee.full_name %></div>
              <div class="text-sm text-gray-500"><%= employee.designation&.name || 'No Designation' %> • <%= employee.department&.name || 'No Dept' %></div>
            </div>
            <div class="ml-auto text-sm text-gray-500">
              Joined <%= time_ago_in_words(employee.joining_date) %> ago
            </div>
          </div>
        <% end %>
        <% if @recent_hires.empty? %>
          <div class="px-6 py-4 text-gray-500 text-center">No recent hires found.</div>
        <% end %>
      </div>
    </div>
    <!-- Upcoming Anniversaries -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-linear-to-r from-purple-50 to-white">
        <h3 class="text-lg font-bold text-gray-800 flex items-center gap-2">
          <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          Upcoming Anniversaries
        </h3>
        <span class="text-xs font-semibold px-2 py-1 bg-purple-100 text-purple-700 rounded-full">Next 30 Days</span>
      </div>
      <div class="p-4 space-y-4">
        <% @upcoming_anniversaries.each do |employee| %>
          <% years = (Date.current.year - employee.joining_date.year) %>
          <% anniversary_date = Date.new(Date.current.year, employee.joining_date.month, employee.joining_date.day) %>
          <% # Handle edge case if anniversary is next year (in Jan) and we are in Dec %>
          <% anniversary_date = anniversary_date + 1.year if anniversary_date < Date.current %>
          <div class="flex items-center justify-between p-4 bg-white border border-gray-100 rounded-xl hover:shadow-md transition-all duration-200 group">
            <div class="flex items-center gap-4">
              <!-- Avatar / Initials -->
              <div class="relative">
                <div class="h-12 w-12 rounded-full bg-linear-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-white font-bold text-lg shadow-sm">
                  <%= employee.first_name[0] %><%= employee.last_name[0] %>
                </div>
                <div class="absolute -bottom-1 -right-1 bg-yellow-400 text-yellow-900 text-[10px] font-bold px-1.5 py-0.5 rounded-full border border-white shadow-sm">
                  <%= years %>y
                </div>
              </div>
              <div>
                <h4 class="text-sm font-bold text-gray-900 group-hover:text-purple-700 transition-colors">
                  <%= employee.full_name %>
                </h4>
                <div class="flex items-center gap-2 text-xs text-gray-500 mt-0.5">
                  <span class="bg-gray-100 px-1.5 py-0.5 rounded text-gray-600 font-medium"><%= employee.department&.name || 'Team' %></span>
                  <span>•</span>
                  <span><%= years.ordinalize %> Anniversary</span>
                </div>
              </div>
            </div>
            <div class="flex flex-col items-end gap-2">
              <div class="text-sm font-semibold text-gray-900 bg-gray-50 px-3 py-1 rounded-lg border border-gray-200 group-hover:border-purple-200 group-hover:bg-purple-50 transition-colors">
                <%= anniversary_date.strftime("%b %d") %>
              </div>
              <a href="mailto:<%= employee.email %>?subject=Happy Work Anniversary!&body=Hi <%= employee.first_name %>,%0D%0A%0D%0AWishing you a very happy <%= years.ordinalize %> work anniversary! Thank you for your contributions.%0D%0A%0D%0ABest,%0D%0A[Your Name]" 
                 class="text-xs font-medium text-purple-600 hover:text-purple-800 hover:underline flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                Send Wish
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </a>
            </div>
          </div>
        <% end %>
        <% if @upcoming_anniversaries.empty? %>
          <div class="flex flex-col items-center justify-center py-8 text-center text-gray-400">
            <svg class="w-12 h-12 mb-3 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            <p class="text-sm font-medium">No anniversaries in the next 30 days.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
