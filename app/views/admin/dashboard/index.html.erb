<% content_for(:page_title, "Dashboard") %>
<div class="space-y-6">

  <%# ── Setup checklist — shown until the tenant's first payroll run is approved/paid ── %>
  <% unless @first_payroll_done %>
    <% setup_steps = [
         { label: "Company account created", done: true },
         { label: "Admin account set up", done: true },
         { label: "Add your employees", done: @employees_added, cta: "Add employees", path: admin_employees_path },
         { label: "Assign salary structures", done: @salary_started, cta: "Assign salary", path: admin_employees_path },
         { label: "Lock attendance for the month", done: @attendance_locked_any, cta: "Attendance", path: admin_attendance_summaries_path },
         { label: "Run your first payroll", done: @first_payroll_done, cta: "Run payroll", path: new_admin_payroll_run_path }
       ] %>
    <% done_count = setup_steps.count { |s| s[:done] } %>
    <div class="card card-pad animate-fade-up">
      <div class="flex items-center justify-between mb-4 gap-4">
        <div>
          <h3 class="card-title">Get set up</h3>
          <p class="text-xs text-stone-500 mt-0.5">Finish these steps to run your first payroll.</p>
        </div>
        <span class="text-sm font-semibold text-kula-700 amount whitespace-nowrap"><%= done_count %> / <%= setup_steps.size %></span>
      </div>
      <div class="h-1.5 rounded-full bg-stone-100 overflow-hidden mb-5">
        <div class="h-full rounded-full bg-kula-600 transition-all" style="width: <%= (done_count.to_f / setup_steps.size * 100).round %>%"></div>
      </div>
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3" data-controller="reveal" data-reveal-delay-value="40">
        <% setup_steps.each_with_index do |step, i| %>
          <li class="flex items-center gap-3 px-4 py-3 rounded-lg <%= step[:done] ? "bg-emerald-50/60" : "bg-stone-50" %>">
            <% if step[:done] %>
              <span class="flex size-6 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-600">
                <svg class="size-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </span>
            <% else %>
              <span class="flex size-6 shrink-0 items-center justify-center rounded-full bg-white ring-1 ring-stone-300 text-[11px] font-semibold text-stone-400 amount"><%= i + 1 %></span>
            <% end %>
            <div class="min-w-0 flex-1">
              <p class="text-sm truncate <%= step[:done] ? "text-stone-500 line-through decoration-stone-300" : "text-stone-800 font-medium" %>"><%= step[:label] %></p>
            </div>
            <% if !step[:done] && step[:path] %>
              <%= link_to step[:cta], step[:path], class: "text-xs font-medium text-kula-700 hover:underline whitespace-nowrap" %>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# ── Row 1: pay-date hero + needs-attention queue ─────────────────────── %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <%# Hero — the one thing this product exists for %>
    <% run = @payroll_data.current_run %>
    <% pay_date = Date.current.end_of_month %>
    <% days_left = (pay_date - Date.current).to_i %>
    <div class="lg:col-span-2 card bg-kula-950 border-kula-900 text-white overflow-hidden relative animate-fade-up">
      <div class="absolute -top-16 -right-16 size-64 rounded-full bg-white/5 pointer-events-none" aria-hidden="true"></div>
      <div class="absolute -bottom-24 right-24 size-48 rounded-full bg-marigold-400/10 pointer-events-none" aria-hidden="true"></div>
      <div class="relative p-6 sm:p-8 flex flex-col gap-6 h-full">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <p class="text-[11px] font-semibold uppercase tracking-widest text-kula-300">Next pay date</p>
            <p class="text-3xl sm:text-4xl font-bold tracking-tight mt-2"><%= pay_date.strftime("%d %B") %></p>
            <p class="text-sm text-kula-200 mt-1">
              <% if days_left.zero? %>
                Today — make sure salaries go out.
              <% else %>
                in <span class="font-semibold text-white amount"><%= days_left %></span> day<%= "s" unless days_left == 1 %>
              <% end %>
            </p>
          </div>
          <% if run %>
            <span class="badge bg-white/10 ring-white/20 text-white">
              <%= run.period_label %> · <%= PayrollRunPresenter.new(run).status_badge_label %>
            </span>
          <% end %>
        </div>

        <div class="flex flex-wrap items-end justify-between gap-4 mt-auto">
          <div class="flex gap-8">
            <div>
              <p class="text-[11px] font-semibold uppercase tracking-widest text-kula-300">Net pay<%= " · #{run.period_label}" if run %></p>
              <p class="text-xl font-bold amount mt-1"
                 data-controller="countup"
                 data-countup-value-value="<%= @payroll_data.current_run_net.to_f.round %>"
                 data-countup-prefix-value="₹"><%= inr(@payroll_data.current_run_net) %></p>
            </div>
            <div class="hidden sm:block">
              <p class="text-[11px] font-semibold uppercase tracking-widest text-kula-300">Employees</p>
              <p class="text-xl font-bold amount mt-1"><%= @payroll_data.current_run_employees %></p>
            </div>
          </div>

          <% cta_path, cta_label = run.nil? || run.paid? ? [new_admin_payroll_run_path, "Start payroll run"] : [admin_payroll_run_path(run), "Continue payroll run"] %>
          <%= link_to cta_path, class: "btn btn-lg bg-marigold-400 text-kula-950 hover:bg-marigold-300 shadow-xs" do %>
            <%= cta_label %>
            <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          <% end %>
        </div>
      </div>
    </div>

    <%# Needs attention — the to-do queue %>
    <% oldest_days = @payroll_data.oldest_pending_leave_days.to_i %>
    <% attention_items = [
      { count: @payroll_data.pending_leave_count,
        text: "leave #{"request".pluralize(@payroll_data.pending_leave_count)} waiting" +
              (oldest_days.positive? ? " — oldest #{oldest_days} day#{"s" unless oldest_days == 1}" : ""),
        path: admin_leave_requests_path(status: "pending") },
      { count: @missing_bank_count,
        text: "#{"employee".pluralize(@missing_bank_count)} missing bank details",
        path: admin_employees_path },
      { count: @missing_salary_count,
        text: "#{"employee".pluralize(@missing_salary_count)} with no salary assigned",
        path: admin_employees_path },
      { count: @unlocked_attendance_count,
        text: "attendance #{"record".pluralize(@unlocked_attendance_count)} not locked for #{Date.current.strftime('%B')}",
        path: admin_attendance_summaries_path }
    ].select { |i| i[:count].positive? } %>

    <div class="card overflow-hidden animate-fade-up flex flex-col" style="animation-delay: 80ms">
      <div class="card-header py-3.5">
        <h3 class="card-title text-sm">Needs attention</h3>
        <% if attention_items.any? %>
          <span class="text-[10px] font-bold rounded-full bg-marigold-400 text-kula-950 px-2 py-0.5 amount"><%= attention_items.sum { |i| i[:count] } %></span>
        <% end %>
      </div>
      <% if attention_items.any? %>
        <ul class="divide-y divide-stone-100 flex-1" data-controller="reveal" data-reveal-delay-value="60">
          <% attention_items.each do |item| %>
            <li>
              <%= link_to item[:path], class: "flex items-center gap-3 px-5 py-3.5 hover:bg-stone-50 transition-colors group" do %>
                <span class="flex size-7 shrink-0 items-center justify-center rounded-full bg-marigold-50 text-marigold-700 text-xs font-bold amount"><%= item[:count] %></span>
                <p class="text-sm text-stone-700 flex-1"><%= item[:text] %></p>
                <svg class="size-4 text-stone-300 group-hover:text-stone-500 group-hover:translate-x-0.5 transition-all shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="empty-state flex-1">
          <span class="flex size-10 items-center justify-center rounded-full bg-emerald-50 mb-2">
            <svg class="size-5 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" class="draw-stroke"/></svg>
          </span>
          <p class="text-sm font-medium text-stone-700">All clear</p>
          <p class="text-xs text-stone-400 mt-0.5">Nothing needs your attention right now.</p>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Row 2: compact stat strip ─────────────────────────────────────────── %>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4" data-controller="reveal" data-reveal-delay-value="50">
    <div class="stat-card">
      <p class="stat-label">Headcount</p>
      <p class="stat-value" data-controller="countup" data-countup-value-value="<%= @total_employees %>"><%= @total_employees %></p>
    </div>
    <div class="stat-card">
      <p class="stat-label">Active</p>
      <p class="stat-value" data-controller="countup" data-countup-value-value="<%= @active_employees %>"><%= @active_employees %></p>
    </div>
    <div class="stat-card">
      <p class="stat-label">On probation</p>
      <p class="stat-value" data-controller="countup" data-countup-value-value="<%= @probation_employees %>"><%= @probation_employees %></p>
    </div>
    <div class="stat-card">
      <p class="stat-label">On leave today</p>
      <p class="stat-value" data-controller="countup" data-countup-value-value="<%= @on_leave_today %>"><%= @on_leave_today %></p>
    </div>
  </div>

  <%# ── Row 3: one chart + payroll activity ───────────────────────────────── %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="card card-pad animate-fade-up">
      <div class="flex items-center justify-between mb-4">
        <h3 class="card-title">Payroll cost <span class="text-stone-400 font-normal">· last 6 months</span></h3>
        <%= link_to "All reports →", admin_reports_path, class: "link text-sm" %>
      </div>
      <% if @payroll_data.payroll_trend.any? %>
        <%= line_chart [
              { name: "Gross", data: @payroll_data.payroll_trend.map { |t| [t[:label], t[:gross]] } },
              { name: "Net", data: @payroll_data.payroll_trend.map { |t| [t[:label], t[:net]] } }
            ], height: "260px", prefix: "₹", thousands: ",",
            colors: ["#276b50", "#e8a823"], library: { tension: 0.4 } %>
      <% else %>
        <div class="empty-state">
          <p class="text-sm text-stone-500">No approved payroll runs yet.</p>
          <p class="text-xs text-stone-400 mt-1">The cost trend appears after your first approved run.</p>
        </div>
      <% end %>
    </div>

    <div class="card overflow-hidden animate-fade-up" style="animation-delay: 60ms">
      <div class="card-header">
        <h3 class="card-title">Recent payroll activity</h3>
        <%= link_to "View all", admin_payroll_runs_path, class: "link text-sm" %>
      </div>
      <% if @payroll_data.recent_activity.any? %>
        <div class="divide-y divide-stone-100">
          <% @payroll_data.recent_activity.each do |activity| %>
            <div class="px-5 sm:px-6 py-3 flex items-center justify-between gap-3">
              <div class="min-w-0">
                <p class="text-sm font-medium text-stone-900"><%= activity[:period] %></p>
                <p class="text-xs text-stone-500">by <%= activity[:initiator] || "System" %> &middot; <%= time_ago_in_words(activity[:updated_at]) %> ago</p>
              </div>
              <%= status_badge activity[:status] %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="empty-state">
          <p class="text-sm text-stone-500">No payroll activity yet.</p>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Row 4: people moments ─────────────────────────────────────────────── %>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-controller="reveal" data-reveal-delay-value="70">
    <div class="card overflow-hidden">
      <div class="card-header py-3.5"><h3 class="card-title text-sm">Recent hires</h3></div>
      <% if @recent_hires.any? %>
        <ul class="divide-y divide-stone-100">
          <% @recent_hires.each do |emp| %>
            <li class="px-5 py-3 flex items-center gap-3">
              <%= avatar_chip(emp.full_name) %>
              <div class="min-w-0">
                <p class="text-sm font-medium text-stone-900 truncate"><%= emp.full_name %></p>
                <p class="text-xs text-stone-500">Joined <%= emp.joining_date.strftime("%d %b %Y") %></p>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="empty-state py-8"><p class="text-sm text-stone-400">No recent hires.</p></div>
      <% end %>
    </div>

    <div class="card overflow-hidden">
      <div class="card-header py-3.5"><h3 class="card-title text-sm">Birthdays <span class="text-stone-400 font-normal">· next 30 days</span></h3></div>
      <% if @upcoming_birthdays.any? %>
        <ul class="divide-y divide-stone-100">
          <% @upcoming_birthdays.each do |emp| %>
            <li class="px-5 py-3 flex items-center gap-3">
              <%= avatar_chip(emp.full_name) %>
              <div class="min-w-0">
                <p class="text-sm font-medium text-stone-900 truncate"><%= emp.full_name %></p>
                <p class="text-xs text-stone-500"><%= emp.date_of_birth.strftime("%d %B") %></p>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="empty-state py-8"><p class="text-sm text-stone-400">No birthdays coming up.</p></div>
      <% end %>
    </div>

    <div class="card overflow-hidden">
      <div class="card-header py-3.5"><h3 class="card-title text-sm">Work anniversaries</h3></div>
      <% if @upcoming_anniversaries.any? %>
        <ul class="divide-y divide-stone-100">
          <% @upcoming_anniversaries.each do |emp| %>
            <% years = Date.current.year - emp.joining_date.year %>
            <li class="px-5 py-3 flex items-center gap-3">
              <%= avatar_chip(emp.full_name) %>
              <div class="min-w-0">
                <p class="text-sm font-medium text-stone-900 truncate"><%= emp.full_name %></p>
                <p class="text-xs text-stone-500"><%= emp.joining_date.strftime("%d %B") %><%= " · #{years} #{"year".pluralize(years)}" if years.positive? %></p>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="empty-state py-8"><p class="text-sm text-stone-400">No anniversaries coming up.</p></div>
      <% end %>
    </div>
  </div>
</div>
