<div class="space-y-6">
  <%# Breadcrumb + header %>
  <div>
    <div class="flex items-center gap-2 text-sm text-stone-500 mb-1">
      <%= link_to "Payroll Runs", admin_payroll_runs_path, class: "hover:text-stone-700" %>
      <span>/</span>
      <%= link_to @payroll_run.period_label, admin_payroll_run_path(@payroll_run), class: "hover:text-stone-700" %>
      <span>/</span>
      <%= link_to "Payslips", admin_payroll_run_payslips_path(@payroll_run), class: "hover:text-stone-700" %>
      <span>/</span>
      <%= link_to @payslip.employee.full_name, admin_payslip_path(@payslip), class: "hover:text-stone-700" %>
      <span>/</span>
      <span class="text-stone-900">Edit</span>
    </div>
    <h1 class="page-title text-2xl">
      Edit Payslip — <%= @payslip.employee.full_name %>
    </h1>
    <p class="text-sm text-stone-500 mt-0.5">
      <%= @payslip.period_label %> &middot; <%= @payslip.employee.employee_code %>
    </p>
  </div>

  <%= form_with url: admin_payslip_path(@payslip), method: :patch do |f| %>
    <%# Flash error %>
    <% if flash[:alert].present? %>
      <div class="rounded-lg bg-red-50 border border-red-200 p-4 text-sm text-red-700">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <%# Earnings table %>
    <div class="card overflow-hidden">
      <div class="bg-green-50 border-b border-stone-200 px-4 py-3 flex items-center justify-between">
        <h2 class="text-sm font-semibold text-green-800">Earnings</h2>
      </div>
      <table class="w-full text-sm" id="earnings-table">
        <thead class="bg-stone-50 border-b border-stone-100">
          <tr>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 w-1/2">Component</th>
            <th class="px-4 py-2 text-right text-xs font-medium text-stone-500">Full Amount</th>
            <th class="px-4 py-2 text-right text-xs font-medium text-stone-500">Earned Amount</th>
            <th class="px-4 py-2 w-10"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-stone-50" id="earnings-body">
          <% @payslip.earnings.each do |item| %>
            <tr id="line-item-<%= item.id %>">
              <td class="px-4 py-2.5 text-stone-700"><%= item.component_name %></td>
              <td class="px-4 py-2.5 text-right text-stone-400 text-xs">
                <% if item.full_amount.present? %>
                  ₹<%= number_with_delimiter(item.full_amount.round(0)) %>
                <% else %>
                  —
                <% end %>
              </td>
              <td class="px-4 py-2.5 text-right">
                <div class="flex items-center justify-end gap-1">
                  <span class="text-stone-400">₹</span>
                  <input type="number" step="0.01" min="0"
                         name="line_items[<%= item.id %>][amount]"
                         value="<%= item.amount.round(2) %>"
                         class="w-32 text-right border border-stone-300 rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-kula-600 focus:border-kula-600">
                </div>
              </td>
              <td class="px-4 py-2.5 text-center">
                <% if item.category == "variable" %>
                  <label class="flex items-center justify-center cursor-pointer">
                    <input type="checkbox" name="remove_line_items[]" value="<%= item.id %>"
                           class="rounded border-stone-300 text-red-500 focus:ring-red-500">
                  </label>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <%# Add new earning row %>
      <div class="border-t border-dashed border-stone-200 p-4" id="new-earnings-section">
        <p class="text-xs text-stone-400 mb-3 uppercase tracking-wide">Add Earning</p>
        <div class="flex items-center gap-2">
          <input type="text" name="new_line_items[earning_1][component_name]"
                 placeholder="Component name"
                 class="flex-1 border border-stone-300 rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-kula-600 focus:border-kula-600">
          <input type="hidden" name="new_line_items[earning_1][component_type]" value="earning">
          <div class="flex items-center gap-1">
            <span class="text-stone-400 text-sm">₹</span>
            <input type="number" step="0.01" min="0" name="new_line_items[earning_1][amount]"
                   placeholder="0.00"
                   class="w-32 text-right border border-stone-300 rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-kula-600 focus:border-kula-600">
          </div>
        </div>
      </div>
    </div>

    <%# Deductions table %>
    <div class="card overflow-hidden">
      <div class="bg-red-50 border-b border-stone-200 px-4 py-3">
        <h2 class="text-sm font-semibold text-red-800">Deductions</h2>
      </div>
      <table class="w-full text-sm">
        <thead class="bg-stone-50 border-b border-stone-100">
          <tr>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 w-1/2">Component</th>
            <th class="px-4 py-2 text-right text-xs font-medium text-stone-500">Amount</th>
            <th class="px-4 py-2 w-10"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-stone-50">
          <% @payslip.deductions.each do |item| %>
            <tr id="line-item-<%= item.id %>">
              <td class="px-4 py-2.5 text-stone-700"><%= item.component_name %></td>
              <td class="px-4 py-2.5 text-right">
                <div class="flex items-center justify-end gap-1">
                  <span class="text-stone-400">₹</span>
                  <input type="number" step="0.01" min="0"
                         name="line_items[<%= item.id %>][amount]"
                         value="<%= item.amount.round(2) %>"
                         class="w-32 text-right border border-stone-300 rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-kula-600 focus:border-kula-600">
                </div>
              </td>
              <td class="px-4 py-2.5 text-center">
                <% if item.category == "variable" %>
                  <label class="flex items-center justify-center cursor-pointer">
                    <input type="checkbox" name="remove_line_items[]" value="<%= item.id %>"
                           class="rounded border-stone-300 text-red-500 focus:ring-red-500">
                  </label>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <%# Add new deduction row %>
      <div class="border-t border-dashed border-stone-200 p-4">
        <p class="text-xs text-stone-400 mb-3 uppercase tracking-wide">Add Deduction</p>
        <div class="flex items-center gap-2">
          <input type="text" name="new_line_items[deduction_1][component_name]"
                 placeholder="Component name"
                 class="flex-1 border border-stone-300 rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-kula-600 focus:border-kula-600">
          <input type="hidden" name="new_line_items[deduction_1][component_type]" value="deduction">
          <div class="flex items-center gap-1">
            <span class="text-stone-400 text-sm">₹</span>
            <input type="number" step="0.01" min="0" name="new_line_items[deduction_1][amount]"
                   placeholder="0.00"
                   class="w-32 text-right border border-stone-300 rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-kula-600 focus:border-kula-600">
          </div>
        </div>
      </div>
    </div>

    <%# Revision notes %>
    <div class="card p-4">
      <label class="label">Revision Notes</label>
      <textarea name="revision_notes" rows="3"
                placeholder="Describe why this payslip was revised…"
                class="w-full border border-stone-300 rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-kula-600 focus:border-kula-600"><%= @payslip.revision_notes %></textarea>
    </div>

    <%# Actions %>
    <div class="flex items-center gap-3">
      <%= f.submit "Save Changes",
            class: "px-5 py-2 bg-kula-700 text-white text-sm font-medium rounded-lg hover:bg-kula-800 cursor-pointer" %>
      <%= link_to "Cancel", admin_payslip_path(@payslip),
            class: "px-5 py-2 bg-white border border-stone-300 text-stone-700 text-sm font-medium rounded-lg hover:bg-stone-50" %>
    </div>
  <% end %>
</div>
