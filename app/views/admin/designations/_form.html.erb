<%= form_with model: designation, url: url, method: local_assigns[:method] || :post,
    data: (designation.persisted? ? {} : { turbo_frame: "_top" }),
    class: "flex items-end gap-4" do |f| %>
  <div class="flex-1">
    <%= f.label :name, class: "label" %>
    <%= f.text_field :name, class: "input", autofocus: true, placeholder: "Designation name" %>
    <% if designation.errors[:name].any? %>
      <p class="mt-1 text-sm text-red-600"><%= designation.errors[:name].first %></p>
    <% end %>
  </div>
  <div class="flex gap-2">
    <%= f.submit designation.persisted? ? "Update" : "Create", class: "px-4 py-3 bg-kula-700 text-white text-sm font-medium rounded-lg hover:bg-kula-800 cursor-pointer" %>
    <%= link_to "Cancel", admin_designations_path, class: "px-4 py-3 bg-stone-100 text-stone-700 text-sm font-medium rounded-lg hover:bg-stone-200" %>
  </div>
<% end %>
