<%= form_with model: holiday, url: url, method: local_assigns.fetch(:method, :post), class: "space-y-4" do |f| %>
  <% if holiday.errors.any? %>
    <div class="rounded-lg bg-red-50 p-4">
      <ul class="text-sm text-red-700 list-disc list-inside space-y-1">
        <% holiday.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= f.label :name, class: "label" %>
      <%= f.text_field :name,
          class: "input",
          autofocus: true,
          placeholder: "e.g. Republic Day" %>
    </div>

    <div>
      <%= f.label :date, class: "label" %>
      <%= f.date_field :date,
          class: "input" %>
    </div>
  </div>

  <% locations = WorkLocation.active.order(:name) %>
  <% if locations.any? %>
    <div>
      <%= f.label :work_location_id, "Work location", class: "label" %>
      <%= f.collection_select :work_location_id, locations, :id, :name,
          { include_blank: "Company-wide (all locations)" },
          class: "select" %>
      <p class="text-xs text-stone-500 mt-1">Leave blank for a holiday that applies to every location.</p>
    </div>
  <% end %>

  <div>
    <label class="flex items-center gap-2 cursor-pointer">
      <%= f.check_box :is_active, class: "rounded border-stone-300 text-kula-700 shadow-sm focus:ring-kula-600" %>
      <span class="text-sm text-stone-700">Active</span>
    </label>
  </div>

  <div class="flex items-center gap-3 pt-1">
    <%= f.submit holiday.persisted? ? "Update Holiday" : "Create Holiday",
        class: "btn btn-primary cursor-pointer" %>
    <%= link_to "Cancel", admin_holidays_path,
        class: "btn btn-ghost" %>
  </div>
<% end %>
