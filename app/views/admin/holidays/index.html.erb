<div class="max-w-4xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="page-title text-2xl">Public Holidays</h1>
      <p class="text-sm text-stone-500 mt-1">Define company holidays. These are excluded from leave day calculations.</p>
    </div>
    <div class="flex items-center gap-2">
      <%= form_with url: admin_holidays_path, method: :get do |f| %>
        <%= f.select :per_page,
              options_for_select(Admin::HolidaysController::PER_PAGE_OPTIONS.map { |n| [ "#{n} / page", n ] }, @per_page),
              {},
              class: "select w-28",
              aria: { label: "Holidays per page" },
              onchange: "this.form.requestSubmit()" %>
      <% end %>
      <%= button_to add_standard_presets_admin_holidays_path(year: Date.today.year),
          method: :post,
          class: "btn btn-secondary cursor-pointer" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        Add standard <%= Date.today.year %> holidays
      <% end %>
      <%= link_to new_admin_holiday_path,
          class: "btn btn-primary",
          data: { turbo_frame: "holiday_form" } do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Add Holiday
      <% end %>
    </div>
  </div>

  <%= turbo_frame_tag "holiday_form" %>

  <div class="card overflow-hidden">
    <% if @holidays.any? %>
      <div class="overflow-x-auto">
        <table class="tbl">
          <thead>
            <tr>
              <th>Name</th>
              <th>Date</th>
              <th>Day</th>
              <th>Location</th>
              <th>Status</th>
              <th class="text-right">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @holidays.each do |holiday| %>
              <tr class="hover:bg-stone-50 <%= 'opacity-50' unless holiday.is_active? %>">
                  <td class="text-sm font-medium text-stone-900"><%= holiday.name %></td>
                  <td class="text-sm text-stone-700"><%= holiday.date.strftime("%d %b %Y") %></td>
                  <td class="text-sm text-stone-500"><%= holiday.date.strftime("%A") %></td>
                  <td class="text-sm text-stone-500"><%= holiday.work_location&.name || "Company-wide" %></td>
                  <td>
                    <% if holiday.is_active? %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-700">Active</span>
                    <% else %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-stone-100 text-stone-500">Inactive</span>
                    <% end %>
                  </td>
                  <td class="text-right">
                    <div class="flex items-center justify-end gap-2">
                      <%= button_to toggle_active_admin_holiday_path(holiday),
                          method: :patch,
                          title: holiday.is_active? ? "Deactivate" : "Activate",
                          class: "p-1.5 rounded-md transition-colors cursor-pointer #{holiday.is_active? ? 'text-amber-600 hover:bg-amber-100' : 'text-emerald-600 hover:bg-emerald-100'}" do %>
                        <% if holiday.is_active? %>
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                          </svg>
                        <% else %>
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                          </svg>
                        <% end %>
                      <% end %>

                      <%= link_to edit_admin_holiday_path(holiday),
                          title: "Edit",
                          class: "p-1.5 rounded-md text-kula-700 hover:bg-kula-100 transition-colors cursor-pointer",
                          data: { turbo_frame: "holiday_form" } do %>
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                        </svg>
                      <% end %>

                      <%= button_to admin_holiday_path(holiday),
                          method: :delete,
                          title: "Delete",
                          class: "p-1.5 rounded-md text-red-600 hover:bg-red-100 transition-colors cursor-pointer",
                          form: { data: { turbo_confirm: "Delete '#{holiday.name}'? This cannot be undone." } } do %>
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                        </svg>
                      <% end %>
                    </div>
                  </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <% if @pagy.pages > 1 %>
        <div class="px-6 py-3 border-t border-stone-200 flex items-center justify-between gap-4">
          <p class="text-xs text-stone-500">
            Showing <span class="amount"><%= @pagy.from %>–<%= @pagy.to %></span>
            of <span class="amount"><%= @pagy.count %></span> holidays
          </p>
          <%= render "shared/pagy_nav", pagy: @pagy %>
        </div>
      <% end %>
    <% else %>
      <div class="p-12 text-center">
        <svg class="mx-auto h-10 w-10 text-stone-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5"/>
        </svg>
        <p class="text-sm text-stone-500">No holidays configured yet. Add holidays to exclude them from leave calculations.</p>
      </div>
    <% end %>
  </div>
</div>
