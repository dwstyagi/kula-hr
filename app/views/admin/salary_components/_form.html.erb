<%= form_with model: salary_component, url: url, method: local_assigns[:method] || :post, class: "space-y-4" do |f| %>
  <% if salary_component.errors.any? %>
    <div class="rounded-lg bg-red-50 p-4">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
        </svg>
        <div class="ml-3">
          <ul class="text-sm text-red-700 list-disc list-inside">
            <% salary_component.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= f.label :name, class: "label" %>
      <%= f.text_field :name, class: "input", autofocus: true, placeholder: "e.g. Performance Bonus" %>
    </div>

    <div>
      <%= f.label :component_type, "Type", class: "label" %>
      <%= f.select :component_type,
          SalaryComponent.component_types.keys.map { |t| [t.titleize, t] },
          { include_blank: "Select type" },
          class: "select" %>
    </div>

    <div>
      <%= f.label :calculation_type, "Calculation", class: "label" %>
      <%= f.select :calculation_type,
          SalaryComponent.calculation_types.keys.map { |t| [t.capitalize, t] },
          { include_blank: "Select calculation type" },
          class: "select" %>
    </div>

    <div>
      <%= f.label :sort_order, "Display Order", class: "label" %>
      <%= f.number_field :sort_order, class: "input", placeholder: "0" %>
    </div>
  </div>

  <div class="flex items-center gap-6">
    <label class="flex items-center gap-2 cursor-pointer">
      <%= f.check_box :taxable, class: "rounded border-stone-300 text-kula-700 shadow-sm focus:ring-kula-600" %>
      <span class="text-sm text-stone-700">Taxable</span>
    </label>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit salary_component.persisted? ? "Update Component" : "Create Component",
        class: "btn btn-primary cursor-pointer" %>
    <%= link_to "Cancel", admin_salary_components_path,
        class: "btn btn-ghost" %>
  </div>
<% end %>
