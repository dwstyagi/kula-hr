<%= form_with model: salary_component, url: url, method: local_assigns[:method] || :post, class: "space-y-4" do |f| %>
  <% if salary_component.errors.any? %>
    <div class="rounded-lg bg-red-50 p-4">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
        </svg>
        <div class="ml-3">
          <ul class="text-sm text-red-700 list-disc list-inside">
            <% salary_component.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, class: "w-full rounded-lg border-gray-300 px-4 py-3 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm", autofocus: true, placeholder: "e.g. Performance Bonus" %>
    </div>

    <div>
      <%= f.label :component_type, "Type", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :component_type,
          SalaryComponent.component_types.keys.map { |t| [t.titleize, t] },
          { include_blank: "Select type" },
          class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm" %>
    </div>

    <div>
      <%= f.label :calculation_type, "Calculation", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :calculation_type,
          SalaryComponent.calculation_types.keys.map { |t| [t.capitalize, t] },
          { include_blank: "Select calculation type" },
          class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm" %>
    </div>

    <div>
      <%= f.label :sort_order, "Display Order", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :sort_order, class: "w-full rounded-lg border-gray-300 px-4 py-3 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm", placeholder: "0" %>
    </div>
  </div>

  <div class="flex items-center gap-6">
    <label class="flex items-center gap-2 cursor-pointer">
      <%= f.check_box :taxable, class: "rounded border-gray-300 text-blue-600 shadow-sm focus:ring-blue-500" %>
      <span class="text-sm text-gray-700">Taxable</span>
    </label>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit salary_component.persisted? ? "Update Component" : "Create Component",
        class: "px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 cursor-pointer" %>
    <%= link_to "Cancel", admin_salary_components_path,
        class: "px-4 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-200" %>
  </div>
<% end %>
