<div class="mb-6">
  <div class="flex items-center gap-2 mb-3">
    <% dot_color = { "green" => "bg-green-500", "red" => "bg-red-500", "blue" => "bg-blue-500" }[color] %>
    <span class="h-2.5 w-2.5 rounded-full <%= dot_color %>"></span>
    <h2 class="text-lg font-semibold text-gray-900"><%= title %></h2>
    <span class="text-xs text-gray-400 ml-1">(<%= components.size %>)</span>
  </div>
  <p class="text-sm text-gray-500 mb-3"><%= description %></p>

  <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
    <% if components.any? %>
      <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Calculation</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Taxable</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Order</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% components.each do |component| %>
            <%= turbo_frame_tag component do %>
              <tr class="hover:bg-gray-50 <%= 'opacity-50' unless component.active? %>">
                <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= component.name %></td>
                <td class="px-6 py-4">
                  <% calc_styles = { "flat" => "bg-gray-100 text-gray-700", "percentage" => "bg-indigo-100 text-indigo-700" } %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= calc_styles[component.calculation_type] %>">
                    <%= component.calculation_type.capitalize %>
                  </span>
                </td>
                <td class="px-6 py-4 text-sm text-gray-500">
                  <% if component.taxable? %>
                    <span class="text-amber-600">Yes</span>
                  <% else %>
                    <span class="text-gray-400">No</span>
                  <% end %>
                </td>
                <td class="px-6 py-4">
                  <% if component.active? %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-700">Active</span>
                  <% else %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-500">Inactive</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 text-sm text-gray-500 font-mono"><%= component.sort_order %></td>
                <td class="px-6 py-4 text-right">
                  <div class="flex items-center justify-end gap-2">
                    <%= button_to toggle_active_admin_salary_component_path(component),
                        method: :patch,
                        title: component.active? ? "Deactivate" : "Activate",
                        class: "p-1 rounded-md transition-colors cursor-pointer #{component.active? ? 'text-amber-600 hover:bg-amber-200' : 'text-emerald-600 hover:bg-emerald-200'}" do %>
                      <% if component.active? %>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M14.25 9v6m-4.5 0V9M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                        </svg>
                      <% else %>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-10.5-3.906c0-.762.83-1.23 1.47-.843l6.807 4.097c.656.395.656 1.347 0 1.742l-6.807 4.097c-.64.386-1.47-.082-1.47-.844V8.094Z" />
                        </svg>
                      <% end %>
                    <% end %>

                    <%= link_to edit_admin_salary_component_path(component),
                        title: "Edit",
                        class: "p-1 rounded-md text-blue-600 hover:bg-blue-200 transition-colors cursor-pointer",
                        data: { turbo_frame: dom_id(component) } do %>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                      </svg>
                    <% end %>

                    <%= button_to admin_salary_component_path(component),
                        method: :delete,
                        title: "Delete",
                        class: "p-1 rounded-md text-red-600 hover:bg-red-200 transition-colors cursor-pointer",
                        form: { data: { turbo_confirm: "Delete '#{component.name}'?" } } do %>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                      </svg>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
      </div>
    <% else %>
      <div class="p-8 text-center">
        <p class="text-sm text-gray-500">No <%= title.downcase %> configured.</p>
      </div>
    <% end %>
  </div>
</div>
