<% content_for :page_title, "Leave Requests" %>

<div class="max-w-6xl mx-auto" data-controller="drawer bulk">
  <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
    <div>
      <h1 class="page-title text-2xl">Leave requests</h1>
      <p class="page-sub">Click a request for details; select rows to approve in bulk.</p>
    </div>

    <%# Status filter tabs with live counts %>
    <div class="flex items-center gap-1 bg-stone-100 rounded-lg p-1">
      <% [["All", ""], ["Pending", "pending"], ["Approved", "approved"], ["Rejected", "rejected"], ["Cancelled", "cancelled"]].each do |label, value| %>
        <% count = value.blank? ? @status_counts.values.sum : @status_counts.fetch(value, 0) %>
        <%= link_to admin_leave_requests_path(status: value.presence),
            class: "px-3 py-1.5 text-sm font-medium rounded-md transition-colors flex items-center gap-1.5 #{params[:status].to_s == value ? 'bg-white text-stone-900 shadow-sm' : 'text-stone-500 hover:text-stone-900'}" do %>
          <%= label %>
          <% if value == "pending" && count.positive? %>
            <span class="text-[10px] font-bold rounded-full bg-marigold-400 text-kula-950 px-1.5 py-px amount"><%= count %></span>
          <% elsif count.positive? %>
            <span class="text-[10px] text-stone-400 amount"><%= count %></span>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>

  <%= form_with url: bulk_approve_admin_leave_requests_path(status: params[:status].presence),
        method: :patch, data: { turbo_confirm: "Approve all selected leave requests?" } do %>
    <div class="card overflow-hidden">
      <% if @leave_requests.any? %>
        <div class="overflow-x-auto">
          <table class="tbl">
            <thead>
              <tr>
                <th class="w-10">
                  <input type="checkbox" class="checkbox cursor-pointer" aria-label="Select all pending"
                         data-bulk-target="all" data-action="bulk#toggleAll">
                </th>
                <th>Employee</th>
                <th>Type</th>
                <th>Dates</th>
                <th class="text-right">Days</th>
                <th>Status</th>
                <th>Approver</th>
                <th class="w-8"><span class="sr-only">Open</span></th>
              </tr>
            </thead>
            <tbody data-controller="reveal" data-reveal-delay-value="30">
              <% @leave_requests.each do |lr| %>
                <tr id="<%= dom_id(lr) %>" class="cursor-pointer"
                    data-action="click->drawer#open"
                    data-drawer-url-param="<%= admin_leave_request_path(lr) %>">
                  <td onclick="event.stopPropagation()">
                    <% if lr.pending? && lr.employee.hr_is_approver? %>
                      <input type="checkbox" name="ids[]" value="<%= lr.id %>" aria-label="Select <%= lr.employee.full_name %>"
                             class="checkbox cursor-pointer" data-bulk-target="item" data-action="bulk#refresh">
                    <% end %>
                  </td>
                  <td>
                    <div class="flex items-center gap-3">
                      <%= avatar_chip(lr.employee.full_name) %>
                      <div class="min-w-0">
                        <p class="text-sm font-medium text-stone-900 truncate"><%= lr.employee.full_name %></p>
                        <p class="code text-xs"><%= lr.employee.employee_code %></p>
                      </div>
                    </div>
                  </td>
                  <td>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-kula-100 text-kula-800"><%= lr.leave_type.code %></span>
                  </td>
                  <td class="text-sm text-stone-700 whitespace-nowrap">
                    <%= lr.from_date.strftime("%d %b") %><% if lr.from_date != lr.to_date %> – <%= lr.to_date.strftime("%d %b %Y") %><% else %><%= lr.from_date.strftime(", %Y") %><% end %>
                  </td>
                  <td class="num text-sm font-semibold text-stone-900"><%= lr.number_of_days.to_i %></td>
                  <td><%= status_badge(lr.status) %></td>
                  <td class="text-xs text-stone-500 whitespace-nowrap">
                    <% mgr = lr.employee.reporting_manager %>
                    <% if mgr&.user.present? %>
                      <%= mgr.full_name %>
                    <% else %>
                      HR admin
                    <% end %>
                  </td>
                  <td class="text-stone-300">
                    <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <% if @pagy.pages > 1 %>
          <div class="px-6 py-3 border-t border-stone-200 flex justify-center">
            <%= render "shared/pagy_nav", pagy: @pagy %>
          </div>
        <% end %>
      <% else %>
        <div class="empty-state">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5"/>
          </svg>
          <p class="text-sm text-stone-500">No <%= params[:status].presence %> leave requests found.</p>
        </div>
      <% end %>
    </div>

    <%# Floating bulk-action bar — appears when rows are selected %>
    <div class="hidden sticky bottom-4 z-30 mt-4" data-bulk-target="bar">
      <div class="card bg-kula-950 text-white shadow-lg px-5 py-3 flex items-center justify-between gap-4 animate-slide-up border-kula-900">
        <p class="text-sm">
          <span class="font-bold amount" data-bulk-target="count">0</span>
          <span class="text-kula-200">selected</span>
        </p>
        <button type="submit" class="btn bg-marigold-400 text-kula-950 hover:bg-marigold-300 cursor-pointer" data-bulk-target="submit" disabled>
          <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
          Approve selected
        </button>
      </div>
    </div>
  <% end %>

  <%# Slide-over detail drawer %>
  <div class="drawer-backdrop opacity-0 pointer-events-none" data-drawer-target="backdrop" data-action="click->drawer#close" aria-hidden="true"></div>
  <aside class="drawer-panel translate-x-full" data-drawer-target="panel" role="dialog" aria-label="Leave request details">
    <%= turbo_frame_tag "drawer", class: "flex flex-col h-full", data: { drawer_target: "frame" } %>
  </aside>
</div>
