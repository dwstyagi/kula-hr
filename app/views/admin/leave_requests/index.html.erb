<div class="max-w-6xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Leave Requests</h1>
      <p class="text-sm text-gray-500 mt-1">Review and manage employee leave requests.</p>
    </div>

    <%# Status filter tabs %>
    <div class="flex items-center gap-1 bg-gray-100 rounded-lg p-1">
      <% [["All", ""], ["Pending", "pending"], ["Approved", "approved"], ["Rejected", "rejected"], ["Cancelled", "cancelled"]].each do |label, value| %>
        <%= link_to label,
            admin_leave_requests_path(status: value.presence),
            class: "px-3 py-1.5 text-sm font-medium rounded-md transition-colors #{params[:status].to_s == value ? 'bg-white text-gray-900 shadow-sm' : 'text-gray-500 hover:text-gray-900'}" %>
      <% end %>
    </div>
  </div>

  <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
    <% if @leave_requests.any? %>
      <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Employee</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Dates</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Days</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Reason</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Approver</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @leave_requests.each do |lr| %>
            <tr class="hover:bg-gray-50" id="<%= dom_id(lr) %>">
              <td class="px-6 py-4">
                <p class="text-sm font-medium text-gray-900"><%= lr.employee.full_name %></p>
                <p class="text-xs text-gray-400"><%= lr.employee.employee_code %></p>
              </td>
              <td class="px-6 py-4">
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-700">
                  <%= lr.leave_type.code %>
                </span>
                <p class="text-xs text-gray-400 mt-0.5"><%= lr.leave_type.name %></p>
              </td>
              <td class="px-6 py-4 text-sm text-gray-700">
                <%= lr.from_date.strftime("%d %b") %>
                <% if lr.from_date != lr.to_date %>
                  – <%= lr.to_date.strftime("%d %b %Y") %>
                <% else %>
                  <%= lr.from_date.strftime(", %Y") %>
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= lr.number_of_days.to_i %></td>
              <td class="px-6 py-4 text-sm text-gray-500 max-w-xs truncate"><%= lr.reason.presence || "—" %></td>
              <td class="px-6 py-4">
                <% badge = {
                  "pending"   => "bg-yellow-100 text-yellow-700",
                  "approved"  => "bg-green-100 text-green-700",
                  "rejected"  => "bg-red-100 text-red-700",
                  "cancelled" => "bg-gray-100 text-gray-500"
                } %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= badge[lr.status] %>">
                  <%= lr.status.titleize %>
                </span>
                <% if lr.rejected? && lr.rejection_reason.present? %>
                  <p class="text-xs text-red-400 mt-0.5 truncate max-w-[140px]" title="<%= lr.rejection_reason %>">
                    <%= lr.rejection_reason %>
                  </p>
                <% end %>
              </td>
              <td class="px-6 py-4 text-xs text-gray-500">
                <% mgr = lr.employee.reporting_manager %>
                <% if mgr&.user.present? %>
                  <p class="font-medium text-gray-700"><%= mgr.full_name %></p>
                  <p class="text-gray-400">Manager</p>
                <% else %>
                  <span class="text-gray-400">HR Admin</span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-right">
                <div class="flex items-center justify-end gap-2">
                  <% if lr.pending? %>
                    <%# Approve %>
                    <%= button_to approve_admin_leave_request_path(lr),
                        method: :patch,
                        title: "Approve",
                        class: "p-1.5 rounded-md bg-green-50 text-green-600 hover:bg-green-100 transition-colors cursor-pointer" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                      </svg>
                    <% end %>

                    <%# Reject — opens modal rendered outside the table %>
                    <button type="button"
                        title="Reject"
                        data-action="click->modal#open"
                        data-modal-id="reject-modal-<%= lr.id %>"
                        onclick="document.getElementById('reject-modal-<%= lr.id %>').querySelector('[data-modal-target=dialog]').classList.remove('hidden')"
                        class="p-1.5 rounded-md bg-red-50 text-red-600 hover:bg-red-100 transition-colors cursor-pointer">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                      </svg>
                    </button>
                  <% end %>

                  <% if lr.pending? || lr.approved? %>
                    <%# Cancel %>
                    <%= button_to cancel_admin_leave_request_path(lr),
                        method: :patch,
                        title: "Cancel",
                        class: "p-1.5 rounded-md text-gray-400 hover:bg-gray-100 transition-colors cursor-pointer",
                        form: { data: { turbo_confirm: "Cancel this leave request?" } } do %>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 0 0 5.636 5.636m12.728 12.728A9 9 0 0 1 5.636 5.636m12.728 12.728L5.636 5.636" />
                      </svg>
                    <% end %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      </div>

      <%# Pagination %>
      <% if @pagy.pages > 1 %>
        <div class="px-6 py-4 border-t border-gray-100">
          <%== pagy_nav(@pagy) %>
        </div>
      <% end %>

    <% else %>
      <div class="p-12 text-center">
        <svg class="mx-auto h-10 w-10 text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5"/>
        </svg>
        <p class="text-sm text-gray-500">
          No <%= params[:status].present? ? params[:status] : "" %> leave requests found.
        </p>
      </div>
    <% end %>
  </div>

  <%# Reject modals — rendered outside the table to produce valid HTML %>
  <% @leave_requests.select(&:pending?).each do |lr| %>
    <div id="reject-modal-<%= lr.id %>" data-controller="modal">
      <div data-modal-target="dialog"
           class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50"
           data-action="click->modal#closeOnBackdrop">
        <div class="bg-white rounded-xl shadow-xl w-full max-w-md p-6" onclick="event.stopPropagation()">
          <h3 class="text-base font-semibold text-gray-900 mb-1">Reject Leave Request</h3>
          <p class="text-sm text-gray-500 mb-4">
            <%= lr.employee.full_name %> &middot;
            <%= lr.leave_type.name %> &middot;
            <%= lr.from_date.strftime("%d %b") %>–<%= lr.to_date.strftime("%d %b %Y") %>
            (<%= lr.number_of_days.to_i %> days)
          </p>
          <%= form_with url: reject_admin_leave_request_path(lr), method: :patch do |f| %>
            <div class="mb-4">
              <%= f.label :rejection_reason, "Reason for rejection", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_area :rejection_reason,
                  rows: 3,
                  class: "w-full rounded-lg border-gray-300 px-4 py-3 shadow-sm focus:border-red-400 focus:ring-red-400 text-sm",
                  placeholder: "Enter reason (optional)" %>
            </div>
            <div class="flex justify-end gap-3">
              <button type="button" data-action="modal#close"
                  class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200">
                Cancel
              </button>
              <%= f.submit "Confirm Rejection",
                  class: "px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 cursor-pointer" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
