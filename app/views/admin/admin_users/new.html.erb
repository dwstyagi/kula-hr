<div class="max-w-xl mx-auto">
  <div class="mb-6">
    <h1 class="page-title text-2xl">Invite Admin</h1>
    <p class="text-sm text-stone-500 mt-1">They will receive an email invitation to set up their account.</p>
  </div>

  <div class="card card-pad">
    <%= form_with url: admin_admin_users_path, method: :post do |f| %>
      <% if flash[:alert] %>
        <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <div class="space-y-5">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="label">First Name</label>
            <%= f.text_field :first_name, name: "user[first_name]",
                value: @user.first_name,
                class: "w-full border border-stone-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-kula-600 focus:border-transparent",
                placeholder: "Jane",
                required: true %>
          </div>
          <div>
            <label class="label">Last Name</label>
            <%= f.text_field :last_name, name: "user[last_name]",
                value: @user.last_name,
                class: "w-full border border-stone-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-kula-600 focus:border-transparent",
                placeholder: "Smith",
                required: true %>
          </div>
        </div>

        <div>
          <label class="label">Work Email</label>
          <%= f.email_field :email, name: "user[email]",
              value: @user.email,
              class: "w-full border border-stone-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-kula-600 focus:border-transparent",
              placeholder: "jane@company.com",
              required: true %>
        </div>

        <div>
          <label class="label">Role</label>
          <div class="px-3 py-2 bg-stone-50 border border-stone-200 rounded-lg text-sm text-stone-600 flex items-center gap-2">
            <span class="badge bg-kula-100 text-kula-900">HR Admin</span>
            <span class="text-stone-400">— can access all HR admin features</span>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-3 mt-6">
        <%= f.submit "Send Invitation",
            class: "px-5 py-2 bg-kula-700 text-white text-sm font-medium rounded-lg hover:bg-kula-800 cursor-pointer" %>
        <%= link_to "Cancel", admin_admin_users_path,
            class: "px-5 py-2 bg-stone-100 text-stone-700 text-sm font-medium rounded-lg hover:bg-stone-200" %>
      </div>
    <% end %>
  </div>
</div>
