<div class="max-w-4xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Admin Users</h1>
      <p class="text-sm text-gray-500 mt-1">Manage who has access to the admin dashboard.</p>
    </div>
    <%= link_to "Invite Admin", new_admin_admin_user_path,
        class: "px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700" %>
  </div>

  <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Role</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @admin_users.each do |admin| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4">
              <div class="flex items-center gap-3">
                <div class="h-8 w-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 font-semibold text-sm shrink-0">
                  <%= admin.first_name.first %><%= admin.last_name.first %>
                </div>
                <span class="text-sm font-medium text-gray-900">
                  <%= admin.full_name %>
                  <% if admin == current_user %>
                    <span class="ml-1 text-xs text-gray-400">(you)</span>
                  <% end %>
                </span>
              </div>
            </td>
            <td class="px-6 py-4 text-sm text-gray-600"><%= admin.email %></td>
            <td class="px-6 py-4">
              <% if admin.has_role?(:super_admin) %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                  Super Admin
                </span>
              <% else %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                  HR Admin
                </span>
              <% end %>
            </td>
            <td class="px-6 py-4">
              <% if admin.invitation_accepted_at.present? %>
                <span class="inline-flex items-center gap-1 text-xs font-medium text-green-700">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  Invite Accepted
                </span>
              <% elsif admin.invitation_sent_at.present? %>
                <span class="inline-flex items-center gap-1 text-xs font-medium text-yellow-700">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>
                  Invite Pending
                </span>
              <% else %>
                <span class="text-xs text-gray-400">—</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-right">
              <% unless admin.has_role?(:super_admin) || admin == current_user %>
                <%= button_to "Remove", admin_admin_user_path(admin),
                    method: :delete,
                    data: { turbo_confirm: "Remove #{admin.full_name}'s admin access? They will no longer be able to log in to the admin dashboard." },
                    class: "text-sm text-red-600 hover:text-red-800 font-medium cursor-pointer" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
