<div class="max-w-5xl mx-auto">

  <%# Header %>
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="page-title text-2xl"><%= @salary_structure.name %></h1>
      <div class="flex items-center gap-3 mt-1">
        <% if @salary_structure.active? %>
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-700">Active</span>
        <% else %>
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-stone-100 text-stone-500">Inactive</span>
        <% end %>
        <span class="text-sm text-stone-500"><%= @components.size %> component<%= @components.size == 1 ? "" : "s" %></span>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to "Edit Name", edit_admin_salary_structure_path(@salary_structure),
          class: "btn btn-secondary" %>
      <%= link_to "All Structures", admin_salary_structures_path,
          class: "btn btn-ghost" %>
    </div>
  </div>

  <%# Statutory deductions are automatic — make that explicit so admins don't
      try to add PF/ESI/PT/TDS here (ISSUE-2). %>
  <div class="rounded-lg bg-kula-50 border border-kula-200 p-4 mb-6 flex items-start gap-3">
    <svg class="w-5 h-5 text-kula-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>
    <div class="text-sm">
      <p class="font-medium text-kula-950">Define earnings only</p>
      <p class="text-kula-800 mt-0.5">
        PF, ESI, Professional Tax and TDS are calculated automatically per statutory rules
        at payroll time — you don't (and can't) add them here.
      </p>
    </div>
  </div>

  <%# Component list by type %>
  <% grouped = @components.group_by(&:component_type) %>

  <% [["earning", "Earnings", "green"], ["deduction", "Deductions", "red"], ["employer_contribution", "Employer Contributions", "blue"]].each do |type, label, color| %>
    <% type_components = grouped[type] || [] %>
    <% next if type_components.empty? && @available_components.none? { |c| c.component_type == type } %>

    <div class="mb-6">
      <div class="flex items-center gap-2 mb-3">
        <% dot_color = { "green" => "bg-green-500", "red" => "bg-red-500", "blue" => "bg-kula-600" }[color] %>
        <span class="h-2.5 w-2.5 rounded-full <%= dot_color %>"></span>
        <h2 class="text-base font-semibold text-stone-900"><%= label %></h2>
      </div>

      <div class="card overflow-hidden">
        <% if type_components.any? %>
          <table class="tbl">
            <thead>
              <tr>
                <th>Component</th>
                <th>Calculation</th>
                <th>Value</th>
                <th class="text-right">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% type_components.each do |ssc| %>
                <tr class="hover:bg-stone-50">
                  <td class="text-sm font-medium text-stone-900"><%= ssc.name %></td>
                  <td>
                    <% calc_styles = { "flat" => "bg-stone-100 text-stone-700", "percentage" => "bg-kula-100 text-kula-700" } %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= calc_styles[ssc.calculation_type] %>">
                      <%= ssc.calculation_type.capitalize %>
                    </span>
                  </td>
                  <td class="text-sm text-stone-900">
                    <%# Form lives here but its submit button sits in the Actions cell,
                        bound via the HTML5 `form` attribute (keeps table markup valid). %>
                    <%= form_with url: update_component_admin_salary_structure_path(@salary_structure, component_id: ssc.id),
                          method: :patch, id: "update_component_#{ssc.id}", class: "flex items-center gap-1.5" do |f| %>
                      <% if ssc.calculation_type == "percentage" %>
                        <%= f.number_field "salary_structure_component[value]", value: ssc.value,
                              step: "0.01", min: "0.01",
                              class: "w-20 rounded-lg border-stone-300 px-4 py-3 shadow-sm focus:border-kula-600 focus:ring-kula-600 text-sm font-mono" %>
                        <span class="text-xs text-stone-500">% of CTC</span>
                      <% else %>
                        <span class="text-xs text-stone-500">₹</span>
                        <%= f.number_field "salary_structure_component[value]", value: ssc.value,
                              step: "0.01", min: "0.01",
                              class: "w-24 rounded-lg border-stone-300 px-4 py-3 shadow-sm focus:border-kula-600 focus:ring-kula-600 text-sm font-mono" %>
                        <span class="text-xs text-stone-500">/month</span>
                      <% end %>
                    <% end %>
                  </td>
                  <td class="text-right">
                    <div class="flex items-center justify-end gap-2">
                      <%# Save value — submits the form in the previous cell %>
                      <button type="submit" form="update_component_<%= ssc.id %>"
                              title="Save value"
                              class="p-1 rounded-md text-green-600 hover:bg-green-100 transition-colors cursor-pointer">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                        </svg>
                      </button>
                      <%= button_to remove_component_admin_salary_structure_path(@salary_structure, component_id: ssc.id),
                          method: :delete,
                          title: "Remove from structure",
                          class: "p-1 rounded-md text-red-600 hover:bg-red-200 transition-colors cursor-pointer",
                          form: { data: { turbo_confirm: "Remove '#{ssc.name}' from this structure?" } } do %>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                          <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                        </svg>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <div class="p-6 text-center text-sm text-stone-500">
            No <%= label.downcase %> added yet.
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Summary %>
  <% if @components.any? %>
    <div class="bg-stone-50 rounded-lg border border-stone-200 p-4 mb-6">
      <div class="flex items-center gap-6 text-sm">
        <div>
          <span class="text-stone-500">Total % of CTC allocated:</span>
          <span class="font-semibold text-stone-900 ml-1"><%= @salary_structure.total_percentage %>%</span>
        </div>
        <div>
          <span class="text-stone-500">Flat components:</span>
          <span class="font-semibold text-stone-900 ml-1">
            ₹<%= number_with_delimiter(@components.select { |c| c.calculation_type == "flat" }.sum(&:value)) %>/month
          </span>
        </div>
      </div>
    </div>
  <% end %>

  <%# Add component form %>
  <% if @available_components.any? %>
    <div class="card card-pad">
      <h3 class="card-title mb-4">Add Component</h3>
      <%= form_with url: add_component_admin_salary_structure_path(@salary_structure), method: :post, class: "flex items-end gap-4" do |f| %>
        <div class="flex-1">
          <%= f.label "salary_structure_component[salary_component_id]", "Component", class: "label" %>
          <%= f.select "salary_structure_component[salary_component_id]",
              @available_components.map { |c|
                type_label = c.component_type.titleize
                calc_label = c.calculation_type == "percentage" ? "%" : "flat"
                ["#{c.name} (#{type_label} · #{calc_label})", c.id]
              },
              { include_blank: "Select a component..." },
              class: "select" %>
        </div>
        <div class="w-48">
          <%= f.label "salary_structure_component[value]", "Value", class: "label" %>
          <%= f.number_field "salary_structure_component[value]", step: "0.01", min: "0.01",
              placeholder: "% or ₹ amount",
              class: "input" %>
        </div>
        <div>
          <%= f.submit "Add", class: "btn btn-primary cursor-pointer" %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
