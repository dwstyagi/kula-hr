<%= form_with model: salary_structure, url: url, method: local_assigns[:method] || :post, class: "space-y-4" do |f| %>
  <div>
    <%= f.label :name, class: "label" %>
    <%= f.text_field :name, class: "input", autofocus: true, placeholder: "e.g. Standard CTC Package" %>
    <% if salary_structure.errors[:name].any? %>
      <p class="mt-1 text-sm text-red-600"><%= salary_structure.errors[:name].first %></p>
    <% end %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit salary_structure.persisted? ? "Update Structure" : "Create Structure",
        class: "btn btn-primary cursor-pointer" %>
    <%= link_to "Cancel",
        salary_structure.persisted? ? admin_salary_structure_path(salary_structure) : admin_salary_structures_path,
        class: "btn btn-ghost" %>
  </div>
<% end %>
