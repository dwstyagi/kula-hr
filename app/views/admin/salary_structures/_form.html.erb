<%= form_with model: salary_structure, url: url, method: local_assigns[:method] || :post, class: "space-y-4" do |f| %>
  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm", autofocus: true, placeholder: "e.g. Standard CTC Package" %>
    <% if salary_structure.errors[:name].any? %>
      <p class="mt-1 text-sm text-red-600"><%= salary_structure.errors[:name].first %></p>
    <% end %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit salary_structure.persisted? ? "Update Structure" : "Create Structure",
        class: "px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 cursor-pointer" %>
    <%= link_to "Cancel",
        salary_structure.persisted? ? admin_salary_structure_path(salary_structure) : admin_salary_structures_path,
        class: "px-4 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-200" %>
  </div>
<% end %>
