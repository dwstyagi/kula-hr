<div class="max-w-5xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <h1 class="page-title text-2xl">Salary Structures</h1>
    <%= link_to new_admin_salary_structure_path,
        class: "btn btn-primary" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      New Structure
    <% end %>
  </div>

  <div class="card overflow-hidden">
    <% if @salary_structures.any? %>
      <div class="overflow-x-auto">
      <table class="tbl">
        <thead>
          <tr>
            <th>Name</th>
            <th>Components</th>
            <th>Status</th>
            <th class="text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @salary_structures.each do |structure| %>
            <tr class="hover:bg-stone-50 <%= 'opacity-50' unless structure.active? %>">
              <td>
                <%= link_to admin_salary_structure_path(structure), class: "text-sm font-medium text-kula-700 hover:text-kula-900" do %>
                  <%= structure.name %>
                <% end %>
              </td>
              <td class="text-sm text-stone-500">
                <%= structure.component_count %> component<%= structure.component_count == 1 ? "" : "s" %>
              </td>
              <td>
                <% if structure.active? %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-700">Active</span>
                <% else %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-stone-100 text-stone-500">Inactive</span>
                <% end %>
              </td>
              <td class="text-right">
                <div class="flex items-center justify-end gap-2">
                  <%= link_to admin_salary_structure_path(structure),
                      title: "View",
                      class: "p-1 rounded-md text-kula-700 hover:bg-kula-100 transition-colors cursor-pointer" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    </svg>
                  <% end %>

                  <%= button_to toggle_active_admin_salary_structure_path(structure),
                      method: :patch,
                      title: structure.active? ? "Deactivate" : "Activate",
                      class: "p-1 rounded-md transition-colors cursor-pointer #{structure.active? ? 'text-amber-600 hover:bg-amber-200' : 'text-emerald-600 hover:bg-emerald-200'}" do %>
                    <% if structure.active? %>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.25 9v6m-4.5 0V9M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                      </svg>
                    <% else %>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-10.5-3.906c0-.762.83-1.23 1.47-.843l6.807 4.097c.656.395.656 1.347 0 1.742l-6.807 4.097c-.64.386-1.47-.082-1.47-.844V8.094Z" />
                      </svg>
                    <% end %>
                  <% end %>

                  <%= button_to admin_salary_structure_path(structure),
                      method: :delete,
                      title: "Delete",
                      class: "p-1 rounded-md text-red-600 hover:bg-red-200 transition-colors cursor-pointer",
                      form: { data: { turbo_confirm: "Delete '#{structure.name}' and all its component assignments?" } } do %>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                    </svg>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      </div>
    <% else %>
      <div class="p-12 text-center">
        <svg class="mx-auto h-12 w-12 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-stone-900">No salary structures</h3>
        <p class="mt-1 text-sm text-stone-500">Create a structure to group salary components into a reusable template.</p>
      </div>
    <% end %>
  </div>
</div>
