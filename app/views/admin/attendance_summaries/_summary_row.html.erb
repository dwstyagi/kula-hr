<%# Turbo Frame wraps each row — edit/update swaps content in-place %>
<%= turbo_frame_tag dom_id(summary) do %>
  <tr class="hover:bg-gray-50">
    <td class="px-5 py-3">
      <p class="text-sm font-medium text-gray-900"><%= summary.employee.full_name %></p>
      <p class="text-xs text-gray-400 mt-0.5">
        <%= summary.employee.employee_code %>
        <% if summary.employee.department %>
          &middot; <%= summary.employee.department.name %>
        <% end %>
      </p>
    </td>

    <td class="px-5 py-3 text-center text-sm font-medium text-gray-700">
      <%= summary.total_working_days.to_i %>
    </td>

    <td class="px-5 py-3 text-center text-sm text-gray-700">
      <%= summary.days_present %>
    </td>

    <td class="px-5 py-3 text-center text-sm text-gray-500">
      <%= summary.half_days.zero? ? "—" : summary.half_days.to_i %>
    </td>

    <td class="px-5 py-3 text-center">
      <% if summary.approved_leaves > 0 %>
        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-700">
          +<%= summary.approved_leaves.to_i %>
        </span>
      <% else %>
        <span class="text-sm text-gray-400">—</span>
      <% end %>
    </td>

    <td class="px-5 py-3 text-center">
      <% if summary.unapproved_absences > 0 %>
        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-700">
          <%= summary.unapproved_absences %>
        </span>
      <% else %>
        <span class="text-sm text-gray-400">—</span>
      <% end %>
    </td>

    <td class="px-5 py-3 text-center">
      <% if summary.lop_days > 0 %>
        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-orange-100 text-orange-700">
          <%= summary.lop_days %>
        </span>
      <% else %>
        <span class="text-sm text-gray-400">0</span>
      <% end %>
    </td>

    <td class="px-5 py-3 text-center text-sm font-semibold text-gray-900">
      <%= summary.paid_days %>
    </td>

    <td class="px-5 py-3 text-center">
      <% if summary.locked? %>
        <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
          </svg>
          Locked
        </span>
      <% else %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-700">
          Draft
        </span>
      <% end %>
    </td>

    <td class="px-5 py-3 text-right">
      <% if summary.draft? %>
        <%= link_to "Edit",
              edit_admin_attendance_summary_path(summary),
              class: "text-xs px-3 py-1.5 bg-gray-100 text-gray-600 rounded-lg hover:bg-gray-200",
              title: "Edit attendance",
              data: { turbo_frame: dom_id(summary) } %>
      <% else %>
        <span class="text-gray-300 text-xs">—</span>
      <% end %>
    </td>
  </tr>
<% end %>
