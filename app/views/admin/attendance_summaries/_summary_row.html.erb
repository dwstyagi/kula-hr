<tr class="hover:bg-stone-50">
  <td class="px-5 py-3">
    <p class="text-sm font-medium text-stone-900"><%= summary.employee.full_name %></p>
    <p class="text-xs text-stone-400 mt-0.5">
      <%= summary.employee.employee_code %>
      <% if summary.employee.department %>
        &middot; <%= summary.employee.department.name %>
      <% end %>
    </p>
  </td>

  <td class="px-5 py-3 text-center text-sm font-medium text-stone-700">
    <%= summary.total_working_days.to_i %>
  </td>

  <td class="px-5 py-3 text-center text-sm text-stone-700">
    <%= summary.days_present %>
  </td>

  <td class="px-5 py-3 text-center text-sm text-stone-500">
    <%= summary.half_days.zero? ? "—" : summary.half_days.to_i %>
  </td>

  <td class="px-5 py-3 text-center">
    <% if summary.approved_leaves > 0 %>
      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium badge-success">
        +<%= summary.approved_leaves.to_i %>
      </span>
    <% else %>
      <span class="text-sm text-stone-400">—</span>
    <% end %>
  </td>

  <td class="px-5 py-3 text-center">
    <% if summary.unapproved_absences > 0 %>
      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium badge-danger">
        <%= summary.unapproved_absences %>
      </span>
    <% else %>
      <span class="text-sm text-stone-400">—</span>
    <% end %>
  </td>

  <td class="px-5 py-3 text-center">
    <% if summary.lop_days > 0 %>
      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium badge-warning">
        <%= summary.lop_days %>
      </span>
    <% else %>
      <span class="text-sm text-stone-400">0</span>
    <% end %>
  </td>

  <td class="px-5 py-3 text-center text-sm font-semibold text-stone-900">
    <%= summary.paid_days %>
  </td>

  <td class="px-5 py-3 text-center">
    <% if summary.locked? %>
      <span class="badge badge-success">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
        </svg>
        Locked
      </span>
    <% else %>
      <span class="badge badge-warning">
        Draft
      </span>
    <% end %>
  </td>

  <td class="px-5 py-3 text-right">
    <% if summary.draft? %>
      <%= link_to edit_admin_attendance_summary_path(summary),
            class: "inline-flex items-center justify-center w-8 h-8 rounded-lg text-stone-400 hover:text-kula-700 hover:bg-kula-50 transition-colors",
            title: "Edit attendance" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
      <% end %>
    <% else %>
      <span class="text-stone-300 text-xs">—</span>
    <% end %>
  </td>
</tr>
