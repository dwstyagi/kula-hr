<div class="space-y-6">

  <%# Page header %>
  <div class="flex items-start justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Attendance Summary</h1>
      <p class="text-sm text-gray-500 mt-0.5">Review, adjust, and lock monthly attendance before payroll</p>
    </div>

    <%# Month / Year picker %>
    <%= form_with url: admin_attendance_summaries_path, method: :get,
                  class: "flex items-center gap-2" do |f| %>
      <%= f.select :month,
            (1..12).map { |m| [Date::MONTHNAMES[m], m] },
            { selected: @month },
            class: "text-sm border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      <%= f.number_field :year, value: @year, min: 2020, max: 2099,
            class: "w-24 text-sm border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      <%= f.submit "View",
            class: "px-4 py-2 text-sm font-medium bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 cursor-pointer" %>
    <% end %>
  </div>

  <%# Action bar %>
  <div class="flex flex-wrap items-center gap-3">
    <%# Generate %>
    <% if !@any_generated %>
      <%= button_to generate_admin_attendance_summaries_path(month: @month, year: @year),
            method: :post,
            class: "inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 cursor-pointer",
            form: { data: { turbo_confirm: "Generate attendance summaries for #{Date::MONTHNAMES[@month]} #{@year}? Existing locked records will not be changed." } } do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
        </svg>
        Generate for <%= Date::MONTHNAMES[@month] %> <%= @year %>
      <% end %>
    <% else %>
      <%= button_to generate_admin_attendance_summaries_path(month: @month, year: @year),
            method: :post,
            class: "inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 cursor-pointer",
            form: { data: { turbo_confirm: "Re-generate will refresh leave data for draft records. Locked records will not change. Continue?" } } do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
        </svg>
        Re-generate
      <% end %>
    <% end %>

    <% if @any_generated %>
      <%# Download template %>
      <%= link_to download_template_admin_attendance_summaries_path(month: @month, year: @year),
            class: "inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        Download CSV
      <% end %>

      <%# Upload template %>
      <%= form_with url: upload_template_admin_attendance_summaries_path(month: @month, year: @year),
                    method: :post, multipart: true, class: "flex items-center gap-2" do |f| %>
        <%= f.file_field :file, accept: ".csv",
              class: "text-sm text-gray-500 file:mr-3 file:py-2 file:px-3 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 cursor-pointer" %>
        <%= f.submit "Upload",
              class: "px-4 py-2 text-sm font-medium bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 cursor-pointer" %>
      <% end %>

      <%# Lock month %>
      <% unless @all_locked %>
        <%= button_to lock_month_admin_attendance_summaries_path(month: @month, year: @year),
              method: :patch,
              class: "inline-flex items-center gap-2 px-4 py-2 bg-green-600 text-white text-sm font-medium rounded-lg hover:bg-green-700 cursor-pointer ml-auto",
              form: { data: { turbo_confirm: "Lock all attendance for #{Date::MONTHNAMES[@month]} #{@year}? This cannot be undone." } } do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
          Lock Month
        <% end %>
      <% else %>
        <span class="inline-flex items-center gap-1.5 px-3 py-2 bg-green-50 border border-green-200 text-green-700 text-sm font-medium rounded-lg ml-auto">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
          Attendance Locked
        </span>
      <% end %>
    <% end %>
  </div>

  <%# Attendance table %>
  <% if @summaries.any? %>
    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Employee</th>
            <th class="px-5 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider" title="Total Working Days">WD</th>
            <th class="px-5 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider" title="Days Present">Present</th>
            <th class="px-5 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider" title="Half Days">½ Days</th>
            <th class="px-5 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider" title="Approved Paid Leaves">Leaves</th>
            <th class="px-5 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider" title="Unapproved Absences">Absent</th>
            <th class="px-5 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider" title="Loss of Pay Days">LOP</th>
            <th class="px-5 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider" title="Paid Days">Paid</th>
            <th class="px-5 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @summaries.each do |summary| %>
            <% if @editing_summary&.id == summary.id %>
              <%= render "edit_row", summary: summary %>
            <% else %>
              <%= render "summary_row", summary: summary %>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @editing_summary %>
      <%= form_with url: admin_attendance_summary_path(@editing_summary),
                    method: :patch,
                    id: "edit_attendance_#{@editing_summary.id}",
                    class: "hidden" do %>
      <% end %>
    <% end %>
  <% elsif @any_generated == false %>
    <div class="bg-white rounded-xl border border-gray-200 p-16 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
      </svg>
      <p class="text-sm font-medium text-gray-900">No attendance data for <%= Date::MONTHNAMES[@month] %> <%= @year %></p>
      <p class="text-xs text-gray-400 mt-1">Click <strong>Generate</strong> to auto-fill from approved leaves.</p>
    </div>
  <% end %>

</div>
