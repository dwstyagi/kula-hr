<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Edit Company Profile</h1>
    <p class="text-sm text-gray-500 mt-0.5">Update statutory identifiers and registered address</p>
  </div>

  <%= form_with model: @tenant, url: admin_company_profile_path, method: :patch, class: "space-y-6" do |f| %>
    <% if @tenant.errors.any? %>
      <div class="rounded-lg bg-red-50 border border-red-200 p-4">
        <p class="text-sm font-medium text-red-800 mb-1"><%= pluralize(@tenant.errors.count, "error") %> prevented saving:</p>
        <ul class="list-disc list-inside text-sm text-red-700 space-y-0.5">
          <% @tenant.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <%# Company Details %>
      <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-5">
        <h2 class="text-base font-semibold text-gray-900 border-b border-gray-100 pb-3">Company Details</h2>

        <div>
          <%= f.label :name, "Company Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :name,
                class: "w-full px-4 py-3 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
                placeholder: "Acme Pvt. Ltd." %>
        </div>

        <div>
          <%= f.label :state, "State", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :state,
                class: "w-full px-4 py-3 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
                placeholder: "Maharashtra" %>
          <p class="text-xs text-gray-500 mt-1">Used for Professional Tax slab lookup. Must match the state set during signup.</p>
        </div>
      </div>

      <%# Statutory Identifiers %>
      <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-5">
        <h2 class="text-base font-semibold text-gray-900 border-b border-gray-100 pb-3">Statutory Identifiers</h2>

        <div class="grid grid-cols-1 gap-4">
          <div>
            <%= f.label :gstin, "GSTIN", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :gstin,
                  class: "w-full px-4 py-3 text-sm font-mono border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
                  placeholder: "22AAAAA0000A1Z5",
                  maxlength: 15 %>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <%= f.label :pan, "PAN", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_field :pan,
                    class: "w-full px-4 py-3 text-sm font-mono border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
                    placeholder: "AAAAA0000A",
                    maxlength: 10 %>
            </div>
            <div>
              <%= f.label :tan, "TAN", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_field :tan,
                    class: "w-full px-4 py-3 text-sm font-mono border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
                    placeholder: "ABCD12345E",
                    maxlength: 10 %>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <%= f.label :pf_establishment_code, "PF Establishment Code", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_field :pf_establishment_code,
                    class: "w-full px-4 py-3 text-sm font-mono border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
                    placeholder: "MH/BAN/0012345/000" %>
            </div>
            <div>
              <%= f.label :esi_code, "ESI Code", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_field :esi_code,
                    class: "w-full px-4 py-3 text-sm font-mono border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
                    placeholder: "12345678901" %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%# Registered Address %>
    <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-5">
      <h2 class="text-base font-semibold text-gray-900 border-b border-gray-100 pb-3">Registered Address</h2>

      <div>
        <%= f.label :address, "Street Address", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_area :address, rows: 2,
              class: "w-full px-4 py-3 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
              placeholder: "123, MG Road, Bandra West" %>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <%= f.label :city, "City", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :city,
                class: "w-full px-4 py-3 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
                placeholder: "Mumbai" %>
        </div>
        <div>
          <%= f.label :state, "State", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :state,
                class: "w-full px-4 py-3 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
                placeholder: "Maharashtra" %>
        </div>
        <div>
          <%= f.label :pincode, "Pincode", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :pincode,
                class: "w-full px-4 py-3 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
                placeholder: "400050",
                maxlength: 6 %>
        </div>
      </div>
    </div>

    <%# Actions %>
    <div class="flex items-center gap-3">
      <%= f.submit "Save Profile",
            class: "px-5 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 cursor-pointer" %>
      <%= link_to "Cancel", admin_company_profile_path,
            class: "px-5 py-2 text-sm font-medium text-gray-700 hover:text-gray-900" %>
    </div>
  <% end %>
</div>
