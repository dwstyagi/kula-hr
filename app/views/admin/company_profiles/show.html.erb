<div class="space-y-6">
  <%# Header %>
  <div class="flex items-start justify-between">
    <div>
      <h1 class="page-title text-2xl">Company Profile</h1>
      <p class="text-sm text-stone-500 mt-0.5">Statutory identifiers and registered address for this organisation</p>
    </div>
    <% if policy(@tenant).update? %>
      <%= link_to edit_admin_company_profile_path,
            class: "btn btn-primary" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
        Edit Profile
      <% end %>
    <% end %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <%# Company Details %>
    <div class="card card-pad space-y-4">
      <h2 class="text-base font-semibold text-stone-900 border-b border-stone-100 pb-3">Company Details</h2>
      <dl class="space-y-3 text-sm">
        <div class="grid grid-cols-2 gap-x-4">
          <dt class="text-stone-500">Company Name</dt>
          <dd class="font-medium text-stone-900"><%= @tenant.name %></dd>
        </div>
        <div class="grid grid-cols-2 gap-x-4">
          <dt class="text-stone-500">Subdomain</dt>
          <dd class="font-medium text-stone-900"><%= @tenant.subdomain %></dd>
        </div>
        <div class="grid grid-cols-2 gap-x-4">
          <dt class="text-stone-500">State</dt>
          <dd class="font-medium text-stone-900"><%= @tenant.state.presence&.humanize || "—" %></dd>
        </div>
      </dl>
    </div>

    <%# Statutory Identifiers %>
    <div class="card card-pad space-y-4">
      <h2 class="text-base font-semibold text-stone-900 border-b border-stone-100 pb-3">Statutory Identifiers</h2>
      <dl class="space-y-3 text-sm">
        <div class="grid grid-cols-2 gap-x-4">
          <dt class="text-stone-500">GSTIN</dt>
          <dd class="font-medium text-stone-900 font-mono"><%= @tenant.gstin.presence || "—" %></dd>
        </div>
        <div class="grid grid-cols-2 gap-x-4">
          <dt class="text-stone-500">PAN</dt>
          <dd class="font-medium text-stone-900 font-mono"><%= @tenant.pan.presence || "—" %></dd>
        </div>
        <div class="grid grid-cols-2 gap-x-4">
          <dt class="text-stone-500">TAN</dt>
          <dd class="font-medium text-stone-900 font-mono"><%= @tenant.tan.presence || "—" %></dd>
        </div>
        <div class="grid grid-cols-2 gap-x-4">
          <dt class="text-stone-500">PF Establishment Code</dt>
          <dd class="font-medium text-stone-900 font-mono"><%= @tenant.pf_establishment_code.presence || "—" %></dd>
        </div>
        <div class="grid grid-cols-2 gap-x-4">
          <dt class="text-stone-500">ESI Code</dt>
          <dd class="font-medium text-stone-900 font-mono"><%= @tenant.esi_code.presence || "—" %></dd>
        </div>
      </dl>
    </div>

    <%# Registered Address %>
    <div class="card card-pad space-y-4 lg:col-span-2">
      <h2 class="text-base font-semibold text-stone-900 border-b border-stone-100 pb-3">Registered Address</h2>
      <dl class="grid grid-cols-2 lg:grid-cols-4 gap-x-4 gap-y-3 text-sm">
        <div>
          <dt class="text-stone-500">Street Address</dt>
          <dd class="font-medium text-stone-900"><%= @tenant.address.presence || "—" %></dd>
        </div>
        <div>
          <dt class="text-stone-500">City</dt>
          <dd class="font-medium text-stone-900"><%= @tenant.city.presence || "—" %></dd>
        </div>
        <div>
          <dt class="text-stone-500">State</dt>
          <dd class="font-medium text-stone-900"><%= @tenant.state.presence&.humanize || "—" %></dd>
        </div>
        <div>
          <dt class="text-stone-500">Pincode</dt>
          <dd class="font-medium text-stone-900"><%= @tenant.pincode.presence || "—" %></dd>
        </div>
      </dl>
    </div>
  </div>

  <%# Incomplete profile warning %>
  <% missing = [
       ("GSTIN" unless @tenant.gstin.present?),
       ("PAN"   unless @tenant.pan.present?),
       ("TAN"   unless @tenant.tan.present?),
       ("PF Establishment Code" unless @tenant.pf_establishment_code.present?),
       ("ESI Code" unless @tenant.esi_code.present?),
     ].compact %>
  <% if missing.any? %>
    <div class="rounded-lg bg-amber-50 border border-amber-200 p-4 flex items-start gap-3">
      <svg class="w-5 h-5 text-amber-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
      </svg>
      <div>
        <p class="text-sm font-medium text-amber-800">Profile incomplete</p>
        <p class="text-sm text-amber-700 mt-0.5">Missing: <%= missing.to_sentence %>. These are required for payslips and statutory reports.</p>
      </div>
    </div>
  <% end %>
</div>
