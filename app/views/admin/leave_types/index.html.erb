<div class="max-w-5xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="page-title text-2xl">Leave Types</h1>
      <p class="text-sm text-stone-500 mt-1">Configure leave policies for your organization.</p>
    </div>
    <%= link_to new_admin_leave_type_path,
        class: "btn btn-primary",
        data: { turbo_frame: "leave_type_form" } do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Add Leave Type
    <% end %>
  </div>

  <%= turbo_frame_tag "leave_type_form" %>

  <div class="card overflow-hidden">
    <% if @leave_types.any? %>
      <div class="overflow-x-auto">
      <table class="tbl">
        <thead>
          <tr>
            <th>Name</th>
            <th>Code</th>
            <th>Days / Year</th>
            <th>Carry Forward</th>
            <th>Paid?</th>
            <th>Status</th>
            <th class="text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @leave_types.each do |lt| %>
            <%= turbo_frame_tag lt do %>
              <tr class="hover:bg-stone-50 <%= 'opacity-50' unless lt.is_active? %>">
                <td class="text-sm font-medium text-stone-900"><%= lt.name %></td>
                <td>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-mono font-medium bg-stone-100 text-stone-700"><%= lt.code %></span>
                </td>
                <td class="text-sm text-stone-700">
                  <% if lt.annual_quota.zero? %>
                    <span class="text-stone-400">Unlimited</span>
                  <% else %>
                    <%= lt.annual_quota.to_i %> days
                  <% end %>
                </td>
                <td class="text-sm text-stone-700">
                  <% if lt.carry_forward? %>
                    <span class="text-kula-700">Yes <span class="text-stone-400">(max <%= lt.max_carry_forward.to_i %>)</span></span>
                  <% else %>
                    <span class="text-stone-400">No</span>
                  <% end %>
                </td>
                <td class="text-sm">
                  <% if lt.is_paid? %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-700">Paid</span>
                  <% else %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-700">Unpaid (LOP)</span>
                  <% end %>
                </td>
                <td>
                  <% if lt.is_active? %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-700">Active</span>
                  <% else %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-stone-100 text-stone-500">Inactive</span>
                  <% end %>
                </td>
                <td class="text-right">
                  <div class="flex items-center justify-end gap-2">
                    <%= button_to toggle_active_admin_leave_type_path(lt),
                        method: :patch,
                        title: lt.is_active? ? "Deactivate" : "Activate",
                        class: "p-1 rounded-md transition-colors cursor-pointer #{lt.is_active? ? 'text-amber-600 hover:bg-amber-200' : 'text-emerald-600 hover:bg-emerald-200'}" do %>
                      <% if lt.is_active? %>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M14.25 9v6m-4.5 0V9M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                        </svg>
                      <% else %>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-10.5-3.906c0-.762.83-1.23 1.47-.843l6.807 4.097c.656.395.656 1.347 0 1.742l-6.807 4.097c-.64.386-1.47-.082-1.47-.844V8.094Z" />
                        </svg>
                      <% end %>
                    <% end %>

                    <%= link_to edit_admin_leave_type_path(lt),
                        title: "Edit",
                        class: "p-1 rounded-md text-kula-700 hover:bg-kula-100 transition-colors cursor-pointer",
                        data: { turbo_frame: dom_id(lt) } do %>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                      </svg>
                    <% end %>

                    <%= button_to admin_leave_type_path(lt),
                        method: :delete,
                        title: "Delete",
                        class: "p-1 rounded-md text-red-600 hover:bg-red-200 transition-colors cursor-pointer",
                        form: { data: { turbo_confirm: "Delete '#{lt.name}'? This cannot be undone." } } do %>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                      </svg>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
      </div>
    <% else %>
      <div class="p-12 text-center">
        <svg class="mx-auto h-10 w-10 text-stone-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
        </svg>
        <p class="text-sm text-stone-500">No leave types configured. Add your first leave type to get started.</p>
      </div>
    <% end %>
  </div>
</div>
