<%= form_with model: leave_type, url: url, method: local_assigns[:method] || :post, class: "space-y-5" do |f| %>
  <% if leave_type.errors.any? %>
    <div class="rounded-lg bg-red-50 p-4">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
        </svg>
        <div class="ml-3">
          <ul class="text-sm text-red-700 list-disc list-inside">
            <% leave_type.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-5">
    <div>
      <%= f.label :name, class: "label" %>
      <%= f.text_field :name,
          class: "input",
          autofocus: true, placeholder: "e.g. Maternity Leave" %>
    </div>

    <div>
      <%= f.label :code, "Short Code", class: "label" %>
      <%= f.text_field :code,
          class: "input font-mono uppercase",
          placeholder: "e.g. ML",
          oninput: "this.value = this.value.toUpperCase()" %>
    </div>

    <div>
      <%= f.label :annual_quota, "Days Per Year", class: "label" %>
      <%= f.number_field :annual_quota,
          class: "input",
          min: 0, step: 1, placeholder: "0 = unlimited" %>
    </div>

    <div>
      <%= f.label :max_carry_forward, "Max Carry Forward Days", class: "label" %>
      <%= f.number_field :max_carry_forward,
          class: "input",
          min: 0, step: 1, placeholder: "0" %>
      <p class="text-xs text-stone-400 mt-1">Only applies if carry forward is enabled.</p>
    </div>
  </div>

  <div class="flex items-center gap-6">
    <label class="flex items-center gap-2 cursor-pointer">
      <%= f.check_box :carry_forward, class: "rounded border-stone-300 text-kula-700 shadow-sm focus:ring-kula-600" %>
      <span class="text-sm text-stone-700">Allow Carry Forward</span>
    </label>

    <label class="flex items-center gap-2 cursor-pointer">
      <%= f.check_box :is_paid, class: "rounded border-stone-300 text-kula-700 shadow-sm focus:ring-kula-600" %>
      <span class="text-sm text-stone-700">Paid Leave</span>
    </label>

    <label class="flex items-center gap-2 cursor-pointer">
      <%= f.check_box :is_active, class: "rounded border-stone-300 text-kula-700 shadow-sm focus:ring-kula-600" %>
      <span class="text-sm text-stone-700">Active</span>
    </label>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit leave_type.persisted? ? "Update Leave Type" : "Create Leave Type",
        class: "btn btn-primary cursor-pointer" %>
    <%= link_to "Cancel", admin_leave_types_path,
        class: "btn btn-ghost" %>
  </div>
<% end %>
