<%= form_with model: department, url: url, method: local_assigns[:method] || :post, class: "flex items-end gap-4" do |f| %>
  <div class="flex-1">
    <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm", autofocus: true, placeholder: "Department name" %>
    <% if department.errors[:name].any? %>
      <p class="mt-1 text-sm text-red-600"><%= department.errors[:name].first %></p>
    <% end %>
  </div>
  <div class="flex gap-2">
    <%= f.submit department.persisted? ? "Update" : "Create", class: "px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 cursor-pointer" %>
    <%= link_to "Cancel", admin_departments_path, class: "px-4 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-200" %>
  </div>
<% end %>
