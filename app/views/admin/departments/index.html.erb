<div class="max-w-4xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Departments</h1>
    <%= link_to new_admin_department_path,
        class: "inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700",
        data: { turbo_frame: "department_form" } do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Add Department
    <% end %>
  </div>

  <%= turbo_frame_tag "department_form" %>

  <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
    <% if @departments.any? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @departments.each do |department| %>
            <%= turbo_frame_tag department do %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-sm text-gray-900"><%= department.name %></td>
                <td class="px-6 py-4 text-right space-x-2">
                  <%= link_to "Edit", edit_admin_department_path(department),
                      class: "text-sm text-blue-600 hover:text-blue-800",
                      data: { turbo_frame: dom_id(department) } %>
                  <%= button_to "Delete", admin_department_path(department),
                      method: :delete,
                      class: "text-sm text-red-600 hover:text-red-800",
                      form: { data: { turbo_confirm: "Delete '#{department.name}'?" } } %>
                </td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">No departments</h3>
        <p class="mt-1 text-sm text-gray-500">Get started by creating a new department.</p>
      </div>
    <% end %>
  </div>
</div>
