<%# ── Pricing ── %>
<div id="pricing" class="bg-stone-50 py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="sr mx-auto max-w-2xl text-center">
      <p class="text-base font-semibold leading-7 text-kula-600">Transparent pricing</p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight text-stone-900 sm:text-4xl">Pay per employee, not per feature</h2>
      <p class="mt-4 text-lg text-stone-600">Start free. Upgrade when you're ready. No hidden fees, no setup cost.</p>
    </div>
    <div class="sr-stagger mx-auto mt-16 grid max-w-3xl grid-cols-1 gap-8 lg:grid-cols-2">
      <%# Trial %>
      <div class="price-card sr-c flex flex-col rounded-3xl bg-white p-8 ring-1 ring-stone-200">
        <h3 class="text-lg font-semibold leading-8 text-stone-900">Trial</h3>
        <p class="mt-4 text-sm leading-6 text-stone-600">Full access for your first payroll run. No credit card needed.</p>
        <div class="mt-6 flex items-baseline gap-x-1">
          <span class="text-4xl font-bold tracking-tight text-stone-900">Free</span>
        </div>
        <a href="<%= signup_path %>" class="mt-8 block rounded-lg bg-kula-50 px-4 py-2.5 text-center text-sm font-semibold text-kula-600 hover:bg-kula-100 transition">
          Get started free
        </a>
        <ul class="mt-8 space-y-3 text-sm leading-6 text-stone-600">
          <% ["Up to 25 employees", "1 payroll run included", "Full payroll processing", "Leave & attendance", "Statutory compliance (PF / ESI / PT / TDS)", "Payslip PDF generation", "Bulk CSV import", "Bank file download", "Employee self-service portal"].each do |f| %>
            <li class="flex gap-x-3">
              <svg class="h-6 w-5 flex-none text-kula-600" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              <%= f %>
            </li>
          <% end %>
        </ul>
      </div>
      <%# Paid — highlighted %>
      <div class="price-card sr-c flex flex-col rounded-3xl bg-kula-600 p-8 ring-1 ring-kula-600 relative">
        <h3 class="text-lg font-semibold leading-8 text-white">Paid</h3>
        <p class="mt-4 text-sm leading-6 text-kula-200">Unlimited payroll runs. Unlimited employees. Everything included.</p>
        <div class="mt-6 flex items-baseline gap-x-1">
          <span class="text-4xl font-bold tracking-tight text-white">₹99</span>
          <span class="text-sm font-semibold leading-6 text-kula-200">/ employee / month</span>
        </div>
        <a href="<%= signup_path %>" class="btn-cta mt-8 block rounded-lg bg-white px-4 py-2.5 text-center text-sm font-semibold text-kula-600 hover:bg-kula-50 transition shadow-sm">
          Start free trial
        </a>
        <ul class="mt-8 space-y-3 text-sm leading-6 text-kula-200">
          <% ["Everything in Trial", "Unlimited employees", "Unlimited payroll runs", "Bank file generation (HDFC / ICICI / SBI)", "PF ECR + ESI + PT reports", "YTD earnings export", "Priority email support"].each do |f| %>
            <li class="flex gap-x-3">
              <svg class="h-6 w-5 flex-none text-white" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              <%= f %>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
    <p class="sr text-center text-sm text-stone-400 mt-10">Start with 1 free payroll run — no credit card required. Upgrade anytime.</p>
  </div>
</div>
