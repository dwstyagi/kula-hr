<%# ── Hero: fake admin dashboard mockup ── %>
<div class="hero-reveal d5 mt-16 flow-root sm:mt-24">
  <div class="dashboard-float -m-2 rounded-xl bg-gray-900/5 p-2 ring-1 ring-inset ring-gray-900/10 lg:-m-4 lg:rounded-2xl lg:p-4">
    <div class="rounded-xl bg-white shadow-2xl ring-1 ring-gray-900/10 overflow-hidden">
      <%# Fake browser bar %>
      <div class="border-b border-gray-200 bg-gray-50 flex items-center px-4 py-2.5 gap-2">
        <div class="w-3 h-3 rounded-full bg-red-400"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
        <div class="w-3 h-3 rounded-full bg-green-400"></div>
        <div class="flex-1 bg-white mx-4 rounded-md h-6 border border-gray-200 flex items-center px-3">
          <span class="text-xs text-gray-400">acme.<%= @app_domain %>/admin/dashboard</span>
        </div>
      </div>
      <%# Dashboard content %>
      <div class="flex bg-slate-50 min-h-[420px]">
        <%# Sidebar %>
        <div class="hidden md:flex flex-col w-52 bg-white border-r border-gray-100 p-4 gap-1 shrink-0">
          <div class="flex items-center gap-2 mb-4 px-2">
            <div class="w-6 h-6 rounded bg-indigo-600 flex items-center justify-center text-white text-xs font-bold">K</div>
            <span class="font-semibold text-sm text-gray-900">Acme Corp</span>
          </div>
          <div class="text-xs font-semibold text-indigo-600 bg-indigo-50 rounded-md px-3 py-2">Dashboard</div>
          <div class="text-xs text-gray-500 px-3 py-2 hover:bg-gray-50 rounded-md cursor-default">Employees</div>
          <div class="text-xs text-gray-500 px-3 py-2 hover:bg-gray-50 rounded-md cursor-default">Payroll Runs</div>
          <div class="text-xs text-gray-500 px-3 py-2 hover:bg-gray-50 rounded-md cursor-default">Leave Requests</div>
          <div class="text-xs text-gray-500 px-3 py-2 hover:bg-gray-50 rounded-md cursor-default">Attendance</div>
          <div class="text-xs text-gray-500 px-3 py-2 hover:bg-gray-50 rounded-md cursor-default">Reports</div>
          <div class="text-xs text-gray-500 px-3 py-2 hover:bg-gray-50 rounded-md cursor-default">Settings</div>
        </div>
        <%# Main content %>
        <div class="flex-1 p-6 space-y-4 overflow-hidden">
          <div class="flex items-center justify-between">
            <div>
              <h3 class="text-sm font-semibold text-gray-900">Dashboard</h3>
              <p class="text-xs text-gray-400">March 2026</p>
            </div>
            <span class="inline-flex items-center gap-1.5 text-xs font-medium text-green-700 bg-green-50 px-2.5 py-1 rounded-full ring-1 ring-green-600/20">
              <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>Payroll Paid
            </span>
          </div>
          <%# Stat cards %>
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
            <div class="bg-white p-3.5 rounded-xl border border-gray-100 shadow-sm">
              <p class="text-xs text-gray-400 font-medium">Employees</p>
              <p class="text-xl font-bold text-gray-900 mt-0.5">52</p>
              <p class="text-xs text-green-600 mt-0.5">+3 this month</p>
            </div>
            <div class="bg-white p-3.5 rounded-xl border border-gray-100 shadow-sm">
              <p class="text-xs text-gray-400 font-medium">Net Pay</p>
              <p class="text-xl font-bold text-gray-900 mt-0.5">₹26.4L</p>
              <p class="text-xs text-green-600 mt-0.5">▲ 2.1% vs last</p>
            </div>
            <div class="bg-white p-3.5 rounded-xl border border-gray-100 shadow-sm">
              <p class="text-xs text-gray-400 font-medium">PF Liability</p>
              <p class="text-xl font-bold text-gray-900 mt-0.5">₹3.75L</p>
              <p class="text-xs text-gray-400 mt-0.5">Due 15 Apr</p>
            </div>
            <div class="bg-white p-3.5 rounded-xl border border-gray-100 shadow-sm">
              <p class="text-xs text-gray-400 font-medium">Leave Pending</p>
              <p class="text-xl font-bold text-gray-900 mt-0.5">5</p>
              <p class="text-xs text-amber-600 mt-0.5">Needs approval</p>
            </div>
          </div>
          <%# Payroll row %>
          <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
            <div class="px-4 py-3 border-b border-gray-50 flex items-center justify-between">
              <span class="text-xs font-semibold text-gray-700">Recent Payslips — March 2026</span>
              <span class="text-xs text-indigo-600 font-medium">View all →</span>
            </div>
            <table class="w-full text-xs">
              <thead class="bg-gray-50">
                <tr>
                  <th class="text-left px-4 py-2 text-gray-400 font-medium">Employee</th>
                  <th class="text-right px-4 py-2 text-gray-400 font-medium">Gross</th>
                  <th class="text-right px-4 py-2 text-gray-400 font-medium">PF</th>
                  <th class="text-right px-4 py-2 text-gray-400 font-medium">TDS</th>
                  <th class="text-right px-4 py-2 text-gray-400 font-medium">Net Pay</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-50">
                <tr>
                  <td class="px-4 py-2.5 font-medium text-gray-800">Amit Sharma</td>
                  <td class="px-4 py-2.5 text-right text-gray-600">₹77,826</td>
                  <td class="px-4 py-2.5 text-right text-gray-600">₹1,800</td>
                  <td class="px-4 py-2.5 text-right text-gray-600">₹2,962</td>
                  <td class="px-4 py-2.5 text-right font-semibold text-gray-900">₹72,864</td>
                </tr>
                <tr>
                  <td class="px-4 py-2.5 font-medium text-gray-800">Sneha Patel</td>
                  <td class="px-4 py-2.5 text-right text-gray-600">₹55,200</td>
                  <td class="px-4 py-2.5 text-right text-gray-600">₹1,800</td>
                  <td class="px-4 py-2.5 text-right text-gray-600">₹1,140</td>
                  <td class="px-4 py-2.5 text-right font-semibold text-gray-900">₹51,860</td>
                </tr>
                <tr>
                  <td class="px-4 py-2.5 font-medium text-gray-800">Ravi Kumar</td>
                  <td class="px-4 py-2.5 text-right text-gray-600">₹42,000</td>
                  <td class="px-4 py-2.5 text-right text-gray-600">₹1,800</td>
                  <td class="px-4 py-2.5 text-right text-gray-600">₹350</td>
                  <td class="px-4 py-2.5 text-right font-semibold text-gray-900">₹39,650</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
