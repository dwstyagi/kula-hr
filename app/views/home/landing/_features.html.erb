<%# ── Features ── %>
<div id="features" class="bg-white py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="sr mx-auto max-w-2xl text-center">
      <p class="text-base font-semibold leading-7 text-kula-600">Everything in one platform</p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight text-stone-900 sm:text-4xl">
        From onboarding to payslip — done.
      </h2>
      <p class="mt-6 text-lg leading-8 text-stone-600">
        Kula HR replaces spreadsheets, tally adjustments, and manual bank transfers with a single, compliant workflow built for Indian companies.
      </p>
    </div>
    <div class="mx-auto mt-16 max-w-2xl sm:mt-20 lg:mt-24 lg:max-w-none">
      <dl class="sr-stagger grid max-w-xl grid-cols-1 gap-x-8 gap-y-10 lg:max-w-none lg:grid-cols-3">
        <% [
          { color: "indigo", title: "Employee Management",
            icon: "M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5zm6-10.125a1.875 1.875 0 11-3.75 0 1.875 1.875 0 013.75 0zm1.294 6.336a6.721 6.721 0 01-3.17.789 6.721 6.721 0 01-3.168-.789 3.376 3.376 0 016.338 0z",
            desc: "Full employee lifecycle — CRUD, bulk CSV/Excel import, department and designation management, invite flow, and export. All scoped to your company." },
          { color: "indigo", title: "Salary Structures & CTC",
            icon: "M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z",
            desc: "Configure CTC-based salary structures with Indian components — Basic (40%), HRA (50% of Basic), Special Allowance (balancing). Auto-calculate breakup from CTC in real time." },
          { color: "indigo", title: "Leave & Attendance",
            icon: "M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5",
            desc: "Configurable leave types (CL, SL, EL), approval workflows, auto leave-balance deduction, attendance summaries, LOP calculation, and template upload — all feeding directly into payroll." },
          { color: "violet", title: "One-click Payroll Processing",
            icon: "M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z",
            desc: "Initiate payroll for the month. System calculates gross, PF, ESI, PT, and TDS for every employee, handles LOP proration, and generates payslips — all in the background via Sidekiq." },
          { color: "violet", title: "Bank File Generation",
            icon: "M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z",
            desc: "Download a salary transfer file formatted for your bank — HDFC, ICICI, SBI, or a generic CSV. Upload directly to your corporate net banking and salaries are on their way." },
          { color: "violet", title: "Statutory Reports",
            icon: "M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z",
            desc: "Generate PF ECR files, ESI contribution statements, PT challans, and YTD earnings reports in the exact format required for filing. No more manual Excel work." },
        ].each do |f| %>
          <div class="feat-card sr-c flex flex-col bg-white p-8 rounded-2xl shadow-sm border border-stone-100">
            <dt class="flex items-center gap-x-3 text-base font-semibold leading-7 text-stone-900">
              <div class="h-10 w-10 flex items-center justify-center rounded-lg <%= f[:color] == "violet" ? "bg-marigold-500" : "bg-kula-600" %> text-white shrink-0">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="<%= f[:icon] %>" />
                </svg>
              </div>
              <%= f[:title] %>
            </dt>
            <dd class="mt-4 flex flex-auto flex-col text-base leading-7 text-stone-600">
              <p class="flex-auto"><%= f[:desc] %></p>
            </dd>
          </div>
        <% end %>
      </dl>
    </div>
  </div>
</div>
