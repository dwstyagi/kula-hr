<%# ── Hero ── %>
<div class="relative isolate pt-14 overflow-hidden">
  <%# Background gradient blobs %>
  <div class="absolute inset-x-0 -top-40 -z-10 transform-gpu overflow-hidden blur-3xl sm:-top-80" aria-hidden="true">
    <div class="blob-a relative left-[calc(50%-11rem)] aspect-1155/678 w-144.5 -translate-x-1/2 rotate-30 bg-linear-to-tr from-[#818cf8] to-[#6366f1] opacity-20 sm:left-[calc(50%-30rem)] sm:w-288.75"
      style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)">
    </div>
  </div>
  <div class="py-24 sm:py-32 lg:pb-40">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <%# India badge %>
        <div class="hero-reveal d0 mb-6 flex justify-center">
          <span class="inline-flex items-center gap-2 rounded-full bg-indigo-50 px-4 py-1.5 text-sm font-medium text-indigo-700 ring-1 ring-inset ring-indigo-700/20">
            🇮🇳 Built for Indian companies
          </span>
        </div>
        <h1 class="hero-reveal d1 text-4xl font-bold tracking-tight text-gray-900 sm:text-6xl">
          Payroll & HR for<br/>
          <span class="text-transparent bg-clip-text bg-linear-to-r from-indigo-600 to-violet-600">growing Indian teams</span>
        </h1>
        <p class="hero-reveal d2 mt-6 text-lg leading-8 text-gray-600 max-w-2xl mx-auto">
          Run compliant payroll in minutes. Automate PF, ESI, Professional Tax, and TDS. Generate payslips, bank files, and statutory reports — all from one platform.
        </p>
        <div class="hero-reveal d3 mt-10 flex items-center justify-center gap-x-6 flex-wrap gap-y-4">
          <a href="<%= signup_path %>" class="btn-cta rounded-lg bg-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition hover:shadow-lg">
            Start free trial — no credit card
          </a>
          <a href="#how-it-works" class="text-sm font-semibold leading-6 text-gray-900 flex items-center gap-1 hover:text-indigo-600 transition">
            See how it works <span aria-hidden="true">→</span>
          </a>
        </div>
        <p class="hero-reveal d4 mt-4 text-xs text-gray-400">1 free payroll run · up to 25 employees · No credit card</p>
      </div>
      <%= render "home/landing/hero_dashboard" %>
    </div>
  </div>
  <div class="absolute inset-x-0 top-[calc(100%-13rem)] -z-10 transform-gpu overflow-hidden blur-3xl sm:top-[calc(100%-30rem)]" aria-hidden="true">
    <div class="blob-b relative left-[calc(50%+3rem)] aspect-1155/678 w-144.5 -translate-x-1/2 bg-linear-to-tr from-[#818cf8] to-[#6366f1] opacity-20 sm:left-[calc(50%+36rem)] sm:w-288.75"
      style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)">
    </div>
  </div>
</div>
