<%# ── Two portals, one platform ── %>
<div id="portals" class="bg-white py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="sr mx-auto max-w-2xl text-center mb-16">
      <p class="text-base font-semibold leading-7 text-indigo-600">Built for everyone in your company</p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Two portals, one platform</h2>
      <p class="mt-6 text-lg leading-8 text-gray-600">
        HR runs payroll and compliance from the admin console. Your team gets a self-service portal of their own. Same login, role-based access — nothing to install.
      </p>
    </div>

    <div class="sr-stagger mx-auto grid max-w-2xl grid-cols-1 gap-8 lg:max-w-none lg:grid-cols-2">
      <%# HR & Admin portal %>
      <div class="feat-card sr-c flex flex-col rounded-3xl bg-white p-8 shadow-sm border border-gray-100">
        <div class="flex items-center gap-x-4">
          <div class="h-12 w-12 flex items-center justify-center rounded-xl bg-indigo-600 text-white shrink-0">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12M3 7.5h12M3 12h12" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-gray-900">For HR &amp; Admins</h3>
            <p class="text-sm text-gray-500"><code class="text-xs bg-gray-100 px-1.5 py-0.5 rounded text-gray-600">yourcompany.<%= @app_domain %>/admin</code></p>
          </div>
        </div>
        <p class="mt-5 text-sm leading-6 text-gray-600">Everything to run payroll and stay compliant — from onboarding to bank transfer.</p>
        <ul class="mt-6 space-y-3.5 text-sm text-gray-700">
          <% [
            [ "Employee management", "Onboard, bulk-import via CSV, manage departments & designations" ],
            [ "Salary structures", "CTC-based with auto Basic / HRA / Special allowance breakup" ],
            [ "One-click payroll", "PF, ESI, PT & TDS auto-calculated, with LOP proration" ],
            [ "Leave & attendance", "Approve requests, set holidays, lock the month" ],
            [ "Payslips & bank files", "PDF payslips plus HDFC / ICICI / SBI transfer files" ],
            [ "Statutory reports", "PF ECR, ESI, PT challan and YTD earnings — filing-ready" ],
            [ "Company announcements", "Publish news & events, and track who has read them" ],
          ].each do |title, desc| %>
            <li class="flex items-start gap-3">
              <svg class="h-5 w-5 flex-none text-indigo-600 mt-0.5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
              </svg>
              <span><span class="font-semibold text-gray-900"><%= title %>.</span> <%= desc %></span>
            </li>
          <% end %>
        </ul>
        <a href="<%= signup_path %>" class="mt-8 inline-flex items-center gap-1 text-sm font-semibold text-indigo-600 hover:text-indigo-500 transition">
          Start free trial <span aria-hidden="true">→</span>
        </a>
      </div>

      <%# Employee portal %>
      <div class="feat-card sr-c flex flex-col rounded-3xl bg-white p-8 shadow-sm border border-gray-100">
        <div class="flex items-center gap-x-4">
          <div class="h-12 w-12 flex items-center justify-center rounded-xl bg-violet-600 text-white shrink-0">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-gray-900">For your Employees</h3>
            <p class="text-sm text-gray-500"><code class="text-xs bg-gray-100 px-1.5 py-0.5 rounded text-gray-600">yourcompany.<%= @app_domain %>/portal</code></p>
          </div>
        </div>
        <p class="mt-5 text-sm leading-6 text-gray-600">Self-service for your whole team — no more emailing HR for payslips.</p>
        <ul class="mt-6 space-y-3.5 text-sm text-gray-700">
          <% [
            [ "Payslips", "View & download PDFs, with 12-month history and YTD summary" ],
            [ "Leave", "Apply, track approval status, and check balances anytime" ],
            [ "Tax declarations", "Submit Old or New Regime with full investment details" ],
            [ "Announcements", "Read company news, with unread indicators for updates" ],
            [ "Team views", "Managers approve their team's leave and see the calendar" ],
            [ "Profile", "Keep personal and bank details up to date" ],
          ].each do |title, desc| %>
            <li class="flex items-start gap-3">
              <svg class="h-5 w-5 flex-none text-violet-600 mt-0.5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
              </svg>
              <span><span class="font-semibold text-gray-900"><%= title %>.</span> <%= desc %></span>
            </li>
          <% end %>
        </ul>
        <p class="mt-8 text-sm font-medium text-gray-400">Included free with every plan · unlimited employees</p>
      </div>
    </div>
  </div>
</div>
