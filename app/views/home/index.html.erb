    <div class="flex lg:flex-1">
      <a href="/" class="-m-1.5 p-1.5 flex items-center gap-2">
        <span class="sr-only"><%= t('app_name') %></span>
        <div class="h-8 w-8 rounded-lg bg-indigo-600 flex items-center justify-center text-white font-bold text-lg">K</div>
        <span class="font-bold text-xl tracking-tight text-gray-900"><%= t('app_name') %></span>
      </a>
    </div>
    <div class="flex lg:hidden">
      <button type="button" id="mobile-menu-btn" class="-m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-gray-700">
        <span class="sr-only">Open main menu</span>
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
    <div class="hidden lg:flex lg:gap-x-10">
      <a href="#features"  class="text-sm font-semibold leading-6 text-gray-700 hover:text-indigo-600 transition">Features</a>
      <a href="#how-it-works" class="text-sm font-semibold leading-6 text-gray-700 hover:text-indigo-600 transition">How it works</a>
      <a href="#pricing"   class="text-sm font-semibold leading-6 text-gray-700 hover:text-indigo-600 transition">Pricing</a>
    </div>
    <div class="hidden lg:flex lg:flex-1 lg:justify-end gap-x-4 items-center">
      <a href="#login-prompt" class="text-sm font-semibold leading-6 text-gray-700 hover:text-indigo-600 transition py-2">Log in</a>
      <a href="<%= signup_path %>" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition">
        Start free trial
      </a>
    </div>
  </nav>
</header>

<main>
