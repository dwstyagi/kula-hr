<style>
  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(22px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .reveal { opacity: 0; animation: fadeSlideUp 0.65s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  .rv-1 { animation-delay: 0.05s; }
  .rv-2 { animation-delay: 0.15s; }
  .rv-3 { animation-delay: 0.25s; }

  #site-header { transition: background 0.3s ease, box-shadow 0.3s ease; }
  #site-header.scrolled {
    background: rgba(255,255,255,0.85);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow: 0 1px 0 rgba(0,0,0,0.07), 0 2px 12px rgba(0,0,0,0.05);
  }
  .nav-link { position: relative; padding-bottom: 2px; }
  .nav-link::after {
    content: ''; position: absolute; bottom: 0; left: 0;
    width: 0; height: 1.5px; background: #4f46e5; transition: width 0.24s ease;
  }
  .nav-link:hover::after { width: 100%; }

  .form-field {
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .form-field:focus {
    outline: none;
    border-color: #6366f1;
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.12);
  }
  .btn-cta { position: relative; overflow: hidden; }
  .btn-cta::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.2) 50%, transparent 60%);
    transform: translateX(-100%); transition: transform 0.5s ease;
  }
  .btn-cta:hover::after { transform: translateX(100%); }
</style>

<%# Navigation %>
<header id="site-header" class="fixed inset-x-0 top-0 z-50">
  <nav class="flex items-center justify-between p-6 lg:px-8" aria-label="Global">
    <div class="flex lg:flex-1">
      <a href="<%= root_path %>" class="-m-1.5 p-1.5 flex items-center gap-2">
        <div class="h-8 w-8 rounded-lg bg-indigo-600 flex items-center justify-center text-white font-bold text-lg">K</div>
        <span class="font-bold text-xl tracking-tight text-gray-900"><%= t('app_name') %></span>
      </a>
    </div>
    <div class="hidden lg:flex lg:gap-x-10">
      <a href="<%= root_path %>#features"     class="nav-link text-sm font-semibold leading-6 text-gray-700 hover:text-indigo-600 transition">Features</a>
      <a href="<%= root_path %>#how-it-works" class="nav-link text-sm font-semibold leading-6 text-gray-700 hover:text-indigo-600 transition">How it works</a>
      <a href="<%= root_path %>#pricing"      class="nav-link text-sm font-semibold leading-6 text-gray-700 hover:text-indigo-600 transition">Pricing</a>
      <a href="<%= contact_path %>"           class="nav-link text-sm font-semibold leading-6 text-indigo-600 transition">Contact</a>
    </div>
    <div class="hidden lg:flex lg:flex-1 lg:justify-end gap-x-4 items-center">
      <a href="<%= root_path %>#login-prompt" class="nav-link text-sm font-semibold leading-6 text-gray-700 hover:text-indigo-600 transition py-2">Log in</a>
      <a href="<%= signup_path %>" class="btn-cta rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition">
        Start free trial
      </a>
    </div>
  </nav>
</header>

<main class="pt-14 min-h-screen bg-white">
  <%# Background decoration %>
  <div class="absolute inset-x-0 top-0 -z-10 overflow-hidden blur-3xl" aria-hidden="true">
    <div class="relative left-[calc(50%-11rem)] aspect-1155/678 w-144.5 -translate-x-1/2 rotate-30 bg-linear-to-tr from-[#818cf8] to-[#6366f1] opacity-10 sm:left-[calc(50%-30rem)] sm:w-288.75"
      style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)">
    </div>
  </div>

  <div class="mx-auto max-w-2xl px-6 py-24 sm:py-32 lg:px-8">
    <%# Header %>
    <div class="reveal rv-1 text-center mb-12">
      <div class="mb-4 flex justify-center">
        <span class="inline-flex items-center gap-2 rounded-full bg-indigo-50 px-4 py-1.5 text-sm font-medium text-indigo-700 ring-1 ring-inset ring-indigo-700/20">
          Get in touch
        </span>
      </div>
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">Contact us</h1>
      <p class="mt-4 text-lg text-gray-500">Have a question or want to know more about Kula HR? Send us a message and we'll get back to you.</p>
    </div>

    <%# Contact form card %>
    <div class="reveal rv-2 bg-white rounded-2xl shadow-sm border border-gray-100 p-8 sm:p-10">
      <%= form_with url: contact_path, method: :post, local: true do |f| %>
        <div class="space-y-6">
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
            <div>
              <%= f.label :name, "Your name", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
              <%= f.text_field :name,
                    value: @name,
                    placeholder: "Amit Sharma",
                    class: "form-field w-full rounded-lg border border-gray-200 bg-gray-50 px-4 py-2.5 text-sm text-gray-900 placeholder-gray-400",
                    required: true %>
            </div>
            <div>
              <%= f.label :email, "Email address", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
              <%= f.email_field :email,
                    value: @email,
                    placeholder: "amit@acmecorp.in",
                    class: "form-field w-full rounded-lg border border-gray-200 bg-gray-50 px-4 py-2.5 text-sm text-gray-900 placeholder-gray-400",
                    required: true %>
            </div>
          </div>

          <div>
            <%= f.label :message, "Message", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
            <%= f.text_area :message,
                  rows: 6,
                  placeholder: "Tell us about your company, team size, or any questions you have...",
                  class: "form-field w-full rounded-lg border border-gray-200 bg-gray-50 px-4 py-2.5 text-sm text-gray-900 placeholder-gray-400 resize-none",
                  required: true do %>
<%= @message %><% end %>
          </div>

          <div class="flex items-center justify-between gap-4 flex-wrap">
            <p class="text-xs text-gray-400">We usually respond within 1 business day.</p>
            <%= f.submit "Send message →",
                  class: "btn-cta cursor-pointer rounded-lg bg-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition hover:shadow-md" %>
          </div>
        </div>
      <% end %>
    </div>

    <%# Alternative contact + social links %>
    <div class="reveal rv-3 mt-10 text-center space-y-4">
      <p class="text-sm text-gray-500">
        Prefer email? Reach us at
        <a href="mailto:hello@kulahr.com" class="text-indigo-600 hover:text-indigo-500 font-medium transition">hello@kulahr.com</a>
      </p>
      <div class="flex items-center justify-center gap-3">
        <span class="text-sm text-gray-400">Connect with us:</span>
        <a href="https://www.linkedin.com/in/diwanshu-tyagi" target="_blank" rel="noopener noreferrer"
           class="text-gray-400 hover:text-indigo-600 transition flex items-center gap-1.5 text-sm font-medium">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
        <span class="text-gray-300">·</span>
        <a href="https://www.github.com/dwstyagi" target="_blank" rel="noopener noreferrer"
           class="text-gray-400 hover:text-gray-900 transition flex items-center gap-1.5 text-sm font-medium">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
          </svg>
          GitHub
        </a>
      </div>
      <p class="text-sm text-gray-400">
        ← <a href="<%= root_path %>" class="text-indigo-600 hover:text-indigo-500 transition">Back to home</a>
      </p>
    </div>
  </div>
</main>

<script>
  var header = document.getElementById('site-header');
  if (header) {
    window.addEventListener('scroll', function() {
      header.classList.toggle('scrolled', window.scrollY > 24);
    }, { passive: true });
  }
</script>
