<aside class="w-64 h-full bg-kula-950 flex flex-col">
  <div class="px-5 pt-6 pb-5">
    <%= link_to platform_admin_root_path, class: "flex items-center gap-2.5" do %>
      <div class="size-8 rounded-lg bg-marigold-400 flex items-center justify-center text-kula-950 font-extrabold text-lg">K</div>
      <span class="font-bold text-lg text-white tracking-tight">Kula HR</span>
    <% end %>
    <p class="mt-2 text-xs font-medium text-marigold-300/80 uppercase tracking-widest">Platform Admin</p>
  </div>

  <nav class="flex-1 overflow-y-auto px-3 pb-4 space-y-0.5">
    <%= nav_link "Dashboard", platform_admin_root_path, icon: :dashboard, exact: true %>
    <%= nav_link "Tenants", platform_admin_tenants_path, icon: :building %>
    <%= link_to "/platform_admin/sidekiq", target: "_blank", class: "nav-item" do %>
      <%= nav_icon :refresh %>
      <span class="flex-1">Sidekiq</span>
      <svg class="size-3.5 opacity-50" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
      </svg>
    <% end %>
  </nav>

  <div class="p-3 border-t border-white/10">
    <%= button_to platform_admin_logout_path, method: :delete, class: "nav-item w-full" do %>
      <%= nav_icon :logout %>
      Log out
    <% end %>
  </div>
</aside>
