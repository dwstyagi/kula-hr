<aside class="fixed inset-y-0 left-0 w-64 bg-gray-900 text-white flex flex-col">
  <div class="p-6">
    <div class="flex items-center gap-2">
      <div class="h-8 w-8 rounded bg-blue-600 flex items-center justify-center font-bold text-lg">K</div>
      <span class="font-bold text-lg">Kula HR</span>
    </div>
    <p class="text-xs text-gray-400 mt-1">Platform Admin</p>
  </div>

  <nav class="flex-1 px-4 space-y-1">
    <%= link_to platform_admin_root_path,
        class: "flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium #{current_page?(platform_admin_root_path) ? 'bg-gray-800 text-white' : 'text-gray-300 hover:bg-gray-800 hover:text-white'}" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
      </svg>
      Dashboard
    <% end %>

    <%= link_to platform_admin_tenants_path,
        class: "flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium #{current_page?(platform_admin_tenants_path) ? 'bg-gray-800 text-white' : 'text-gray-300 hover:bg-gray-800 hover:text-white'}" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
      </svg>
      Tenants
    <% end %>
  </nav>

  <div class="p-4 border-t border-gray-800">
    <%= button_to platform_admin_logout_path, method: :delete,
        class: "flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-gray-300 hover:bg-gray-800 hover:text-white w-full" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
      </svg>
      Logout
    <% end %>
  </div>
</aside>
