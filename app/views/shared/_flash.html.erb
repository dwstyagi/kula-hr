<% flash.each do |type, message| %>
  <% variant = type.to_s == "notice" ? "alert-success" : "alert-error" %>
  <div data-controller="flash" data-flash-target="message"
       class="alert <%= variant %> fixed top-4 right-4 z-50 max-w-sm w-full shadow-lg"
       role="alert">
    <p class="flex-1 text-sm font-medium"><%= message %></p>
    <button data-action="flash#dismiss" class="shrink-0 opacity-60 hover:opacity-100 transition-opacity" aria-label="Dismiss">
      <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>
<% end %>
