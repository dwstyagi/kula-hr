<% flash.each do |type, message| %>
  <% color = type == "notice" ? "green" : "red" %>
  <div data-controller="flash" data-flash-target="message"
       class="fixed top-4 right-4 z-50 max-w-sm w-full bg-<%= color %>-50 border border-<%= color %>-200 rounded-lg p-4 shadow-lg"
       role="alert">
    <div class="flex items-start">
      <div class="flex-1">
        <p class="text-sm font-medium text-<%= color %>-800"><%= message %></p>
      </div>
      <button data-action="flash#dismiss" class="ml-3 text-<%= color %>-400 hover:text-<%= color %>-600">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>
<% end %>
