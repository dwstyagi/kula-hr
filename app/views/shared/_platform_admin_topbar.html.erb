<header class="bg-white border-b border-stone-200 px-4 md:px-8 h-14 flex items-center justify-between gap-4">
  <h1 class="text-[15px] font-semibold text-stone-900 tracking-tight truncate"><%= content_for(:page_title).presence || controller.controller_name.titleize %></h1>
  <div class="flex items-center gap-3">
    <time class="code hidden sm:block" datetime="<%= Date.current.iso8601 %>"><%= Date.current.strftime("%d %b %Y") %></time>
    <% if current_platform_admin %>
      <span class="text-sm font-medium text-stone-600"><%= current_platform_admin.full_name %></span>
    <% end %>
  </div>
</header>
