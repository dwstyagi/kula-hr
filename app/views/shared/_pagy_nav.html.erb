<% prev_url = pagy.page_url(:previous) %>
<% next_url = pagy.page_url(:next) %>

<nav class="flex items-center gap-1" aria-label="Pagination">
  <%# Previous %>
  <% if prev_url %>
    <%= link_to prev_url,
        class: "inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium rounded-md text-stone-600 hover:bg-stone-100 hover:text-stone-900 transition-colors",
        rel: "prev", aria: { label: "Previous page" } do %>
      <svg class="size-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
      </svg>
      Prev
    <% end %>
  <% else %>
    <span class="inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium rounded-md text-stone-300 cursor-not-allowed select-none">
      <svg class="size-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
      </svg>
      Prev
    </span>
  <% end %>

  <%# Page items %>
  <% pagy_series(pagy).each do |item| %>
    <% case item %>
    <% when Integer %>
      <%= link_to item, pagy.page_url(item),
          class: "amount inline-flex items-center justify-center size-9 text-sm font-medium rounded-md text-stone-600 hover:bg-stone-100 hover:text-stone-900 transition-colors",
          aria: { label: "Page #{item}" } %>
    <% when String %>
      <span class="amount inline-flex items-center justify-center size-9 text-sm font-semibold rounded-md bg-kula-700 text-white" aria-current="page">
        <%= item %>
      </span>
    <% when :gap %>
      <span class="inline-flex items-center justify-center size-9 text-sm text-stone-400 select-none">&hellip;</span>
    <% end %>
  <% end %>

  <%# Next %>
  <% if next_url %>
    <%= link_to next_url,
        class: "inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium rounded-md text-stone-600 hover:bg-stone-100 hover:text-stone-900 transition-colors",
        rel: "next", aria: { label: "Next page" } do %>
      Next
      <svg class="size-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
      </svg>
    <% end %>
  <% else %>
    <span class="inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium rounded-md text-stone-300 cursor-not-allowed select-none">
      Next
      <svg class="size-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
      </svg>
    </span>
  <% end %>
</nav>
