<aside class="w-64 h-full bg-kula-950 flex flex-col">
  <div class="px-5 pt-6 pb-5">
    <%= link_to employee_portal_root_path, class: "flex items-center gap-2.5" do %>
      <div class="size-8 rounded-lg bg-marigold-400 flex items-center justify-center text-kula-950 font-extrabold text-lg">K</div>
      <span class="font-bold text-lg text-white tracking-tight">Kula HR</span>
    <% end %>
    <% if ActsAsTenant.current_tenant %>
      <p class="mt-2 text-xs font-medium text-kula-300/60 truncate"><%= ActsAsTenant.current_tenant.name %></p>
    <% end %>
  </div>

  <nav class="flex-1 overflow-y-auto px-3 pb-4 space-y-0.5">
    <%= nav_link "Dashboard", employee_portal_root_path, icon: :dashboard, exact: true %>
    <%= nav_link "My Leaves", employee_portal_leave_requests_path, icon: :calendar %>
    <%= nav_link "Team Calendar", employee_portal_team_calendar_path, icon: :calendar_days %>

    <% if current_employee %>
      <% unread_announcements = Announcement.published.where.not(id: current_employee.announcement_reads.select(:announcement_id)).count %>
      <%= nav_link "Announcements", employee_portal_announcements_path, icon: :megaphone, count: unread_announcements %>

      <% if current_employee.direct_reports.exists? %>
        <%= nav_link "My Team's Leaves", employee_portal_team_leave_requests_path, icon: :users %>
      <% end %>

      <div class="pt-5 pb-1"><p class="nav-label">Money &amp; Tax</p></div>
      <%= nav_link "My Payslips", employee_portal_payslips_path, icon: :banknote %>
      <%= nav_link "Tax Declaration", employee_portal_tax_declaration_path, icon: :receipt %>

      <div class="pt-5 pb-1"><p class="nav-label">Account</p></div>
      <%= nav_link "My Profile", employee_portal_profile_path, icon: :user %>
    <% end %>
  </nav>

  <div class="p-3 border-t border-white/10">
    <div class="flex items-center gap-3 px-2 py-2">
      <%= avatar_chip current_user&.full_name, dark: true %>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-semibold text-white truncate"><%= current_user&.full_name %></p>
        <p class="text-xs text-kula-300/60 truncate"><%= current_user&.email %></p>
      </div>
    </div>
    <%= button_to destroy_user_session_path, method: :delete, class: "nav-item w-full" do %>
      <%= nav_icon :logout %>
      Log out
    <% end %>
  </div>
</aside>
