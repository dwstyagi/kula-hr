<aside class="w-64 h-screen bg-kula-950 flex flex-col">
  <div class="px-5 pt-6 pb-5">
    <%= link_to admin_root_path, class: "flex items-center gap-2.5" do %>
      <div class="size-8 rounded-lg bg-marigold-400 flex items-center justify-center text-kula-950 font-extrabold text-lg">K</div>
      <span class="font-bold text-lg text-white tracking-tight">Kula HR</span>
    <% end %>
    <% if ActsAsTenant.current_tenant %>
      <p class="mt-2 text-xs font-medium text-kula-300/60 truncate"><%= ActsAsTenant.current_tenant.name %></p>
    <% end %>
  </div>

  <nav class="flex-1 overflow-y-auto px-3 pb-4 space-y-0.5">
    <%= nav_link "Dashboard", admin_root_path, icon: :dashboard, exact: true %>
    <%= nav_link "Employees", admin_employees_path, icon: :users %>
    <%= nav_link "Departments", admin_departments_path, icon: :building %>
    <%= nav_link "Designations", admin_designations_path, icon: :briefcase %>
    <%= nav_link "Announcements", admin_announcements_path, icon: :megaphone %>

    <div class="pt-5 pb-1"><p class="nav-label">Leave &amp; Attendance</p></div>
    <%= nav_link "Leave Requests", admin_leave_requests_path, icon: :clipboard_check, count: @pending_leave_count %>
    <%= nav_link "Leave Calendar", admin_leave_calendar_path, icon: :calendar_days %>
    <%= nav_link "Leave Types", admin_leave_types_path, icon: :layers %>
    <%= nav_link "Holidays", admin_holidays_path, icon: :calendar %>
    <%= nav_link "Attendance", admin_attendance_summaries_path, icon: :chart %>
    <%= nav_link "Work Locations", admin_work_locations_path, icon: :map_pin %>

    <div class="pt-5 pb-1"><p class="nav-label">Payroll</p></div>
    <%= nav_link "Payroll Runs", admin_payroll_runs_path, icon: :banknote %>
    <%= nav_link "Salary Structures", admin_salary_structures_path, icon: :calculator %>
    <%= nav_link "Salary Components", admin_salary_components_path, icon: :receipt %>
    <%= nav_link "Reports", admin_reports_path, icon: :document %>
    <%= nav_link "Payroll Settings", admin_payroll_setting_path, icon: :cog %>

    <% if current_user&.has_role?(:super_admin) %>
      <div class="pt-5 pb-1"><p class="nav-label">Settings</p></div>
      <%= nav_link "Company Profile", admin_company_profile_path, icon: :identification %>
      <%= nav_link "Admin Users", admin_admin_users_path, icon: :shield %>
    <% end %>
  </nav>

  <div class="p-3 border-t border-white/10">
    <div class="flex items-center gap-3 px-2 py-2">
      <%= avatar_chip current_user&.full_name, dark: true %>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-semibold text-white truncate"><%= current_user&.full_name %></p>
        <p class="text-xs text-kula-300/60 truncate"><%= current_user&.email %></p>
      </div>
    </div>
    <%= button_to destroy_user_session_path, method: :delete, class: "nav-item w-full" do %>
      <%= nav_icon :logout %>
      Log out
    <% end %>
  </div>
</aside>
