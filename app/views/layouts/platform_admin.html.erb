<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Platform Admin - Kula HR" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartkick@5.0.1/dist/chartkick.min.js"></script>
  </head>
  <body class="bg-gray-50">
    <%= render "shared/flash" %>

    <div data-controller="sidebar">
      <%# Mobile topbar with hamburger %>
      <div class="md:hidden fixed top-0 left-0 right-0 z-30 bg-gray-900 px-4 py-3 flex items-center gap-3">
        <button data-action="sidebar#toggle" class="p-1 rounded-lg hover:bg-gray-700">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
        <span class="font-bold text-white">Kula HR — Platform</span>
      </div>

      <%# Overlay %>
      <div data-sidebar-target="overlay" data-action="click->sidebar#close" class="hidden md:hidden fixed inset-0 z-30 bg-black/50"></div>

      <%# Sidebar %>
      <div data-sidebar-target="sidebar" class="-translate-x-full md:translate-x-0 transition-transform duration-200 z-40 fixed inset-y-0 left-0">
        <%= render "shared/platform_admin_sidebar" %>
      </div>

      <div class="md:ml-64 pt-14 md:pt-0">
        <%= render "shared/platform_admin_topbar" %>
        <main class="p-4 md:p-6">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
