<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Admin - Kula HR" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/date-fns@3.3.1/cdn.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartkick@5.0.1/dist/chartkick.min.js"></script>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-gray-50" data-controller="tooltip">
    <div data-controller="notifications"></div>
    <%= render "shared/flash" %>
    <%= render "shared/admin_sidebar" %>

    <div class="ml-64">
      <%= render "shared/admin_topbar" %>
      <% if ActsAsTenant.current_tenant&.trial? %>
        <div class="bg-amber-50 border-b border-amber-200 px-6 py-2 text-sm text-amber-800 flex items-center justify-between">
          <span>
            <strong>You're on a Kula trial.</strong> Some features are limited on trial accounts.
          </span>
          <a href="mailto:support@kulahrms.com" class="font-medium underline">Upgrade →</a>
        </div>
      <% end %>
      <main class="p-6">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
