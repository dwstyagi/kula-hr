<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Admin - Kula HR" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <meta name="view-transition" content="same-origin">    <%= csp_meta_tag %>
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= render "shared/fonts" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/date-fns@3.3.1/cdn.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartkick@5.0.1/dist/chartkick.min.js"></script>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-stone-50 text-stone-900 antialiased" data-controller="tooltip">
    <div data-controller="notifications"></div>
    <%= render "shared/flash" %>

    <div data-controller="sidebar">
      <%# Mobile topbar with hamburger %>
      <div class="md:hidden fixed top-0 left-0 right-0 z-30 bg-kula-950 px-4 py-3 flex items-center gap-3">
        <button data-action="sidebar#toggle" class="p-1 rounded-lg text-kula-100 hover:bg-white/10" aria-label="Open menu">
          <svg class="size-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
        <span class="font-bold text-white">Kula HR</span>
      </div>

      <%# Overlay %>
      <div data-sidebar-target="overlay" data-action="click->sidebar#close" class="hidden md:hidden fixed inset-0 z-30 bg-black/50"></div>

      <%# Sidebar %>
      <div data-sidebar-target="sidebar" class="-translate-x-full md:translate-x-0 transition-transform duration-200 z-40 fixed inset-y-0 left-0">
        <%= render "shared/admin_sidebar" %>
      </div>

      <div class="md:ml-64 pt-14 md:pt-0">
        <%= render "shared/admin_topbar" %>
        <% if (t = ActsAsTenant.current_tenant)&.trial? %>
          <div class="bg-marigold-50 border-b border-marigold-200 px-4 md:px-8 py-2 text-sm text-marigold-800 flex items-center justify-between gap-4">
            <span>
              <strong>Trial account</strong> —
              <span class="amount"><%= t.trial_payroll_runs_used %> / <%= Tenant::TRIAL_PAYROLL_RUN_LIMIT %></span> payroll runs used.
              All features included. Upgrade before your trial ends.
            </span>
            <a href="mailto:support@kula-hr.com" class="font-semibold underline underline-offset-2 whitespace-nowrap">Upgrade →</a>
          </div>
        <% end %>
        <main class="p-4 md:p-8 max-w-[1440px]">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
