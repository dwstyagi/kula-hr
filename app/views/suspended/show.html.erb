<div class="min-h-screen bg-stone-50 flex flex-col items-center justify-center px-4">
  <div class="max-w-md w-full text-center">

    <%# Icon %>
    <div class="mx-auto mb-6 h-20 w-20 rounded-full bg-red-100 flex items-center justify-center">
      <svg class="h-10 w-10 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
      </svg>
    </div>

    <%# Heading %>
    <h1 class="page-title text-2xl">Account Suspended</h1>
    <p class="mt-3 text-stone-500 leading-relaxed">
      The account for <span class="font-medium text-stone-700"><%= @tenant&.name %></span>
      has been suspended. You have been signed out.
    </p>

    <%# Reason block %>
    <div class="mt-6 rounded-lg bg-red-50 border border-red-200 px-6 py-4 text-left">
      <p class="text-sm font-medium text-red-800">What does this mean?</p>
      <ul class="mt-2 text-sm text-red-700 space-y-1 list-disc list-inside">
        <li>All access to your company's HR portal has been paused.</li>
        <li>No data has been deleted.</li>
        <li>Access will be restored once the suspension is lifted.</li>
      </ul>
    </div>

    <%# CTA %>
    <p class="mt-6 text-sm text-stone-500">
      Please contact
      <a href="mailto:support@kulahr.com" class="font-medium text-kula-700 hover:underline">support@kulahr.com</a>
      to resolve this.
    </p>

    <%# Back link %>
    <div class="mt-8">
      <%= link_to "Go to Kula HR Home",
            root_url(subdomain: nil),
            allow_other_host: true,
            class: "inline-flex items-center gap-2 text-sm text-stone-500 hover:text-stone-700" %>
    </div>

  </div>
</div>
