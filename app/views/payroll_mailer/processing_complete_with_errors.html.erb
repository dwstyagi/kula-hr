<%# ── Banner ── %>
<div style="background:linear-gradient(135deg,#D97706 0%,#F59E0B 100%);padding:36px 40px 32px;">
  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td>
        <p style="margin:0 0 6px;font-size:12px;font-weight:600;color:#FEF3C7;letter-spacing:1px;text-transform:uppercase;">Payroll Processing</p>
        <h1 style="margin:0;font-size:26px;font-weight:700;color:#ffffff;line-height:1.2;">Processed with Errors ⚠️</h1>
        <p style="margin:10px 0 0;font-size:15px;color:#FEF9C3;"><%= @payroll_run.period_label %> &middot; <%= @tenant.name %></p>
      </td>
    </tr>
  </table>
</div>

<%# ── Body ── %>
<div style="padding:36px 40px;">
  <p style="margin:0 0 24px;font-size:15px;color:#374151;line-height:1.6;">
    Hi <%= @payroll_run.initiated_by.full_name %>,<br><br>
    Payroll for <strong><%= @payroll_run.period_label %></strong> completed, but
    <strong><%= @errors.count %> employee(s)</strong> were skipped due to errors and will need attention.
  </p>

  <%# Stats grid %>
  <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:28px;">
    <tr>
      <td width="50%" style="padding-right:8px;">
        <div style="background:#F0FDF4;border:1px solid #BBF7D0;border-radius:10px;padding:16px 20px;text-align:center;">
          <p style="margin:0 0 4px;font-size:12px;color:#16A34A;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Processed</p>
          <p style="margin:0;font-size:28px;font-weight:700;color:#14532D;"><%= @payroll_run.processed_employees %></p>
        </div>
      </td>
      <td width="50%" style="padding-left:8px;">
        <div style="background:#FEF2F2;border:1px solid #FECACA;border-radius:10px;padding:16px 20px;text-align:center;">
          <p style="margin:0 0 4px;font-size:12px;color:#DC2626;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Skipped</p>
          <p style="margin:0;font-size:28px;font-weight:700;color:#7F1D1D;"><%= @errors.count %></p>
        </div>
      </td>
    </tr>
  </table>

  <%# Error table %>
  <p style="margin:0 0 12px;font-size:13px;font-weight:600;color:#374151;text-transform:uppercase;letter-spacing:0.5px;">Skipped Employees</p>
  <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border:1px solid #FEE2E2;border-radius:10px;overflow:hidden;margin-bottom:32px;">
    <tr style="background:#FEF2F2;">
      <td style="padding:10px 16px;font-size:12px;font-weight:600;color:#DC2626;text-transform:uppercase;letter-spacing:0.5px;border-bottom:1px solid #FEE2E2;width:40%;">Employee</td>
      <td style="padding:10px 16px;font-size:12px;font-weight:600;color:#DC2626;text-transform:uppercase;letter-spacing:0.5px;border-bottom:1px solid #FEE2E2;">Reason</td>
    </tr>
    <% @errors.each_with_index do |err, i| %>
    <tr style="<%= i.odd? ? 'background:#FFF7F7;' : '' %>">
      <td style="padding:12px 16px;font-size:14px;color:#111827;font-weight:500;border-bottom:1px solid #FEE2E2;"><%= err[:name] %></td>
      <td style="padding:12px 16px;font-size:13px;color:#6B7280;border-bottom:1px solid #FEE2E2;"><%= err[:error] %></td>
    </tr>
    <% end %>
  </table>

  <div style="background:#FFFBEB;border:1px solid #FDE68A;border-radius:10px;padding:16px 20px;margin-bottom:32px;">
    <p style="margin:0;font-size:14px;color:#92400E;line-height:1.6;">
      <strong>Next steps:</strong> Fix the issues for the skipped employees (assign salary structure, lock attendance) and reprocess, or add them manually.
    </p>
  </div>

  <p style="margin:0;font-size:14px;color:#9CA3AF;">
    — The Kula HR System
  </p>
</div>
