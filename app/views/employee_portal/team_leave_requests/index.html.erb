<div class="max-w-6xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="page-title text-2xl">My Team's Leaves</h1>
      <p class="text-sm text-stone-500 mt-1">Review and act on your direct reports' leave requests.</p>
    </div>

    <%# Status filter tabs %>
    <div class="flex items-center gap-1 bg-stone-100 rounded-lg p-1">
      <% [["All", ""], ["Pending", "pending"], ["Approved", "approved"], ["Rejected", "rejected"], ["Cancelled", "cancelled"]].each do |label, value| %>
        <%= link_to label,
            employee_portal_team_leave_requests_path(status: value.presence),
            class: "px-3 py-1.5 text-sm font-medium rounded-md transition-colors #{params[:status].to_s == value ? 'bg-white text-stone-900 shadow-sm' : 'text-stone-500 hover:text-stone-900'}" %>
      <% end %>
    </div>
  </div>

  <div class="card overflow-hidden">
    <% if @leave_requests.any? %>
      <div class="overflow-x-auto">
        <table class="tbl">
          <thead>
            <tr>
              <th>Employee</th>
              <th>Type</th>
              <th>Dates</th>
              <th>Days</th>
              <th>Reason</th>
              <th>Status</th>
              <th class="text-right">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @leave_requests.each do |lr| %>
              <tr class="hover:bg-stone-50" id="<%= dom_id(lr) %>">
                <td>
                  <p class="text-sm font-medium text-stone-900"><%= lr.employee.full_name %></p>
                  <p class="text-xs text-stone-400"><%= lr.employee.employee_code %></p>
                </td>
                <td>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-kula-100 text-kula-800">
                    <%= lr.leave_type.code %>
                  </span>
                  <p class="text-xs text-stone-400 mt-0.5"><%= lr.leave_type.name %></p>
                </td>
                <td class="text-sm text-stone-700">
                  <%= lr.from_date.strftime("%d %b") %>
                  <% if lr.from_date != lr.to_date %>
                    &ndash; <%= lr.to_date.strftime("%d %b %Y") %>
                  <% else %>
                    <%= lr.from_date.strftime(", %Y") %>
                  <% end %>
                </td>
                <td class="text-sm font-medium text-stone-900"><%= lr.number_of_days.to_i %></td>
                <td class="text-sm text-stone-500 max-w-xs truncate"><%= lr.reason.presence || "—" %></td>
                <td>
                  <% badge = {
                    "pending"   => "badge-warning",
                    "approved"  => "badge-success",
                    "rejected"  => "badge-danger",
                    "cancelled" => "badge-neutral"
                  } %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= badge[lr.status] %>">
                    <%= lr.status.titleize %>
                  </span>
                  <% if lr.rejected? && lr.rejection_reason.present? %>
                    <p class="text-xs text-red-400 mt-0.5 truncate max-w-[140px]" title="<%= lr.rejection_reason %>">
                      <%= lr.rejection_reason %>
                    </p>
                  <% end %>
                </td>
                <td class="text-right">
                  <% if lr.pending? %>
                    <div class="flex items-center justify-end gap-2">
                      <%# Approve %>
                      <%= button_to approve_employee_portal_team_leave_request_path(lr),
                          method: :patch,
                          title: "Approve",
                          class: "p-1.5 rounded-md bg-green-50 text-green-600 hover:bg-green-100 transition-colors cursor-pointer" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                          <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                        </svg>
                      <% end %>

                      <%# Reject — opens modal %>
                      <button type="button"
                          title="Reject"
                          onclick="document.getElementById('reject-modal-<%= lr.id %>').querySelector('[data-modal-target=dialog]').classList.remove('hidden')"
                          class="p-1.5 rounded-md bg-red-50 text-red-600 hover:bg-red-100 transition-colors cursor-pointer">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                        </svg>
                      </button>
                    </div>
                  <% else %>
                    <span class="text-stone-300 text-xs">—</span>
                  <% end %>
                </td>
              </tr>

              <%# Reject Modal %>
              <% if lr.pending? %>
                <div id="reject-modal-<%= lr.id %>" data-controller="modal">
                  <div data-modal-target="dialog"
                       class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50"
                       data-action="click->modal#closeOnBackdrop">
                    <div class="bg-white rounded-xl shadow-xl w-full max-w-md p-6">
                      <h3 class="text-base font-semibold text-stone-900 mb-1">Reject Leave Request</h3>
                      <p class="text-sm text-stone-500 mb-4">
                        <%= lr.employee.full_name %> &middot;
                        <%= lr.leave_type.name %> &middot;
                        <%= lr.from_date.strftime("%d %b") %>&ndash;<%= lr.to_date.strftime("%d %b %Y") %>
                        (<%= lr.number_of_days.to_i %> days)
                      </p>
                      <%= form_with url: reject_employee_portal_team_leave_request_path(lr), method: :patch do |f| %>
                        <div class="mb-4">
                          <%= f.label :rejection_reason, "Reason for rejection", class: "label" %>
                          <%= f.text_area :rejection_reason,
                              rows: 3,
                              class: "w-full rounded-lg border-stone-300 px-4 py-3 shadow-sm focus:border-red-400 focus:ring-red-400 text-sm",
                              placeholder: "Enter reason (optional)" %>
                        </div>
                        <div class="flex justify-end gap-3">
                          <button type="button" data-action="modal#close"
                              class="px-4 py-2 text-sm font-medium text-stone-700 bg-stone-100 rounded-lg hover:bg-stone-200">
                            Cancel
                          </button>
                          <%= f.submit "Confirm Rejection",
                              class: "px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 cursor-pointer" %>
                        </div>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="p-12 text-center">
        <svg class="mx-auto h-10 w-10 text-stone-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5"/>
        </svg>
        <p class="text-sm text-stone-500">
          No <%= params[:status].present? ? params[:status] : "" %> leave requests from your team.
        </p>
      </div>
    <% end %>
  </div>
</div>
