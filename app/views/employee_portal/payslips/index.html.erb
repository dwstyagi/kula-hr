<div class="space-y-6">

  <%# Header %>
  <div>
    <h1 class="text-2xl font-bold text-gray-900">My Payslips</h1>
    <p class="text-sm text-gray-500 mt-0.5">View and download your salary slips</p>
  </div>

  <%# YTD Summary %>
  <% if @ytd_payslips.any? %>
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-4">
        Year-to-Date Summary &mdash;
        <%= Date.today.month >= 4 ? "FY #{Date.today.year}-#{(Date.today.year + 1).to_s.last(2)}" : "FY #{Date.today.year - 1}-#{Date.today.year.to_s.last(2)}" %>
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div>
          <p class="text-xs text-gray-400 uppercase tracking-wide">Total Gross</p>
          <p class="text-xl font-bold text-gray-900 mt-0.5">₹<%= number_with_delimiter(@ytd_gross.round(0)) %></p>
        </div>
        <div>
          <p class="text-xs text-gray-400 uppercase tracking-wide">Total Net Pay</p>
          <p class="text-xl font-bold text-green-700 mt-0.5">₹<%= number_with_delimiter(@ytd_net.round(0)) %></p>
        </div>
        <div>
          <p class="text-xs text-gray-400 uppercase tracking-wide">Total PF</p>
          <p class="text-xl font-bold text-gray-600 mt-0.5">₹<%= number_with_delimiter(@ytd_pf.round(0)) %></p>
        </div>
        <div>
          <p class="text-xs text-gray-400 uppercase tracking-wide">Total TDS</p>
          <p class="text-xl font-bold text-gray-600 mt-0.5">₹<%= number_with_delimiter(@ytd_tds.round(0)) %></p>
        </div>
      </div>
    </div>
  <% end %>

  <%# Payslips table %>
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <% if @payslips.any? %>
      <table class="w-full text-sm table-fixed">
        <colgroup>
          <col class="w-36">
          <col class="w-36">
          <col class="w-36">
          <col class="w-32">
          <col class="w-24">
          <col class="w-28">
        </colgroup>
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Period</th>
            <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Gross Pay</th>
            <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Deductions</th>
            <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Net Pay</th>
            <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Change</th>
            <th class="px-5 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @payslips.each do |payslip| %>
            <tr class="hover:bg-gray-50">
              <td class="px-5 py-3.5 font-medium text-gray-900"><%= payslip.period_label %></td>
              <td class="px-5 py-3.5 text-gray-600">₹<%= number_with_delimiter(payslip.gross_pay.round(0)) %></td>
              <td class="px-5 py-3.5 text-gray-600">₹<%= number_with_delimiter(payslip.total_deductions.round(0)) %></td>
              <td class="px-5 py-3.5 font-semibold text-gray-900">₹<%= number_with_delimiter(payslip.net_pay.round(0)) %></td>
              <td class="px-5 py-3.5">
                <% if @mom_changes[payslip.id] %>
                  <% change = @mom_changes[payslip.id] %>
                  <span class="inline-flex items-center text-xs font-medium <%= change >= 0 ? 'text-green-600' : 'text-red-600' %>">
                    <%= change >= 0 ? '↑' : '↓' %> <%= change.abs %>%
                  </span>
                <% else %>
                  <span class="text-xs text-gray-400">—</span>
                <% end %>
              </td>
              <td class="px-5 py-3.5">
                <div class="flex items-center justify-end gap-1">
                  <%# View %>
                  <%= link_to employee_portal_payslip_path(payslip),
                        title: "View",
                        class: "inline-flex items-center justify-center w-8 h-8 rounded-lg text-gray-400 hover:text-blue-600 hover:bg-blue-50 transition-colors" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                    </svg>
                  <% end %>
                  <%# Download PDF %>
                  <%= link_to download_employee_portal_payslip_path(payslip),
                        title: "Download PDF",
                        class: "inline-flex items-center justify-center w-8 h-8 rounded-lg text-gray-400 hover:text-green-600 hover:bg-green-50 transition-colors" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                    </svg>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="text-center py-16 text-gray-400">
        <svg class="mx-auto w-10 h-10 mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        <p class="font-medium">No payslips available yet</p>
        <p class="text-sm mt-1">Payslips appear here once payroll is approved.</p>
      </div>
    <% end %>
  </div>

</div>
