<div class="max-w-6xl mx-auto space-y-6">

  <div class="flex items-center justify-between">
    <div>
      <h1 class="page-title text-2xl">Edit Profile</h1>
      <p class="text-sm text-stone-500 mt-0.5">Update your personal and banking details</p>
    </div>
    <%= link_to employee_portal_profile_path,
        class: "inline-flex items-center gap-2 px-4 py-2 border border-stone-300 text-stone-700 text-sm font-medium rounded-lg hover:bg-stone-50" do %>
      Cancel
    <% end %>
  </div>

  <%= form_with model: current_employee, url: employee_portal_profile_path, method: :patch, class: "" do |f| %>

    <% if current_employee.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-red-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <div>
            <p class="text-sm font-semibold text-red-800">Please fix the following errors:</p>
            <ul class="mt-1 text-sm text-red-700 list-disc list-inside">
              <% current_employee.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    <% end %>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <%# Personal Information %>
    <div class="card card-pad">
      <h2 class="text-sm font-semibold text-stone-500 uppercase tracking-wider mb-4">Personal Information</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="label">Full Name</label>
          <p class="text-sm text-stone-500 bg-stone-50 rounded-lg px-3 py-2 border border-stone-200"><%= current_employee.full_name %></p>
          <p class="text-xs text-stone-400 mt-1">Contact HR to change your name</p>
        </div>
        <div>
          <label class="label">Email</label>
          <p class="text-sm text-stone-500 bg-stone-50 rounded-lg px-3 py-2 border border-stone-200"><%= current_employee.email %></p>
          <p class="text-xs text-stone-400 mt-1">Contact HR to change your email</p>
        </div>
        <div>
          <%= f.label :phone, class: "label" %>
          <%= f.text_field :phone, class: "input", placeholder: "e.g. 9876543210" %>
        </div>
        <div>
          <%= f.label :date_of_birth, class: "label" %>
          <%= f.date_field :date_of_birth, class: "input" %>
        </div>
      </div>
    </div>

    <%# Address %>
    <div class="card card-pad">
      <h2 class="text-sm font-semibold text-stone-500 uppercase tracking-wider mb-4">Address</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="md:col-span-2">
          <%= f.label :current_address, class: "label" %>
          <%= f.text_area :current_address, rows: 3, class: "input", placeholder: "Enter your current address" %>
        </div>
        <div>
          <%= f.label :city, class: "label" %>
          <%= f.text_field :city, class: "input" %>
        </div>
        <div>
          <%= f.label :state, class: "label" %>
          <%= f.text_field :state, class: "input" %>
        </div>
        <div>
          <%= f.label :pincode, class: "label" %>
          <%= f.text_field :pincode, class: "input", placeholder: "e.g. 560001" %>
        </div>
      </div>
    </div>

    <%# Identity Documents %>
    <div class="card card-pad">
      <h2 class="text-sm font-semibold text-stone-500 uppercase tracking-wider mb-4">Identity Documents</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <%= f.label :pan_number, "PAN Number", class: "label" %>
          <%= f.text_field :pan_number, class: "input uppercase", placeholder: "e.g. ABCDE1234F", maxlength: 10 %>
          <% if current_employee.errors[:pan_number].any? %>
            <p class="text-xs text-red-600 mt-1"><%= current_employee.errors[:pan_number].first %></p>
          <% end %>
        </div>
        <div>
          <%= f.label :aadhaar_number, "Aadhaar Number", class: "label" %>
          <%= f.text_field :aadhaar_number, class: "input", placeholder: "e.g. 123456789012", maxlength: 12 %>
          <% if current_employee.errors[:aadhaar_number].any? %>
            <p class="text-xs text-red-600 mt-1"><%= current_employee.errors[:aadhaar_number].first %></p>
          <% end %>
        </div>
      </div>
    </div>

    <%# Bank Details %>
    <div class="card card-pad">
      <h2 class="text-sm font-semibold text-stone-500 uppercase tracking-wider mb-4">Bank Details</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <%= f.label :bank_name, class: "label" %>
          <%= f.text_field :bank_name, class: "input", placeholder: "e.g. HDFC Bank" %>
        </div>
        <div>
          <%= f.label :bank_account_number, "Account Number", class: "label" %>
          <%= f.text_field :bank_account_number, class: "input" %>
        </div>
        <div>
          <%= f.label :ifsc_code, "IFSC Code", class: "label" %>
          <%= f.text_field :ifsc_code, class: "input", placeholder: "e.g. HDFC0001234" %>
        </div>
      </div>
    </div>

    <%# Emergency Contact %>
    <div class="card card-pad">
      <h2 class="text-sm font-semibold text-stone-500 uppercase tracking-wider mb-4">Emergency Contact</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <%= f.label :emergency_contact_name, "Name", class: "label" %>
          <%= f.text_field :emergency_contact_name, class: "input" %>
        </div>
        <div>
          <%= f.label :emergency_contact_phone, "Phone", class: "label" %>
          <%= f.text_field :emergency_contact_phone, class: "input" %>
        </div>
        <div>
          <%= f.label :emergency_contact_relation, "Relation", class: "label" %>
          <%= f.text_field :emergency_contact_relation, class: "input", placeholder: "e.g. Spouse, Parent" %>
        </div>
      </div>
    </div>
    </div>
    <%# Submit %>
    <div class="flex justify-end gap-3">
      <%= link_to "Cancel", employee_portal_profile_path, class: "px-4 py-2 border border-stone-300 text-stone-700 text-sm font-medium rounded-lg hover:bg-stone-50" %>
      <%= f.submit "Save Changes", class: "btn btn-primary cursor-pointer" %>
    </div>
  <% end %>

</div>
