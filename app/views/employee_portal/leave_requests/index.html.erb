<div class="max-w-5xl mx-auto space-y-6">

  <%# Approver Info %>
  <div class="flex items-center gap-2 text-sm text-stone-500 bg-white border border-stone-200 rounded-lg px-4 py-2.5 w-fit">
    <svg class="w-4 h-4 text-stone-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
    </svg>
    <span>Your leave approver: <strong class="text-stone-700"><%= current_employee.approver_label %></strong></span>
  </div>

  <%# Balance Summary Cards %>
  <div>
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-lg font-semibold text-stone-900">My Leaves</h2>
      <%= link_to new_employee_portal_leave_request_path,
          class: "btn btn-primary" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Apply Leave
      <% end %>
    </div>

    <% if @leave_balances.any? %>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
        <% @leave_balances.each do |balance| %>
          <div class="card p-4">
            <div class="flex items-center justify-between mb-2">
              <span class="text-xs font-medium text-stone-500"><%= balance.leave_type.name %></span>
              <span class="text-xs font-mono bg-stone-100 text-stone-600 px-1.5 py-0.5 rounded"><%= balance.leave_type.code %></span>
            </div>
            <% used_pct = balance.total_days > 0 ? (balance.used_days / balance.total_days * 100).round : 0 %>
            <div class="w-full bg-stone-100 rounded-full h-1 mb-2">
              <div class="h-1 rounded-full <%= used_pct > 80 ? 'bg-red-400' : 'bg-kula-600' %>"
                   style="width: <%= used_pct %>%"></div>
            </div>
            <p class="page-title text-2xl"><%= balance.remaining_days.to_i %></p>
            <p class="text-xs text-stone-400">of <%= balance.total_days.to_i %> days</p>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# March Encashment Banner %>
  <% if Date.today.month == 3 %>
    <% fy = LeaveBalance.current_financial_year %>
    <% encashable_balances = @leave_balances.select { |b|
         b.leave_type.carry_forward? && !b.leave_type.lop? &&
         [b.leave_type.max_carry_forward, b.remaining_days].min > 0
       } %>
    <% if encashable_balances.any? %>
      <% encashable_balances.each do |balance| %>
        <% eligible_days = [balance.leave_type.max_carry_forward, balance.remaining_days].min.to_i %>
        <% existing_request = LeaveEncashmentRequest.find_by(
             employee: current_employee,
             leave_type: balance.leave_type,
             financial_year: fy
           ) %>
        <% unless existing_request %>
          <div class="bg-amber-50 border border-amber-200 rounded-lg px-5 py-4 flex items-start justify-between gap-4">
            <div>
              <p class="text-sm font-semibold text-amber-800">Year-End Option: <%= balance.leave_type.name %></p>
              <p class="text-sm text-amber-700 mt-0.5">
                You have <strong><%= eligible_days %> day(s)</strong> eligible for carry-forward.
                By default they will carry over on April 1st — or you can encash them instead.
              </p>
            </div>
            <%= button_to employee_portal_leave_encashment_requests_path,
                method: :post,
                params: { leave_type_id: balance.leave_type_id },
                class: "shrink-0 px-4 py-2 bg-amber-600 text-white text-sm font-medium rounded-lg hover:bg-amber-700 cursor-pointer",
                form: { data: { turbo_confirm: "Request encashment of #{eligible_days} #{balance.leave_type.name} day(s)? They will NOT carry forward if approved." } } do %>
              Request Encashment
            <% end %>
          </div>
        <% else %>
          <div class="bg-stone-50 border border-stone-200 rounded-lg px-5 py-4">
            <p class="text-sm font-semibold text-stone-700"><%= balance.leave_type.name %> — Encashment Request Submitted</p>
            <p class="text-sm text-stone-500 mt-0.5">
              Status: <strong><%= existing_request.status.titleize %></strong>.
              <% if existing_request.approved? %>
                ₹<%= number_with_delimiter(existing_request.encashment_amount) %> will be added to your next payroll.
              <% elsif existing_request.pending? %>
                Awaiting HR approval. If approved, <%= eligible_days %> days will be encashed instead of carried forward.
              <% else %>
                Request was rejected — your <%= eligible_days %> days will carry forward on April 1st.
              <% end %>
            </p>
          </div>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%# Request History %>
  <div class="card overflow-hidden">
    <div class="px-6 py-4 border-b border-stone-100">
      <h3 class="text-sm font-semibold text-stone-900">Request History</h3>
    </div>

    <% if @leave_requests.any? %>
      <div class="overflow-x-auto">
      <table class="tbl">
        <thead>
          <tr>
            <th>Type</th>
            <th>Dates</th>
            <th>Days</th>
            <th>Status</th>
            <th>Approved By</th>
            <th class="text-right">Action</th>
          </tr>
        </thead>
        <tbody>
          <% @leave_requests.each do |lr| %>
            <tr class="hover:bg-stone-50">
              <td>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-kula-100 text-kula-800">
                  <%= lr.leave_type.code %>
                </span>
                <p class="text-xs text-stone-400 mt-0.5"><%= lr.leave_type.name %></p>
              </td>
              <td class="text-sm text-stone-700">
                <%= lr.from_date.strftime("%d %b") %>
                <% if lr.from_date != lr.to_date %>
                  – <%= lr.to_date.strftime("%d %b %Y") %>
                <% else %>
                  <%= lr.from_date.strftime(", %Y") %>
                <% end %>
              </td>
              <td class="text-sm font-medium text-stone-900"><%= lr.number_of_days.to_i %></td>
              <td>
                <% badge = {
                  "pending"   => ["badge-warning", "⏳"],
                  "approved"  => ["badge-success",  "✅"],
                  "rejected"  => ["badge-danger",      "❌"],
                  "cancelled" => ["badge-neutral",    "—"]
                } %>
                <% color, icon = badge[lr.status] %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-medium <%= color %>">
                  <%= icon %> <%= lr.status.titleize %>
                </span>
              </td>
              <td class="text-xs text-stone-500">
                <% if lr.approved_by.present? %>
                  <p class="font-medium text-stone-700"><%= lr.approved_by.full_name %></p>
                  <% if lr.approved_at.present? %>
                    <p class="text-stone-400 mt-0.5"><%= lr.approved_at.strftime("%d %b, %I:%M %p") %></p>
                  <% end %>
                  <% if lr.rejected? && lr.rejection_reason.present? %>
                    <p class="text-red-500 mt-0.5 max-w-40 truncate" title="<%= lr.rejection_reason %>">
                      "<%= lr.rejection_reason %>"
                    </p>
                  <% end %>
                <% elsif lr.pending? %>
                  <span class="text-stone-400">Awaiting approval</span>
                <% else %>
                  <span class="text-stone-300">—</span>
                <% end %>
              </td>
              <td class="text-right">
                <% if lr.pending? %>
                  <%= button_to cancel_employee_portal_leave_request_path(lr),
                      method: :patch,
                      class: "text-xs px-3 py-1.5 bg-stone-100 text-stone-600 rounded-lg hover:bg-stone-200 cursor-pointer",
                      form: { data: { turbo_confirm: "Cancel this leave request?" } } do %>
                    Cancel
                  <% end %>
                <% else %>
                  <span class="text-stone-300 text-xs">—</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      </div>
    <% else %>
      <div class="p-10 text-center">
        <p class="text-sm text-stone-400">No leave requests yet.</p>
        <%= link_to "Apply for your first leave →", new_employee_portal_leave_request_path,
            class: "text-sm text-kula-700 hover:text-kula-900 mt-2 inline-block" %>
      </div>
    <% end %>
  </div>
</div>
