<div class="space-y-6">

  <%# Section 1: Welcome + Notifications %>
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">
        Good <%= greeting %>, <%= current_employee&.first_name || current_user.first_name %>
      </h1>
      <p class="text-sm text-gray-500 mt-0.5">
        <%= Date.today.strftime("%A, %d %B %Y") %> &middot;
        <%= @working_days_this_month %> working days this month
      </p>
    </div>
    <%= link_to new_employee_portal_leave_request_path,
        class: "inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Apply Leave
    <% end %>
  </div>

  <% if current_employee %>

    <%# Smart Notifications %>
    <% notifications = [] %>
    <% if @payroll_data&.latest_payslip && @payroll_data.latest_payslip.month == Date.today.month && @payroll_data.latest_payslip.year == Date.today.year %>
      <% notifications << { color: "blue", icon: "document", message: "Payslip for #{Date.today.strftime('%B %Y')} is available" } %>
    <% end %>
    <% if @payroll_data&.tax_declaration&.status_draft? %>
      <% notifications << { color: "amber", icon: "warning", message: "Tax declaration is still in draft" } %>
    <% end %>
    <% if current_employee.bank_account_number.blank? %>
      <% notifications << { color: "amber", icon: "warning", message: "Bank account details missing" } %>
    <% end %>
    <% if @payroll_data&.current_month_payroll_status.present? && !%w[approved paid].include?(@payroll_data.current_month_payroll_status[:status]) %>
      <% notifications << { color: "blue", icon: "clock", message: "Payroll for #{@payroll_data.current_month_payroll_status[:period]} is under processing" } %>
    <% end %>

    <% if notifications.any? %>
      <div class="space-y-2">
        <% notifications.each do |notif| %>
          <% bg = notif[:color] == "amber" ? "bg-amber-50 border-amber-200" : "bg-blue-50 border-blue-200" %>
          <% text_color = notif[:color] == "amber" ? "text-amber-800" : "text-blue-800" %>
          <% icon_color = notif[:color] == "amber" ? "text-amber-500" : "text-blue-500" %>
          <div class="flex items-center gap-3 px-4 py-2.5 rounded-lg border <%= bg %>">
            <% if notif[:icon] == "warning" %>
              <svg class="w-4 h-4 shrink-0 <%= icon_color %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
              </svg>
            <% elsif notif[:icon] == "document" %>
              <svg class="w-4 h-4 shrink-0 <%= icon_color %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
            <% else %>
              <svg class="w-4 h-4 shrink-0 <%= icon_color %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            <% end %>
            <p class="text-sm font-medium <%= text_color %>"><%= notif[:message] %></p>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Quick Stats Row %>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      <%# Net Salary %>
      <div class="bg-white rounded-xl border border-gray-200 p-4">
        <div class="flex items-center gap-3">
          <div class="p-2.5 bg-green-50 rounded-lg flex items-center justify-center w-10 h-10">
            <span class="text-green-600 font-bold text-base leading-none">₹</span>
          </div>
          <div>
            <p class="text-xs text-gray-500">Net Salary</p>
            <% if @payroll_data&.latest_payslip %>
              <p class="text-lg font-bold text-gray-900">₹<%= number_with_delimiter(@payroll_data.latest_payslip.net_pay.round(0)) %></p>
            <% else %>
              <p class="text-lg font-bold text-gray-400">--</p>
            <% end %>
          </div>
        </div>
      </div>

      <%# Leave Balance %>
      <div class="bg-white rounded-xl border border-gray-200 p-4">
        <div class="flex items-center gap-3">
          <div class="p-2.5 bg-blue-50 rounded-lg">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs text-gray-500">Leave Balance</p>
            <p class="text-lg font-bold text-gray-900"><%= @leave_balances.sum(&:remaining_days).to_i %> <span class="text-xs font-normal text-gray-400">days</span></p>
          </div>
        </div>
      </div>

      <%# Days Worked %>
      <div class="bg-white rounded-xl border border-gray-200 p-4">
        <div class="flex items-center gap-3">
          <div class="p-2.5 bg-indigo-50 rounded-lg">
            <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
            </svg>
          </div>
          <div>
            <p class="text-xs text-gray-500">Days Worked</p>
            <% if @attendance %>
              <p class="text-lg font-bold text-gray-900"><%= @attendance.paid_days.to_i %><span class="text-xs font-normal text-gray-400">/<%= @attendance.total_working_days.to_i %></span></p>
            <% else %>
              <p class="text-lg font-bold text-gray-400">--</p>
            <% end %>
          </div>
        </div>
      </div>

      <%# Pending Requests %>
      <div class="bg-white rounded-xl border border-gray-200 p-4">
        <div class="flex items-center gap-3">
          <div class="p-2.5 <%= @pending_requests.any? ? 'bg-amber-50' : 'bg-gray-50' %> rounded-lg">
            <svg class="w-5 h-5 <%= @pending_requests.any? ? 'text-amber-600' : 'text-gray-400' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs text-gray-500">Pending Requests</p>
            <p class="text-lg font-bold <%= @pending_requests.any? ? 'text-amber-600' : 'text-gray-900' %>"><%= @pending_requests.count %></p>
          </div>
        </div>
      </div>
    </div>

    <%# Section 2: Salary Summary %>
    <% if @payroll_data&.latest_payslip %>
      <div class="bg-white rounded-xl border border-gray-200 p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider">Salary Summary</h2>
          <span class="text-xs text-gray-400"><%= @payroll_data.latest_payslip.period_label %></span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <%# Net Pay - Prominent %>
          <div class="md:col-span-1">
            <p class="text-xs text-gray-500 mb-1">Net Pay</p>
            <p class="text-3xl font-bold text-green-700">₹<%= number_with_delimiter(@payroll_data.latest_payslip.net_pay.round(0)) %></p>
            <% if @payroll_data.mom_change %>
              <p class="text-xs mt-1 <%= @payroll_data.mom_change >= 0 ? 'text-green-600' : 'text-red-600' %>">
                <%= @payroll_data.mom_change >= 0 ? '↑' : '↓' %> <%= @payroll_data.mom_change.abs %>% vs last month
              </p>
            <% end %>
            <div class="mt-3 flex gap-3">
              <%= link_to employee_portal_payslip_path(@payroll_data.latest_payslip), class: "relative group text-blue-600 hover:text-blue-800" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1 px-2 py-1 text-xs text-white bg-gray-800 rounded whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity">View Payslip</span>
              <% end %>
              <%= link_to download_employee_portal_payslip_path(@payroll_data.latest_payslip), class: "relative group text-green-600 hover:text-green-800" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1 px-2 py-1 text-xs text-white bg-gray-800 rounded whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity">Download Payslip</span>
              <% end %>
            </div>
          </div>

          <%# Gross/Deductions Breakdown %>
          <div class="md:col-span-1">
            <div class="space-y-2">
              <div class="flex justify-between text-sm">
                <span class="text-gray-500">Gross Pay</span>
                <span class="font-medium text-gray-900">₹<%= number_with_delimiter(@payroll_data.latest_payslip.gross_pay.round(0)) %></span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-gray-500">Deductions</span>
                <span class="font-medium text-red-600">-₹<%= number_with_delimiter(@payroll_data.latest_payslip.total_deductions.round(0)) %></span>
              </div>
              <div class="border-t border-gray-100 pt-2 flex justify-between text-sm">
                <span class="font-semibold text-gray-900">Net Pay</span>
                <span class="font-bold text-green-700">₹<%= number_with_delimiter(@payroll_data.latest_payslip.net_pay.round(0)) %></span>
              </div>
            </div>
          </div>

          <%# Paid Days / LOP %>
          <div class="md:col-span-1">
            <div class="space-y-2">
              <% if @payroll_data.latest_payslip.respond_to?(:paid_days) && @payroll_data.latest_payslip.paid_days.present? %>
                <div class="flex justify-between text-sm">
                  <span class="text-gray-500">Paid Days</span>
                  <span class="font-medium text-gray-900"><%= @payroll_data.latest_payslip.paid_days.to_i %></span>
                </div>
              <% end %>
              <% if @payroll_data.latest_payslip.lop_days.to_i > 0 %>
                <div class="flex justify-between text-sm">
                  <span class="text-gray-500">LOP Days</span>
                  <span class="font-medium text-amber-600"><%= @payroll_data.latest_payslip.lop_days.to_i %></span>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% elsif @payroll_data&.current_month_payroll_status.present? && !%w[approved paid].include?(@payroll_data.current_month_payroll_status[:status]) %>
      <%# Payroll Processing Status %>
      <div class="bg-blue-50 rounded-xl border border-blue-200 p-6 text-center">
        <svg class="mx-auto h-10 w-10 text-blue-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <p class="text-sm font-semibold text-blue-800">Payroll for <%= @payroll_data.current_month_payroll_status[:period] %> is being processed</p>
        <p class="text-xs text-blue-600 mt-1">Status: <%= @payroll_data.current_month_payroll_status[:status].titleize %></p>
      </div>
    <% else %>
      <div class="bg-white rounded-xl border border-gray-200 p-8 text-center">
        <svg class="mx-auto h-10 w-10 text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z"/>
        </svg>
        <p class="text-sm font-medium text-gray-500">No payslip available yet</p>
        <p class="text-xs text-gray-400 mt-1">Your salary details will appear here once payroll is processed.</p>
      </div>
    <% end %>

    <%# Section 3: Attendance This Month %>
    <% if @attendance %>
      <div class="bg-white rounded-xl border border-gray-200 p-5">
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Attendance This Month</h2>
        <div class="grid grid-cols-3 gap-4">
          <div class="text-center">
            <p class="text-2xl font-bold text-gray-900"><%= @attendance.total_working_days.to_i %></p>
            <p class="text-xs text-gray-500 mt-1">Working Days</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-bold text-green-700"><%= @attendance.paid_days.to_i %></p>
            <p class="text-xs text-gray-500 mt-1">Paid Days</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-bold <%= @attendance.lop_days.to_i > 0 ? 'text-amber-600' : 'text-gray-400' %>"><%= @attendance.lop_days.to_i %></p>
            <p class="text-xs text-gray-500 mt-1">LOP Days</p>
          </div>
        </div>
      </div>
    <% end %>

    <%# Section 4: Leave Balance Cards %>
    <% if @leave_balances.any? %>
      <div>
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">
          Leave Balance — <%= LeaveBalance.current_financial_year %>
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
          <% @leave_balances.each do |balance| %>
            <% used_pct = balance.total_days > 0 ? (balance.used_days / balance.total_days * 100).round : 0 %>
            <div class="bg-white rounded-xl border border-gray-200 p-5 hover:shadow-sm transition-shadow">
              <div class="flex items-start justify-between mb-3">
                <div>
                  <p class="text-xs font-medium text-gray-500"><%= balance.leave_type.name %></p>
                  <span class="inline-block mt-0.5 text-xs font-mono bg-gray-100 text-gray-500 px-1.5 py-0.5 rounded">
                    <%= balance.leave_type.code %>
                  </span>
                </div>
                <% if balance.leave_type.is_paid? %>
                  <span class="text-xs text-green-600 font-medium">Paid</span>
                <% end %>
              </div>

              <div class="w-full bg-gray-100 rounded-full h-1.5 mb-3">
                <div class="h-1.5 rounded-full transition-all <%= used_pct > 80 ? 'bg-red-400' : used_pct > 50 ? 'bg-amber-400' : 'bg-blue-500' %>"
                     style="width: <%= [used_pct, 100].min %>%"></div>
              </div>

              <div class="flex items-end justify-between">
                <div>
                  <p class="text-3xl font-bold text-gray-900 leading-none"><%= balance.remaining_days.to_i %></p>
                  <p class="text-xs text-gray-400 mt-1">of <%= balance.total_days.to_i %> remaining</p>
                </div>
                <div class="text-right text-xs text-gray-400 space-y-0.5">
                  <p><%= balance.used_days.to_i %> used</p>
                  <% if balance.carried_forward_days > 0 %>
                    <p class="text-blue-400"><%= balance.carried_forward_days.to_i %> carried</p>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Section 5: Payslip History (inline) %>
    <% if @payroll_data&.recent_payslips&.any? %>
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
          <h2 class="text-sm font-semibold text-gray-900">Payslip History</h2>
          <%= link_to employee_portal_payslips_path, class: "text-xs text-blue-600 hover:text-blue-800 font-medium" do %>
            View All →
          <% end %>
        </div>
        <div class="divide-y divide-gray-100">
          <% @payroll_data.recent_payslips.each do |payslip| %>
            <div class="flex items-center justify-between px-6 py-3">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center">
                  <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-gray-900"><%= payslip.period_label %></p>
                  <p class="text-xs text-gray-400">Net: ₹<%= number_with_delimiter(payslip.net_pay.round(0)) %></p>
                </div>
              </div>
              <%= link_to download_employee_portal_payslip_path(payslip), class: "relative group text-gray-400 hover:text-green-600" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1 px-2 py-1 text-xs text-white bg-gray-800 rounded whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity">Download</span>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Section 6: Leave Requests %>
    <%# Pending requests alert %>
    <% if @pending_requests.any? %>
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-4">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-amber-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
          </svg>
          <div class="flex-1">
            <p class="text-sm font-semibold text-amber-800">
              <%= pluralize(@pending_requests.count, "leave request") %> pending approval
            </p>
            <div class="mt-2 space-y-1">
              <% @pending_requests.each do |req| %>
                <p class="text-xs text-amber-700">
                  <%= req.leave_type.name %> &middot;
                  <%= req.from_date.strftime("%d %b") %>
                  <% if req.from_date != req.to_date %>–<%= req.to_date.strftime("%d %b") %><% end %>
                  &middot; <%= req.number_of_days.to_i %> day(s)
                </p>
              <% end %>
            </div>
          </div>
          <%= link_to employee_portal_leave_requests_path, class: "relative group shrink-0 text-amber-700 hover:text-amber-900" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1 px-2 py-1 text-xs text-white bg-gray-800 rounded whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity">View all requests</span>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Recent request history %>
    <% if @recent_requests.any? %>
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
          <h2 class="text-sm font-semibold text-gray-900">Recent Leave Requests</h2>
          <%= link_to employee_portal_leave_requests_path, class: "relative group text-blue-600 hover:text-blue-800" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1 px-2 py-1 text-xs text-white bg-gray-800 rounded whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity">View all requests</span>
          <% end %>
        </div>
        <div class="divide-y divide-gray-100">
          <% @recent_requests.each do |req| %>
            <% badge = {
              "pending"   => "bg-yellow-100 text-yellow-700",
              "approved"  => "bg-green-100 text-green-700",
              "rejected"  => "bg-red-100 text-red-700",
              "cancelled" => "bg-gray-100 text-gray-500"
            } %>
            <div class="flex items-center justify-between px-6 py-3">
              <div class="flex items-center gap-3">
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-700">
                  <%= req.leave_type.code %>
                </span>
                <div>
                  <p class="text-sm text-gray-700">
                    <%= req.from_date.strftime("%d %b") %>
                    <% if req.from_date != req.to_date %>
                      – <%= req.to_date.strftime("%d %b %Y") %>
                    <% else %>
                      <%= req.from_date.strftime(", %Y") %>
                    <% end %>
                    <span class="text-gray-400">&middot; <%= req.number_of_days.to_i %> day(s)</span>
                  </p>
                  <% if req.approved_by.present? %>
                    <p class="text-xs text-gray-400 mt-0.5">
                      <%= req.approved? ? "Approved" : "Reviewed" %> by
                      <span class="font-medium text-gray-500"><%= req.approved_by.full_name %></span>
                      <% if req.approved_at.present? %>
                        &middot; <%= req.approved_at.strftime("%d %b, %I:%M %p") %>
                      <% end %>
                    </p>
                  <% elsif req.pending? %>
                    <p class="text-xs text-gray-400 mt-0.5">Awaiting approval</p>
                  <% end %>
                </div>
              </div>
              <div class="text-right space-y-1">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= badge[req.status] %>">
                  <%= req.status.titleize %>
                </span>
                <% if req.rejected? && req.rejection_reason.present? %>
                  <p class="text-xs text-red-400 max-w-40 truncate" title="<%= req.rejection_reason %>">
                    "<%= req.rejection_reason %>"
                  </p>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Section 7: Tax Summary %>
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider">Tax Summary</h2>
        <%= link_to employee_portal_tax_declaration_path, class: "text-xs text-blue-600 hover:text-blue-800 font-medium" do %>
          View Declaration →
        <% end %>
      </div>
      <% if @payroll_data&.tax_declaration %>
        <% td = @payroll_data.tax_declaration %>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div>
            <p class="text-xs text-gray-500">Regime</p>
            <p class="text-sm font-medium text-gray-900"><%= td.regime.titleize %></p>
          </div>
          <div>
            <p class="text-xs text-gray-500">Status</p>
            <% badge_color = { "draft" => "bg-gray-100 text-gray-700", "submitted" => "bg-blue-100 text-blue-700", "verified" => "bg-green-100 text-green-700" } %>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= badge_color[td.status] %>"><%= td.status.titleize %></span>
          </div>
          <div>
            <p class="text-xs text-gray-500">Monthly TDS</p>
            <p class="text-sm font-medium text-gray-900">₹<%= number_with_delimiter(@payroll_data.monthly_tds.round(0)) %></p>
          </div>
          <div>
            <p class="text-xs text-gray-500">Declared Investments</p>
            <p class="text-sm font-medium text-gray-900">₹<%= number_with_delimiter(@payroll_data.total_declared_investments.round(0)) %></p>
          </div>
        </div>
      <% else %>
        <p class="text-sm text-gray-400">No tax declaration filed yet.</p>
      <% end %>
    </div>

    <%# Section 8: Profile Status %>
    <% if @payroll_data&.profile_completeness %>
      <% pc = @payroll_data.profile_completeness %>
      <div class="bg-white rounded-xl border border-gray-200 p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider">Profile Status</h2>
          <div class="flex items-center gap-3">
            <span class="text-xs font-medium <%= pc[:percentage] == 100 ? 'text-green-600' : 'text-amber-600' %>">
              <%= pc[:percentage] %>% Complete
            </span>
            <% if pc[:missing_fields].any? %>
              <%= link_to edit_employee_portal_profile_path, class: "text-xs text-blue-600 hover:text-blue-800 font-medium" do %>
                Complete Profile →
              <% end %>
            <% end %>
          </div>
        </div>
        <%# Progress bar %>
        <div class="w-full bg-gray-100 rounded-full h-2 mb-3">
          <div class="h-2 rounded-full transition-all <%= pc[:percentage] == 100 ? 'bg-green-500' : pc[:percentage] >= 75 ? 'bg-blue-500' : 'bg-amber-500' %>"
               style="width: <%= pc[:percentage] %>%"></div>
        </div>
        <% if pc[:missing_fields].any? %>
          <div class="flex flex-wrap gap-2">
            <% field_labels = { "bank_account_number" => "Bank Account", "pan_number" => "PAN", "aadhaar_number" => "Aadhaar", "phone" => "Phone", "date_of_birth" => "Date of Birth", "current_address" => "Address" } %>
            <% pc[:missing_fields].each do |field| %>
              <span class="inline-flex items-center gap-1 px-2 py-1 rounded-md text-xs bg-amber-50 text-amber-700 border border-amber-200">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
                </svg>
                <%= field_labels[field] || field.titleize %>
              </span>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-green-600 font-medium">All profile fields are complete!</p>
        <% end %>
      </div>
    <% end %>

  <% else %>
    <%# No employee profile linked %>
    <div class="bg-white rounded-xl border border-gray-200 p-12 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
      </svg>
      <p class="text-sm font-medium text-gray-900">No employee profile found</p>
      <p class="text-xs text-gray-400 mt-1">Contact your HR administrator to set up your profile.</p>
    </div>
  <% end %>

</div>
