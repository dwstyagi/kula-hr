<div class="max-w-3xl mx-auto">
  <div class="mb-6">
    <%= link_to employee_portal_announcements_path, class: "text-sm text-gray-500 hover:text-gray-700 inline-flex items-center gap-1 mb-2" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to announcements
    <% end %>
    <h1 class="text-xl sm:text-2xl font-bold text-gray-900"><%= @announcement.title %></h1>
    <p class="text-sm text-gray-500 mt-1">
      <%= @announcement.author&.full_name %> &middot;
      <%= (@announcement.published_at || @announcement.created_at).strftime("%d %b %Y") %>
    </p>
    <% if @announcement.edited? %>
      <span class="inline-flex items-center gap-1 mt-2 px-2 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-700">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
        Updated <%= @announcement.last_edited_at.strftime("%d %b %Y") %>
      </span>
    <% end %>
  </div>

  <div class="bg-white rounded-lg border border-gray-200 p-6">
    <div class="prose prose-sm max-w-none text-gray-700">
      <%= simple_format(@announcement.body) %>
    </div>
  </div>
</div>
