<div class="max-w-3xl mx-auto space-y-6">
  <div>
    <h1 class="page-title text-2xl">Announcements</h1>
    <p class="text-sm text-stone-500 mt-0.5">News and updates from your company.</p>
  </div>

  <% if @announcements.any? %>
    <div class="space-y-3">
      <% @announcements.each do |announcement| %>
        <% unread = !@read_ids.include?(announcement.id) %>
        <%= link_to employee_portal_announcement_path(announcement),
            class: "block bg-white rounded-lg border #{unread ? 'border-kula-200' : 'border-stone-200'} p-4 hover:border-kula-300 transition-colors" do %>
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <div class="flex items-center gap-2">
                <% if unread %>
                  <span class="h-2 w-2 rounded-full bg-kula-700 shrink-0"></span>
                <% end %>
                <h2 class="text-sm font-semibold text-stone-900 truncate"><%= announcement.title %></h2>
                <% if announcement.edited? %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-700 shrink-0">Updated</span>
                <% end %>
              </div>
              <p class="text-sm text-stone-500 mt-1 line-clamp-2"><%= truncate(announcement.body.to_s, length: 140) %></p>
            </div>
            <span class="text-xs text-stone-400 shrink-0 whitespace-nowrap">
              <%= (announcement.published_at || announcement.created_at).strftime("%d %b") %>
            </span>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="card p-12 text-center">
      <svg class="mx-auto h-10 w-10 text-stone-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
      </svg>
      <p class="text-sm text-stone-500">No announcements yet.</p>
    </div>
  <% end %>
</div>
