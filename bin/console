#!/bin/bash
# Production Console & Shell Access for Kula HR
# Usage: ./bin/console [command]

set -e

# Colors
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
BLUE=$'\033[0;34m'
NC=$'\033[0m'

# Production server
SERVER="kulahr"
SERVER_IP="ubuntu@13.200.249.229"

# Check if SSH alias exists, fallback to IP
if ! ssh -G "$SERVER" &>/dev/null 2>&1; then
    SERVER="$SERVER_IP"
fi

APP_PATH="/var/www/kulahr"
ENV_FILE="/etc/kulahr.env"

# Function to display usage
usage() {
    cat << EOF
${GREEN}Production Console & Shell Access — Kula HR${NC}

${YELLOW}Usage:${NC}
  ./bin/console [command]

${YELLOW}Commands:${NC}
  rails             Open Rails console (production)
  shell             Open bash shell on production server
  dbconsole         Open database console (PostgreSQL)

  status            Check service status (Puma, Sidekiq, Redis, Nginx)
  restart-puma      Restart Puma web server
  restart-sidekiq   Restart Sidekiq workers
  restart-all       Restart both Puma and Sidekiq

  ssh               Direct SSH to production server

${YELLOW}Examples:${NC}
  ./bin/console rails          # Open Rails console
  ./bin/console shell          # Open bash shell
  ./bin/console dbconsole      # Open PostgreSQL console
  ./bin/console status         # Check all services
  ./bin/console restart-puma   # Restart Puma

${YELLOW}Server:${NC} $SERVER
${YELLOW}App path:${NC} $APP_PATH

${YELLOW}Note:${NC} Press Ctrl+D or type 'exit' to close the console/shell
EOF
}

# Function to show interactive menu
show_menu() {
    echo -e "${GREEN}==================================${NC}"
    echo -e "${GREEN}  Kula HR — Production Console${NC}"
    echo -e "${GREEN}==================================${NC}"
    echo ""
    echo -e "Select action:"
    echo ""
    echo -e "  ${BLUE}Consoles:${NC}"
    echo -e "  1) Rails console"
    echo -e "  2) Database console (PostgreSQL)"
    echo -e "  3) Bash shell"
    echo ""
    echo -e "  ${BLUE}Service Management:${NC}"
    echo -e "  4) Check service status"
    echo -e "  5) Restart Puma"
    echo -e "  6) Restart Sidekiq"
    echo -e "  7) Restart all services"
    echo ""
    echo -e "  ${BLUE}Other:${NC}"
    echo -e "  8) Direct SSH"
    echo ""
    echo -e "  0) Exit"
    echo ""
    read -p "Enter choice [0-8]: " choice

    case $choice in
        1) rails_console;;
        2) db_console;;
        3) bash_shell;;
        4) check_status;;
        5) restart_service "puma";;
        6) restart_service "sidekiq";;
        7) restart_all;;
        8) direct_ssh;;
        0) exit 0;;
        *) echo -e "${RED}Invalid choice${NC}" && exit 1;;
    esac
}

# Function to open Rails console
rails_console() {
    echo -e "${BLUE}Connecting to production server...${NC}"
    echo -e "${YELLOW}Opening Rails console (production)...${NC}"
    echo -e "${GREEN}Type 'exit' or press Ctrl+D to close${NC}"
    echo ""

    ssh -t "$SERVER" "export PATH=\"\$HOME/.rbenv/bin:\$HOME/.rbenv/shims:\$PATH\" && eval \"\$(rbenv init -)\" && cd $APP_PATH && set -a && source $ENV_FILE && set +a && RAILS_ENV=production bundle exec rails console"
}

# Function to open database console
db_console() {
    echo -e "${BLUE}Connecting to production server...${NC}"
    echo -e "${YELLOW}Opening database console (PostgreSQL)...${NC}"
    echo -e "${GREEN}Type '\\q' or press Ctrl+D to close${NC}"
    echo ""

    ssh -t "$SERVER" "export PATH=\"\$HOME/.rbenv/bin:\$HOME/.rbenv/shims:\$PATH\" && eval \"\$(rbenv init -)\" && cd $APP_PATH && set -a && source $ENV_FILE && set +a && RAILS_ENV=production bundle exec rails dbconsole"
}

# Function to open bash shell
bash_shell() {
    echo -e "${BLUE}Connecting to production server...${NC}"
    echo -e "${YELLOW}Opening bash shell...${NC}"
    echo -e "${GREEN}Type 'exit' or press Ctrl+D to close${NC}"
    echo ""

    ssh -t "$SERVER" "cd $APP_PATH && bash"
}

# Function to check service status
check_status() {
    echo -e "${BLUE}Checking service status on production...${NC}"
    echo ""

    ssh "$SERVER" << 'EOF'
        echo "======================================"
        echo "  Service Status"
        echo "======================================"
        echo ""

        echo "Puma (Web Server):"
        sudo systemctl is-active puma && echo "  Running" || echo "  Stopped"
        echo ""

        echo "Sidekiq (Background Jobs):"
        sudo systemctl is-active sidekiq && echo "  Running" || echo "  Stopped"
        echo ""

        echo "Redis (Cache + Queue):"
        (sudo systemctl is-active redis-server 2>/dev/null || sudo systemctl is-active redis 2>/dev/null) && echo "  Running" || echo "  Stopped"
        echo ""

        echo "Nginx (Reverse Proxy):"
        sudo systemctl is-active nginx && echo "  Running" || echo "  Stopped"
        echo ""

        echo "======================================"
        echo "  Resource Usage"
        echo "======================================"
        echo ""

        echo "Memory:"
        free -h | grep -E "Mem|Swap"
        echo ""

        echo "Disk:"
        df -h / | grep -v Filesystem
        echo ""

        echo "======================================"
        echo "  App Info"
        echo "======================================"
        echo ""
        echo "Current deploy:"
        cd /var/www/kulahr && git log --oneline -1
        echo ""
EOF
}

# Function to restart a service
restart_service() {
    local service=$1
    echo -e "${YELLOW}Restarting $service on production...${NC}"
    echo ""

    ssh "$SERVER" "sudo systemctl restart $service && echo '$service restarted successfully' || echo 'Failed to restart $service'"

    echo ""
    echo -e "${BLUE}Checking $service status...${NC}"
    ssh "$SERVER" "sudo systemctl status $service --no-pager -l | head -20"
}

# Function to restart all services
restart_all() {
    echo -e "${YELLOW}Restarting all services on production...${NC}"
    echo ""

    ssh "$SERVER" << 'EOF'
        echo "Restarting Puma..."
        sudo systemctl restart puma && echo "Puma restarted" || echo "Puma failed"

        echo "Restarting Sidekiq..."
        sudo systemctl restart sidekiq && echo "Sidekiq restarted" || echo "Sidekiq failed"

        echo ""
        echo "======================================"
        echo "Service Status:"
        sudo systemctl is-active puma && echo "Puma: running" || echo "Puma: stopped"
        sudo systemctl is-active sidekiq && echo "Sidekiq: running" || echo "Sidekiq: stopped"
        echo "======================================"
EOF
}

# Function for direct SSH
direct_ssh() {
    echo -e "${BLUE}Opening direct SSH connection...${NC}"
    echo -e "${GREEN}Type 'exit' or press Ctrl+D to close${NC}"
    echo ""

    ssh -t "$SERVER"
}

# Main script logic
COMMAND="${1:-}"

# If no arguments, show interactive menu
if [ -z "$COMMAND" ]; then
    show_menu
    exit 0
fi

# Parse command
case $COMMAND in
    rails|console)
        rails_console
        ;;
    dbconsole|db)
        db_console
        ;;
    shell|bash)
        bash_shell
        ;;
    status)
        check_status
        ;;
    restart-puma)
        restart_service "puma"
        ;;
    restart-sidekiq)
        restart_service "sidekiq"
        ;;
    restart-all)
        restart_all
        ;;
    ssh)
        direct_ssh
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        echo -e "${RED}Error: Unknown command '$COMMAND'${NC}"
        echo ""
        usage
        exit 1
        ;;
esac
